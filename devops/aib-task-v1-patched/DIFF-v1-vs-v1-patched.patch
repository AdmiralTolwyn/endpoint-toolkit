+            var s = totalSec % 60;
+            if(h > 0) return `${h}h ${m}m ${s}s`;
+            if(m > 0) return `${m}m ${s}s`;
+            return `${s}s`;
+        };
+
+        var printPhaseChange = (newPhase: string) => {
+            if(newPhase && newPhase !== lastPhase) {
