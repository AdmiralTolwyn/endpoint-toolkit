+                var prefix = lastPhase ? "  Γùå" : "  Γû╢";
+                console.log(`${prefix} Phase: ${arrow}  [${formatElapsed(buildStart)}]`);
+                phaseTimestamps.push({ phase: newPhase, time: Date.now() });
+                lastPhase = newPhase;
+            }
+        };
+
+        // Initial phase
+        printPhaseChange("Queued");
+
+        while(true) {
