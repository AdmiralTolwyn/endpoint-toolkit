<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="PresentationOptions"
        Title="WinGet Manifest Manager" Height="860" Width="1240"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        Background="{DynamicResource ThemeAppBg}" Foreground="{DynamicResource ThemeTextBody}" FontFamily="Inter, Segoe UI Variable Display, Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="4" GlassFrameThickness="1" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- THEME BRUSHES (Dark defaults, mutated at runtime for Light Mode) -->
        <SolidColorBrush x:Key="ThemeAppBg"           Color="#111113" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemePanelBg"         Color="#18181B" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeCardBg"          Color="#1E1E1E" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeCardAltBg"       Color="#1A1A1A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeInputBg"         Color="#141414" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeDeepBg"          Color="#0D0D0D" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeOutputBg"        Color="#0A0A0A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSurfaceBg"       Color="#1F1F23" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeHoverBg"         Color="#27272B" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSelectedBg"      Color="#2A2A2A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemePressedBg"       Color="#1A1A1A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccent"          Color="#0078D4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentHover"     Color="#1A8AD4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentLight"     Color="#60CDFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentDim"       Color="#1A0078D4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeGreenAccent"     Color="#00C853" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextPrimary"     Color="#FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextBody"        Color="#E0E0E0" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextSecondary"   Color="#A1A1AA" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextMuted"       Color="#71717A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextDim"         Color="#8B8B93" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextDisabled"    Color="#383838" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextFaintest"    Color="#6B6B73" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorder"          Color="#0FFFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderCard"      Color="#0FFFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderElevated"  Color="#333333" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderHover"     Color="#444444" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeScrollThumb"     Color="#999999" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeScrollTrack"     Color="#22FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSuccess"         Color="#00C853" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeWarning"         Color="#F59E0B" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeError"           Color="#FF5000" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSidebarBg"       Color="#111113" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSidebarBorder"   Color="#00000000" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderSubtle"    Color="#333333" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeErrorDim"        Color="#20FF5000" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeProgressEdge"    Color="#18FFFFFF" PresentationOptions:Freeze="False"/>

        <!-- DOT GRID PATTERN (tiled DrawingBrush — zero code, pure XAML) -->
        <DrawingBrush x:Key="DotGridBrush" TileMode="Tile" Viewport="0,0,44,44" ViewportUnits="Absolute"
                      Viewbox="0,0,44,44" ViewboxUnits="Absolute" PresentationOptions:Freeze="False">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <SolidColorBrush Color="#1EFFFFFF"/>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="22,22" RadiusX="1.3" RadiusY="1.3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- SCROLLVIEWER: hide the corner rectangle when both scrollbars are visible -->
        <Style TargetType="{x:Type ScrollViewer}">
            <Style.Resources>
                <Style TargetType="Rectangle">
                    <Setter Property="Fill" Value="Transparent"/>
                </Style>
            </Style.Resources>
        </Style>

        <!-- SCROLLBAR (Minimal 10px, rounded, themed) -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Background="{DynamicResource ThemeScrollTrack}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder" Background="{DynamicResource ThemeScrollThumb}" CornerRadius="4" MinHeight="40" Margin="1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ThemeAccentLight}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ThemeTextPrimary}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="GridRoot" Property="Height" Value="10"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="10"/>
                                <Setter Property="MinHeight" Value="10"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1.0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TITLE BAR BUTTONS -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeSurfaceBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#B90D1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACCENT BUTTON (Gradient, Robinhood-style) -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#005A9E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#0078D4" Direction="270" ShadowDepth="0" BlurRadius="10" Opacity="0.25"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A8AD4" Offset="0"/>
                                            <GradientStop Color="#0067C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bdr" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#0078D4" Direction="270" ShadowDepth="0" BlurRadius="16" Opacity="0.40"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#005A9E" Offset="0"/>
                                            <GradientStop Color="#004578" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="bdr" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST BUTTON (Subtle border, hover glow) -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SIGN OUT BUTTON (Red tint) -->
        <Style x:Key="DangerGhostButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent" BorderBrush="{DynamicResource ThemeBorderCard}"
                                BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeErrorDim}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeError}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeError}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ICON BUTTON (Round, subtle) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SUBSCRIPTION COMBOBOX (Dark pill, themed dropdown) -->
        <Style x:Key="SubComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ThemeDeepBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleBtn" ClickMode="Press" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bdr" Background="{DynamicResource ThemeDeepBg}"
                                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                                CornerRadius="8" Padding="10,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="10" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentSite" IsHitTestVisible="False" Margin="12,5,24,5"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropBorder" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260"
                                        Background="{DynamicResource ThemeCardBg}" CornerRadius="8"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Margin="0,2,0,0" Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.4"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SubComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bdr" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeAccentDim}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- EDITABLE COMBO BOX (themed, supports typing + dropdown) -->
        <Style x:Key="EditableComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ThemeDeepBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="True"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SubComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="bdr" Background="{DynamicResource ThemeDeepBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                    CornerRadius="8" Padding="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PART_EditableTextBox" Grid.Column="0"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource ThemeTextPrimary}"
                                             Padding="10,5" VerticalAlignment="Center"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"
                                             CaretBrush="{DynamicResource ThemeTextPrimary}"/>
                                    <ToggleButton Grid.Column="1" ClickMode="Press" Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Padding="8,4">
                                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="10" Foreground="{DynamicResource ThemeTextDim}"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropBorder" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260"
                                        Background="{DynamicResource ThemeCardBg}" CornerRadius="8"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Margin="0,2,0,0" Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.4"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TOGGLE SWITCH (Microsoft accent, animated knob) -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="40" Height="20" Margin="0,0,8,0">
                                <Border x:Name="track" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="10"
                                        BorderBrush="{DynamicResource ThemeBorderElevated}" BorderThickness="1.5"/>
                                <Border x:Name="knob" Width="14" Height="14" CornerRadius="7" HorizontalAlignment="Left" Margin="3,0,0,0"
                                        Background="{DynamicResource ThemeTextMuted}">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="KnobTranslate" X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#0078D4" Offset="0"/>
                                            <GradientStop Color="#0067C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="knob" Property="Background" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource ThemeBorderHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CONFIG LIST ITEM (Card-style with selection bar) -->
        <Style x:Key="ConfigListItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,4,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bdr" Background="{DynamicResource ThemeCardBg}"
                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                CornerRadius="8" Padding="0" SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle x:Name="selBar" Grid.Column="0" Fill="Transparent"
                                           Width="4" RadiusX="2" RadiusY="2" HorizontalAlignment="Left"/>
                                <Border Grid.Column="1" Padding="8,6,8,6">
                                    <ContentPresenter/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeBorderHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeSelectedBg}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                                <Setter TargetName="selBar" Property="Fill" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- THEMED TEXTBOX -->
        <Style x:Key="ThemedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource ThemeAccent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeBorderHover}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeDeepBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- THEMED COMBOBOX (form field version) -->
        <Style x:Key="ThemedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleBtn" ClickMode="Press" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bdr" Background="{DynamicResource ThemeInputBg}"
                                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                                CornerRadius="4" Padding="8,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="10" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeBorderHover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Display for non-editable mode -->
                            <ContentPresenter x:Name="contentSite" IsHitTestVisible="False" Margin="10,5,24,5"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <!-- TextBox for editable mode (IsEditable=True) -->
                            <TextBox x:Name="PART_EditableTextBox" Margin="10,3,24,3"
                                     VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource ThemeTextBody}"
                                     FontSize="12" CaretBrush="{DynamicResource ThemeTextBody}"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Visibility="Collapsed" Focusable="True"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropBorder" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260"
                                        Background="{DynamicResource ThemeCardBg}" CornerRadius="4"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Margin="0,2,0,0" Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.4"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- When IsEditable, show the TextBox and hide the ContentPresenter -->
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="contentSite" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GREEN CTA BUTTON -->
        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#008F3D" Offset="0"/>
                                    <GradientStop Color="#006E2E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00C853" Offset="0"/>
                                            <GradientStop Color="#008F3D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#006E2E" Offset="0"/>
                                            <GradientStop Color="#005A25" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TAB BUTTON (Pivot-style with bottom indicator) -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- MAIN LAYOUT -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="rowBottomPanel" Height="160" MinHeight="0"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Background gradient -->
        <Border Grid.Row="0" Grid.RowSpan="6">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,0" RadiusX="1.2" RadiusY="1.0">
                    <GradientStop Color="#08338833" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- ROW 0: CUSTOM TITLE BAR -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeDeepBg}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Border Background="{DynamicResource ThemeAccent}" CornerRadius="4" Width="20" Height="20" Margin="0,0,8,0">
                        <TextBlock Text="&#xE74C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="lblTitle" Text="WinGet Manifest Manager" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblTitleVersion" Text="v0.1.0-alpha" FontSize="9" Margin="8,0,0,0"
                               Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                    <Border CornerRadius="4" Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center"
                            BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                        <TextBlock Text="EXPERIMENTAL" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                    </Border>
                </StackPanel>
                <Button x:Name="btnHelp" Grid.Column="2" Style="{StaticResource TitleBarButton}" Content="?" FontSize="13" FontFamily="Segoe UI" FontWeight="Bold"
                        ToolTip="Help &amp; Keyboard Shortcuts" WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button x:Name="btnThemeToggle" Grid.Column="3" Style="{StaticResource TitleBarButton}" Content="&#x2600;" FontSize="13" FontFamily="Segoe UI"/>
                <Button x:Name="btnMinimize" Grid.Column="4" Style="{StaticResource TitleBarButton}" Content="&#xE921;"/>
                <Button x:Name="btnMaximize" Grid.Column="5" Style="{StaticResource TitleBarButton}" Content="&#xE922;"/>
                <Button x:Name="btnClose"    Grid.Column="6" Style="{StaticResource TitleBarCloseButton}" Content="&#xE8BB;"/>
            </Grid>
        </Border>

        <!-- ROW 1: AUTH BAR -->
        <Border Grid.Row="1" Background="{DynamicResource ThemeSidebarBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="12" Padding="10,4" Height="26" MinWidth="120"
                        Background="{DynamicResource ThemeInputBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="authDot" Width="7" Height="7" Fill="{DynamicResource ThemeError}" Margin="0,0,7,0"/>
                        <TextBlock x:Name="lblAuthStatus" Text="Not connected" FontSize="11"
                                   Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"
                                   MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                <ComboBox x:Name="cmbSubscription" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                          MinWidth="180" MaxWidth="360" Visibility="Collapsed"
                          FontSize="11" FontFamily="Segoe UI Variable Small, Segoe UI"
                          Style="{StaticResource SubComboBox}"/>
                <ComboBox x:Name="cmbRestSource" Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center"
                          MinWidth="160" MaxWidth="320" Visibility="Collapsed"
                          FontSize="11" FontFamily="Segoe UI Variable Small, Segoe UI"
                          Style="{StaticResource SubComboBox}" ToolTip="Active WinGet REST source"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,0,4,0">
                    <Button x:Name="btnLogin" Style="{StaticResource AccentButton}" Padding="16,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Sign In" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Button x:Name="btnLogout" Grid.Column="5" Style="{StaticResource DangerGhostButton}" Content="Sign Out" Visibility="Collapsed" Padding="12,4"/>
            </Grid>
        </Border>

        <!-- ROW 1.5: Accent glow separator (Bagel Commander pattern) -->
        <Border Grid.Row="1" VerticalAlignment="Bottom" Height="1" Panel.ZIndex="1"
                Background="{DynamicResource ThemeAccent}" Opacity="0.25" IsHitTestVisible="False"/>



        <!-- ROW 2: MAIN CONTENT (5-column grid) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition x:Name="colLeftPanel" Width="260" MinWidth="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT ICON RAIL -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeSidebarBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                <DockPanel>
                <StackPanel Margin="0,8,0,0" DockPanel.Dock="Top">
                    <Button x:Name="btnHamburger" Width="32" Height="32" Margin="0,0,0,6"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                    <TextBlock Text="&#xE700;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Package Configs rail icon -->
                    <Button x:Name="railConfigs" Width="32" Height="32" Margin="0,0,0,2" ToolTip="Package Configs"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Rectangle x:Name="railConfigsIndicator" Width="3" Fill="{DynamicResource ThemeAccentLight}"
                                               HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                    <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                        <TextBlock x:Name="railConfigsIcon" Text="&#xE7C3;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Storage rail icon -->
                    <Button x:Name="railStorage" Width="32" Height="32" Margin="0,0,0,2" ToolTip="Storage Accounts"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Rectangle x:Name="railStorageIndicator" Width="3" Fill="Transparent"
                                               HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                    <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                        <TextBlock x:Name="railStorageIcon" Text="&#xE753;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="14" Foreground="{DynamicResource ThemeTextDim}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Settings rail icon -->
                    <Button x:Name="railSettings" Width="32" Height="32" Margin="0,0,0,2" ToolTip="Settings"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Rectangle x:Name="railSettingsIndicator" Width="3" Fill="Transparent"
                                               HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                    <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                        <TextBlock x:Name="railSettingsIcon" Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="14" Foreground="{DynamicResource ThemeTextDim}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <!-- Output toggle at bottom of rail -->
                <Button x:Name="railOutput" DockPanel.Dock="Bottom" Width="32" Height="32" Margin="0,0,0,8" ToolTip="Toggle Output Panel"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Bottom">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                </DockPanel>
            </Border>

            <!-- LEFT PANEL (collapsible) -->
            <Border x:Name="pnlLeftSidebar" Grid.Column="1" Background="{DynamicResource ThemePanelBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Package Configs Section -->
                    <Border x:Name="grpLeftConfigs" Grid.Row="0" Padding="0,4">
                        <StackPanel>
                            <Border x:Name="grpLeftConfigsHeader" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="PACKAGE CONFIGS" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="btnNewConfig" Style="{StaticResource IconButton}" Width="24" Height="24" ToolTip="New Manifest (clears form)">
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                                        </Button>
                                        <Button x:Name="btnRefreshConfigs" Style="{StaticResource IconButton}" Width="24" Height="24" ToolTip="Refresh">
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ListView x:Name="lstConfigs" Background="Transparent" BorderThickness="0"
                                      MaxHeight="300" Margin="4,0"
                                      ItemContainerStyle="{StaticResource ConfigListItem}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            </ListView>
                            <TextBlock x:Name="lblConfigEmpty" Text="No package configs found" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextDisabled}" Margin="16,8"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <!-- Storage Accounts Section -->
                    <Border x:Name="grpLeftStorage" Grid.Row="0" Padding="0,4" Visibility="Collapsed">
                        <StackPanel>
                            <Border Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE753;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="STORAGE ACCOUNTS" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="btnNewStorage" Style="{StaticResource IconButton}" Width="24" Height="24" ToolTip="New Storage Account">
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                                        </Button>
                                        <Button x:Name="btnRefreshStorage" Style="{StaticResource IconButton}" Width="24" Height="24" ToolTip="Refresh">
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ListView x:Name="tvStorage" Background="Transparent" BorderThickness="0"
                                      MaxHeight="400" Margin="4,0"
                                      ItemContainerStyle="{StaticResource ConfigListItem}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                            <TextBlock x:Name="lblStorageEmpty" Text="Sign in to discover storage accounts" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextDisabled}" Margin="16,16" HorizontalAlignment="Center"
                                       FontStyle="Italic" TextAlignment="Center"/>

                            <!-- Storage Info (detail) -->
                            <Border x:Name="grpLeftStorageInfo" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="12,8" Margin="0,4,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="STORAGE INFO" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="pnlStorageInfoRows">
                                            <TextBlock x:Name="lblStorageInfo" Text="Select a storage account" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextDisabled}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Settings Section -->
                    <Border x:Name="grpLeftSettings" Grid.Row="0" Padding="0,4" Visibility="Collapsed" VerticalAlignment="Top">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="12,4">
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,10">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="SETTINGS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- ── Source & Paths ── -->
                            <TextBlock Text="REST Source Function Name" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtRestSourceName" Style="{StaticResource ThemedTextBox}" Grid.Column="0"
                                         Text="func-corpwinget"/>
                                <Button x:Name="btnTestRestSource" Style="{StaticResource GhostButton}" Grid.Column="1"
                                        Margin="6,0,0,0" Padding="10,5" ToolTip="Test REST source connectivity">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8AF;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="Test" FontSize="11"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnConnectCmd" Style="{StaticResource GhostButton}" Grid.Column="2"
                                        Margin="4,0,0,0" Padding="10,5"
                                        ToolTip="Generate the 'winget source add' command for this REST source (resolves APIM gateway URL when fronted, otherwise uses the Function App URL)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE71B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="Connect" FontSize="11"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock x:Name="lblRestSourceStatus" Text="" FontSize="10"
                                       Foreground="{DynamicResource ThemeTextMuted}" Margin="0,-6,0,10" TextWrapping="Wrap"/>

                            <!-- Saved REST Sources -->
                            <TextBlock Text="Saved Sources" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="cmbSavedSources" Style="{StaticResource ThemedComboBox}" Grid.Column="0"
                                          ToolTip="Switch between saved REST source endpoints"/>
                                <Button x:Name="btnSaveSource" Style="{StaticResource GhostButton}" Grid.Column="1"
                                        Margin="4,0,0,0" Padding="8,5" ToolTip="Save current source name to list">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                </Button>
                                <Button x:Name="btnDeleteSource" Style="{StaticResource GhostButton}" Grid.Column="2"
                                        Margin="4,0,0,0" Padding="8,5" ToolTip="Remove selected source from list">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{DynamicResource ThemeError}"/>
                                </Button>
                            </Grid>

                            <TextBlock Text="Default Manifest Path" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtManifestPath" Style="{StaticResource ThemedTextBox}" Grid.Column="0"/>
                                <Button x:Name="btnBrowseManifestPath" Style="{StaticResource IconButton}" Grid.Column="1" Width="28" Height="28" Margin="4,0,0,0" ToolTip="Browse...">
                                    <TextBlock Text="&#xED25;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="Default Manifest Version" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbManifestVersion" Style="{StaticResource ThemedComboBox}" Margin="0,0,0,10">
                                <ComboBoxItem Content="1.9.0" IsSelected="True"/>
                                <ComboBoxItem Content="1.6.0"/>
                            </ComboBox>
                            <TextBlock Text="Default Container" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtDefaultContainer" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                     Text="packages" ToolTip="Default blob container for package uploads"/>

                            <!-- ── Separator ── -->
                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,2,0,10"/>

                            <!-- ── Cache & Performance ── -->
                            <TextBlock Text="Package Cache TTL (seconds)" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,2"/>
                            <TextBlock Text="How long to keep queried package lists before re-fetching. Set 0 to always query live." FontSize="9"
                                       Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBox x:Name="txtCacheTTL" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                     Text="300" ToolTip="Cache time-to-live in seconds (default: 300 = 5 minutes). Set 0 to disable caching."/>

                            <!-- ── Separator ── -->
                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,2,0,10"/>

                            <!-- ── Discovery & Defaults ── -->
                            <TextBlock Text="Source Discovery Pattern" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,2"/>
                            <TextBlock Text="Regex filter for Function App names. Apps matching this OR containing 'winget' are always discovered. Default: ^func-|winget" FontSize="9"
                                       Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBox x:Name="txtDiscoveryPattern" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                     Text="^func-|winget" ToolTip="Regex pattern — Function Apps matching this OR containing 'winget' are discovered. Use pipe (|) for multiple patterns."/>

                            <TextBlock Text="Default Subscription" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,2"/>
                            <TextBlock Text="Auto-select this subscription after sign-in (by name)" FontSize="9"
                                       Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <ComboBox x:Name="cmbDefaultSubscription" Style="{StaticResource EditableComboBox}" Margin="0,0,0,10"
                                      ToolTip="Select from discovered subscriptions or leave blank for Azure context default"/>

                            <!-- ── Separator ── -->
                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,2,0,10"/>

                            <!-- ── Appearance & Behaviour ── -->
                            <CheckBox x:Name="chkDarkMode" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,4,0,4">
                                <TextBlock Text="Dark Mode" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                            </CheckBox>
                            <CheckBox x:Name="chkDebug" Style="{StaticResource ToggleSwitch}" Margin="0,6,0,4">
                                <TextBlock Text="Debug Overlay" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                            </CheckBox>
                            <CheckBox x:Name="chkAutoSave" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,6,0,4">
                                <TextBlock Text="Auto-save Prefs on Exit" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                            </CheckBox>
                            <CheckBox x:Name="chkConfirmUpload" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,6,0,4">
                                <TextBlock Text="Confirm Before Upload" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                            </CheckBox>
                            <CheckBox x:Name="chkDisableAnimations" Style="{StaticResource ToggleSwitch}" Margin="0,6,0,4">
                                <TextBlock Text="Disable Animations" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                            </CheckBox>

                            <!-- ── Maintenance ── -->
                            <Button x:Name="btnPurgeDownloads" Style="{StaticResource GhostButton}" Margin="0,6,0,0" Padding="8,5"
                                    HorizontalAlignment="Left" ToolTip="Delete all cached installer downloads from the temp folder">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"
                                               Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBlock Text="Purge Downloads" FontSize="11" VerticalAlignment="Center"
                                               Foreground="{DynamicResource ThemeTextSecondary}"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnRestoreDefaults" Style="{StaticResource GhostButton}" Margin="0,6,0,0" Padding="8,5"
                                    HorizontalAlignment="Left" ToolTip="Reset all settings to factory defaults">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,6,0"
                                               Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBlock Text="Restore Defaults" FontSize="11" VerticalAlignment="Center"
                                               Foreground="{DynamicResource ThemeTextSecondary}"/>
                                </StackPanel>
                            </Button>

                            <!-- ── Separator ── -->
                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,10"/>

                            <!-- ── About ── -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="9"
                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="ABOUT" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="WinGet Manifest Manager" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,4,0,1"/>
                            <TextBlock Text="by Anton Romanyuk" FontSize="10" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,2"/>
                            <TextBlock x:Name="lblSettingsVersion" Text="v0.1.0-alpha" FontSize="9"
                                       Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,2"/>
                            <TextBlock x:Name="lblSettingsCommit" Text="" FontSize="9"
                                       Foreground="{DynamicResource ThemeTextDisabled}" Margin="0,0,0,2"
                                       ToolTip="Git commit hash for this build"/>
                            <TextBlock Text="PowerShell + WPF" FontSize="9"
                                       Foreground="{DynamicResource ThemeTextDisabled}"/>
                            <TextBlock x:Name="lblSettingsPrefsPath" Text="" FontSize="9"
                                       Foreground="{DynamicResource ThemeTextDisabled}" TextWrapping="Wrap" Margin="0,4,0,0"
                                       ToolTip="Settings file location"/>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Bottom section: Achievements + Config count -->
                    <Border x:Name="grpLeftBottomBorder" Grid.Row="1" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <!-- Achievements (collapsible) -->
                            <Border x:Name="grpLeftAchievements" Padding="12,8">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6" Cursor="Hand">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE735;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeWarning}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="ACHIEVEMENTS" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="lblAchievementCount" Text="0/8" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                        <Button x:Name="btnToggleAchievements" Grid.Column="1" Style="{StaticResource IconButton}" Width="20" Height="20"
                                                ToolTip="Collapse/expand achievements">
                                            <TextBlock x:Name="txtAchievementChevron" Text="&#xE70E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="9"
                                                       Foreground="{DynamicResource ThemeTextDim}" RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.RenderTransform><RotateTransform Angle="180"/></TextBlock.RenderTransform>
                                            </TextBlock>
                                        </Button>
                                    </Grid>
                                    <WrapPanel x:Name="pnlAchievements" Margin="0,0,0,2"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="12,6">
                                <TextBlock x:Name="lblConfigCount" Text="0 configs" FontSize="10"
                                           Foreground="{DynamicResource ThemeTextDisabled}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- LEFT SPLITTER -->
            <GridSplitter x:Name="splitterLeft" Grid.Column="2" Width="3" Background="Transparent"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" Cursor="SizeWE"/>

            <!-- CENTER CONTENT -->
            <Border Grid.Column="3" Background="{DynamicResource ThemeAppBg}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- BACKGROUND LAYERS (dot grid + accent gradient glow) -->
                    <!-- Layer 1: Dot grid pattern -->
                    <Border x:Name="bdrDotGrid" Grid.Row="0" Background="{StaticResource DotGridBrush}" IsHitTestVisible="False" Panel.ZIndex="-2"/>

                    <!-- Layer 2: Accent-to-transparent gradient glow at top -->
                    <Border x:Name="bdrGradientGlow" Grid.Row="0" IsHitTestVisible="False" Panel.ZIndex="-1" Height="320" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#200078D4" Offset="0.0"/>
                                <GradientStop Color="#100078D4" Offset="0.35"/>
                                <GradientStop Color="#080078D4" Offset="0.6"/>
                                <GradientStop Color="#00000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Layer 3: Center radial glow -->
                    <Border Grid.Row="0" IsHitTestVisible="False" Panel.ZIndex="-1"
                            HorizontalAlignment="Center" VerticalAlignment="Top"
                            Width="800" Height="400" Margin="0,40,0,0" Opacity="0.55">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#200078D4" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- NEW STORAGE ACCOUNT OVERLAY -->
                    <Border x:Name="pnlNewStorage" Grid.Row="0" Visibility="Collapsed" Panel.ZIndex="10"
                            Background="{DynamicResource ThemeCardBg}" CornerRadius="12"
                            BorderBrush="{DynamicResource ThemeAccent}" BorderThickness="1"
                            Padding="28,24" Margin="40,30" VerticalAlignment="Top" HorizontalAlignment="Center"
                            MaxWidth="520" MinWidth="440">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="6" BlurRadius="24" Opacity="0.45"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Header -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource ThemeAccentDim}" CornerRadius="8" Width="36" Height="36" Margin="0,0,12,0">
                                    <TextBlock Text="&#xE753;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="17"
                                               Foreground="{DynamicResource ThemeAccentLight}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Create Storage Account" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextPrimary}"/>
                                    <TextBlock Text="Provision a new Azure Storage Account" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextDim}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button x:Name="btnCloseNewStorage" Grid.Column="2" Style="{StaticResource IconButton}" Width="28" Height="28" ToolTip="Close">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,18"/>

                            <!-- Resource Group -->
                            <TextBlock Text="Resource Group *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="cmbNewStorageRG" Style="{StaticResource ThemedComboBox}" Grid.Column="0" IsEditable="True"
                                          ToolTip="Select existing or type a new resource group name"/>
                                <Button x:Name="btnRefreshRGs" Style="{StaticResource IconButton}" Grid.Column="1" Width="28" Height="28" Margin="4,0,0,0" ToolTip="Refresh">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                               Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                            </Grid>

                            <!-- Storage Account Name -->
                            <TextBlock Text="Storage Account Name *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtNewStorageName" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,4"
                                     MaxLength="24" ToolTip="3-24 chars, lowercase letters and numbers only"/>
                            <TextBlock x:Name="lblStorageNameHint" Text="3-24 characters, lowercase letters and numbers only"
                                       FontSize="9" Foreground="{DynamicResource ThemeTextDisabled}" Margin="0,0,0,12"/>

                            <!-- Location + SKU row -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Location *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbNewStorageLocation" Style="{StaticResource ThemedComboBox}">
                                        <ComboBoxItem Content="westeurope" IsSelected="True"/>
                                        <ComboBoxItem Content="northeurope"/>
                                        <ComboBoxItem Content="eastus"/>
                                        <ComboBoxItem Content="eastus2"/>
                                        <ComboBoxItem Content="westus2"/>
                                        <ComboBoxItem Content="westus3"/>
                                        <ComboBoxItem Content="centralus"/>
                                        <ComboBoxItem Content="uksouth"/>
                                        <ComboBoxItem Content="ukwest"/>
                                        <ComboBoxItem Content="southeastasia"/>
                                        <ComboBoxItem Content="australiaeast"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="SKU" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbNewStorageSku" Style="{StaticResource ThemedComboBox}">
                                        <ComboBoxItem Content="Standard_LRS" IsSelected="True"/>
                                        <ComboBoxItem Content="Standard_GRS"/>
                                        <ComboBoxItem Content="Standard_ZRS"/>
                                        <ComboBoxItem Content="Standard_RAGRS"/>
                                        <ComboBoxItem Content="Premium_LRS"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Kind -->
                            <TextBlock Text="Kind" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbNewStorageKind" Style="{StaticResource ThemedComboBox}" Margin="0,0,0,12">
                                <ComboBoxItem Content="StorageV2" IsSelected="True"/>
                                <ComboBoxItem Content="BlobStorage"/>
                                <ComboBoxItem Content="BlockBlobStorage"/>
                            </ComboBox>

                            <!-- Enable blob public access toggle -->
                            <CheckBox x:Name="chkNewStoragePublicAccess" Style="{StaticResource ToggleSwitch}" Margin="0,4,0,16">
                                <TextBlock Text="Allow blob public access" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                            </CheckBox>

                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,16"/>

                            <!-- Status + Actions -->
                            <TextBlock x:Name="lblNewStorageStatus" Text="" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"
                                       Margin="0,0,0,12" TextWrapping="Wrap"/>
                            <ProgressBar x:Name="prgNewStorage" Height="3" Margin="0,0,0,12" Visibility="Collapsed"
                                         Background="{DynamicResource ThemeSurfaceBg}" Foreground="{DynamicResource ThemeAccent}" IsIndeterminate="True"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnCancelNewStorage" Style="{StaticResource GhostButton}" Content="Cancel" Padding="16,7" Margin="0,0,8,0"/>
                                <Button x:Name="btnCreateStorage" Style="{StaticResource AccentButton}" Padding="20,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Create" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Prereq Error Panel (shown when modules missing) -->
                    <Border x:Name="pnlPrereqError" Grid.Row="0" Visibility="Collapsed"
                            Background="{DynamicResource ThemeCardBg}" CornerRadius="12"
                            BorderBrush="{DynamicResource ThemeError}" BorderThickness="1"
                            Padding="24,20" Margin="20" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="&#xE783;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="28"
                                       Foreground="{DynamicResource ThemeError}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock x:Name="lblPrereqMessage" Text="Missing Required Modules" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource ThemeTextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <StackPanel x:Name="pnlModuleStatus" Margin="0,0,0,16"/>
                            <TextBlock Text="Run this command to install missing modules:" FontSize="11"
                                       Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtPrereqCommand" Style="{StaticResource ThemedTextBox}" IsReadOnly="True"
                                         FontFamily="Cascadia Code, Consolas" FontSize="11" Grid.Column="0"/>
                                <Button x:Name="btnCopyCommand" Style="{StaticResource GhostButton}" Content="Copy" Grid.Column="1" Margin="6,0,0,0" Padding="12,5"/>
                            </Grid>
                            <Button x:Name="btnRetryPrereq" Style="{StaticResource AccentButton}" Content="Retry Check" Margin="0,16,0,0"
                                    HorizontalAlignment="Center" Padding="20,8"/>
                        </StackPanel>
                    </Border>

                    <!-- Toast Notification Overlay -->
                    <StackPanel x:Name="pnlToastHost" Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Right"
                                Margin="0,8,16,0" Panel.ZIndex="999" MaxWidth="360"/>

                    <!-- Tab Control -->
                    <Grid x:Name="pnlMainContent" Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tab Header Bar -->
                        <Border Grid.Row="0" Background="{DynamicResource ThemeDeepBg}"
                                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1" Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="tabCreate" Style="{StaticResource TabButton}" Content="Create"
                                        BorderBrush="{DynamicResource ThemeAccent}" Foreground="{DynamicResource ThemeTextPrimary}"
                                        FontWeight="SemiBold" Margin="0,0,2,0"/>
                                <Button x:Name="tabEdit" Style="{StaticResource TabButton}" Content="Edit" Margin="0,0,2,0"/>
                                <Button x:Name="tabUpload" Style="{StaticResource TabButton}" Content="Upload" Margin="0,0,2,0"/>
                                <Button x:Name="tabManage" Style="{StaticResource TabButton}" Content="Manage" Margin="0,0,2,0"/>

                                <!-- Separator: Package Management | Source Management -->
                                <Border Width="1" Margin="8,6" Background="{DynamicResource ThemeBorderCard}" VerticalAlignment="Stretch"/>

                                <Button x:Name="tabDeploy" Style="{StaticResource TabButton}" Margin="0,0,2,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Deploy Source" VerticalAlignment="Center"/>
                                        <Border CornerRadius="6" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                                            <TextBlock Text="BETA" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                                        </Border>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="tabRemove" Style="{StaticResource TabButton}" Margin="0,0,2,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Remove Source" VerticalAlignment="Center"/>
                                        <Border CornerRadius="6" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                                            <TextBlock Text="BETA" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                                        </Border>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="tabBackup" Style="{StaticResource TabButton}" Margin="0,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Backup &amp; Restore" VerticalAlignment="Center"/>
                                        <Border CornerRadius="6" Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                                            <TextBlock Text="BETA" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Global Progress Bar (Bagel Commander style) -->
                        <Grid x:Name="pnlGlobalProgress" Grid.Row="1" Visibility="Collapsed" ClipToBounds="True">
                            <!-- Background track -->
                            <Border Height="22" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="0"/>
                            <!-- Determinate fill (used when Value > 0) -->
                            <ProgressBar x:Name="prgGlobal" Height="22" Minimum="0" Maximum="100" Value="0"
                                         Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#0078D4" Offset="0.0"/>
                                        <GradientStop Color="#60CDFF" Offset="0.5"/>
                                        <GradientStop Color="#0078D4" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                            <!-- Indeterminate shimmer (animated gradient band) -->
                            <Border x:Name="brdGlobalShimmer" Height="22" CornerRadius="0">
                                <Border.Background>
                                    <LinearGradientBrush x:Name="shimmerBrush" StartPoint="0,0" EndPoint="1,0"
                                                         MappingMode="RelativeToBoundingBox" SpreadMethod="Pad">
                                        <GradientStop Color="Transparent"  Offset="0.0"/>
                                        <GradientStop Color="#0078D4"      Offset="0.15"/>
                                        <GradientStop Color="#60CDFF"      Offset="0.35"/>
                                        <GradientStop Color="#0078D4"      Offset="0.55"/>
                                        <GradientStop Color="Transparent"  Offset="0.7"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="shimmerTranslate" X="-400"/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="shimmerTranslate"
                                                                 Storyboard.TargetProperty="X"
                                                                 From="-500" To="1200"
                                                                 Duration="0:0:2.0"
                                                                 AutoReverse="False"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                            <!-- Subtle top/bottom edge lines for depth -->
                            <Border Height="22" BorderThickness="0,1,0,1"
                                    BorderBrush="{DynamicResource ThemeProgressEdge}" IsHitTestVisible="False"/>
                            <!-- Centered label overlay -->
                            <TextBlock x:Name="lblGlobalProgress" Text="" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="Black" Opacity="0.6"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>

                        <!-- Tab Content Panels -->
                        <Grid Grid.Row="2">
                            <!-- TAB: CREATE MANIFEST -->
                            <ScrollViewer x:Name="pnlTabCreate" VerticalScrollBarVisibility="Auto" Padding="24,16">
                                <StackPanel MaxWidth="700">
                                    <!-- Breadcrumb Stepper -->
                                    <Border Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12" Padding="12,8" Margin="0,0,0,20"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel x:Name="pnlStepper" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button x:Name="stepIdentity" Style="{StaticResource GhostButton}" Padding="10,4" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="20" Height="20" CornerRadius="12" Background="{DynamicResource ThemeAccent}" Margin="0,0,6,0">
                                                        <TextBlock Text="1" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="Identity" FontSize="11" Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBlock Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextDisabled}" VerticalAlignment="Center" Margin="4,0"/>
                                            <Button x:Name="stepMetadata" Style="{StaticResource GhostButton}" Padding="10,4" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="20" Height="20" CornerRadius="12" Background="{DynamicResource ThemeSurfaceBg}" Margin="0,0,6,0">
                                                        <TextBlock Text="2" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="Metadata" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBlock Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextDisabled}" VerticalAlignment="Center" Margin="4,0"/>
                                            <Button x:Name="stepInstaller" Style="{StaticResource GhostButton}" Padding="10,4" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="20" Height="20" CornerRadius="12" Background="{DynamicResource ThemeSurfaceBg}" Margin="0,0,6,0">
                                                        <TextBlock Text="3" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="Installer" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <TextBlock Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextDisabled}" VerticalAlignment="Center" Margin="4,0"/>
                                            <Button x:Name="stepReview" Style="{StaticResource GhostButton}" Padding="10,4" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="20" Height="20" CornerRadius="12" Background="{DynamicResource ThemeSurfaceBg}" Margin="0,0,6,0">
                                                        <TextBlock Text="4" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="Review" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <!-- Import PSADT -->
                                    <Border Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource ThemeAccentDim}" BorderThickness="1"
                                            Padding="14,10" Margin="0,0,0,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Import from PSADT" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextPrimary}"/>
                                                <TextBlock Text="Auto-fill all fields from a PSADT package folder or ZIP"
                                                           FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button x:Name="btnImportPSADT" Grid.Column="1" Style="{StaticResource AccentButton}"
                                                    Padding="16,8" ToolTip="Import a PSADT package folder or ZIP and auto-fill manifest fields">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8B5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Import PSADT" FontSize="12" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Import from Community Repo -->
                                    <Border Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource ThemeAccentDim}" BorderThickness="1"
                                            Padding="14,10" Margin="0,0,0,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Column="0" Grid.Row="0" VerticalAlignment="Center">
                                                <TextBlock Text="Import from WinGet Community" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextPrimary}"/>
                                                <TextBlock Text="Fetch manifest from microsoft/winget-pkgs GitHub repo"
                                                           FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button x:Name="btnImportCommunity" Grid.Column="1" Grid.Row="0" Style="{StaticResource GhostButton}"
                                                    Padding="12,8" ToolTip="Fetch a package manifest from the WinGet community repository on GitHub">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                               Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Import" FontSize="12" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                                </StackPanel>
                                            </Button>
                                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="110"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                        <TextBlock Text="Package ID" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,3"/>
                                                        <TextBox x:Name="txtCommunityPkgId" Style="{StaticResource ThemedTextBox}"
                                                                 Tag="e.g. Microsoft.VisualStudioCode"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Version (optional)" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,3"/>
                                                        <TextBox x:Name="txtCommunityVersion" Style="{StaticResource ThemedTextBox}"
                                                                 Tag="latest"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="Enter a WinGet package ID (e.g. Google.Chrome) and click Import to auto-fill all fields from the public repository."
                                                           FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,6,0,0"
                                                           FontStyle="Italic"/>

                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Step 1: Package Identity (Collapsible) -->
                                    <Border x:Name="secIdentityHeader" Cursor="Hand" Background="Transparent" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="secIdentityChevron" Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="10" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="PACKAGE IDENTITY" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeAccentLight}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="secIdentityBody">

                                    <TextBlock Text="Package Identifier *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtPkgId" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                             ToolTip="e.g., 7zip.7zip (Publisher.Package)"/>

                                    <TextBlock Text="Package Version *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtPkgVersion" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                             ToolTip="e.g., 24.09"/>

                                    <TextBlock Text="Manifest Version *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbCreateManifestVer" Style="{StaticResource ThemedComboBox}" Margin="0,0,0,20">
                                        <ComboBoxItem Content="1.9.0" IsSelected="True"/>
                                        <ComboBoxItem Content="1.6.0"/>
                                    </ComboBox>

                                    </StackPanel>
                                    <!-- /secIdentityBody -->

                                    <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,20"/>

                                    <!-- Step 2: Default Locale Metadata (Collapsible) -->
                                    <Border x:Name="secMetadataHeader" Cursor="Hand" Background="Transparent" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="secMetadataChevron" Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="10" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="PACKAGE METADATA" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeAccentLight}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="secMetadataBody">

                                    <!-- Metadata Template Selector -->
                                    <Border Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="8" Padding="10,8" Margin="0,0,0,12"
                                            BorderBrush="{DynamicResource ThemeBorderSubtle}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8F1;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                           Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Template" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ComboBox x:Name="cmbMetadataTemplate" Grid.Column="2" Style="{StaticResource ThemedComboBox}"
                                                      ToolTip="Pre-fill metadata fields with organization defaults">
                                                <ComboBoxItem Content="(none)" IsSelected="True"/>
                                                <ComboBoxItem Content="Internal LOB App"/>
                                                <ComboBoxItem Content="Open Source Tool"/>
                                                <ComboBoxItem Content="Commercial Software"/>
                                                <ComboBoxItem Content="Custom..."/>
                                            </ComboBox>
                                            <Button x:Name="btnApplyTemplate" Grid.Column="4" Style="{StaticResource GhostButton}"
                                                    Content="Apply" Padding="12,5" ToolTip="Apply the selected template to pre-fill metadata fields"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Package Name *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtPkgName" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"/>

                                    <TextBlock Text="Publisher *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtPublisher" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"/>

                                    <TextBlock Text="License *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtLicense" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"/>

                                    <TextBlock Text="Short Description * (max 256)" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtShortDesc" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10" MaxLength="256"/>

                                    <TextBlock Text="Description" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtDescription" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                             AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Author" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtAuthor" Style="{StaticResource ThemedTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Moniker" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtMoniker" Style="{StaticResource ThemedTextBox}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Package URL" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtPackageUrl" Style="{StaticResource ThemedTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Publisher URL" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtPublisherUrl" Style="{StaticResource ThemedTextBox}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="License URL" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtLicenseUrl" Style="{StaticResource ThemedTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Publisher Support URL" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtSupportUrl" Style="{StaticResource ThemedTextBox}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Copyright" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtCopyright" Style="{StaticResource ThemedTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Privacy URL" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtPrivacyUrl" Style="{StaticResource ThemedTextBox}"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Tags (comma-separated)" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtTags" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                             ToolTip="e.g., archive, compress, zip"/>

                                    <TextBlock Text="Release Notes" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtReleaseNotes" Style="{StaticResource ThemedTextBox}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" MaxHeight="120" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"
                                             ToolTip="Free-form release notes text (multiline)"/>

                                    <TextBlock Text="Release Notes URL" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtReleaseNotesUrl" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,20"/>

                                    </StackPanel> <!-- /secMetadataBody -->

                                    <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,20"/>

                                    <!-- Step 3: Installer (Collapsible) -->
                                    <Border x:Name="secInstallerHeader" Cursor="Hand" Background="Transparent" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="secInstallerChevron" Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="10" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="INSTALLER" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeAccentLight}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="secInstallerBody">

                                    <!-- Installer Preset -->
                                    <Border Background="{DynamicResource ThemeCardAltBg}" CornerRadius="8" Padding="12,10"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE771;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                           Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Preset" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ComboBox x:Name="cmbInstallerPreset" Grid.Column="2" Style="{StaticResource ThemedComboBox}"
                                                      ToolTip="Auto-fill installer fields based on common deployment patterns">
                                                <ComboBoxItem Content="(none)" IsSelected="True"/>
                                                <ComboBoxItem Content="PSADT (Deploy-Application.exe)"/>
                                                <ComboBoxItem Content="PSADT (PowerShell wrapper)"/>
                                                <ComboBoxItem Content="Standard MSI"/>
                                                <ComboBoxItem Content="Standard EXE (Inno Setup)"/>
                                                <ComboBoxItem Content="Standard EXE (NSIS)"/>
                                                <ComboBoxItem Content="Burn Bundle"/>
                                                <ComboBoxItem Content="MSIX / AppX"/>
                                                <ComboBoxItem Content="Portable (ZIP)"/>
                                            </ComboBox>
                                            <Button x:Name="btnApplyPreset" Grid.Column="4" Style="{StaticResource GhostButton}"
                                                    Content="Apply" Padding="12,5" ToolTip="Apply the selected preset to auto-fill fields"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel x:Name="pnlInstallers">
                                        <!-- Primary installer (always visible) -->
                                        <Border x:Name="pnlInstaller0" Background="{DynamicResource ThemeCardBg}"
                                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                                CornerRadius="12" Padding="16,12" Margin="0,0,0,10">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Installer Type *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <ComboBox x:Name="cmbInstallerType0" Style="{StaticResource ThemedComboBox}">
                                                            <ComboBoxItem Content="exe"/>
                                                            <ComboBoxItem Content="msi"/>
                                                            <ComboBoxItem Content="msix"/>
                                                            <ComboBoxItem Content="wix"/>
                                                            <ComboBoxItem Content="zip"/>
                                                            <ComboBoxItem Content="burn"/>
                                                            <ComboBoxItem Content="inno"/>
                                                            <ComboBoxItem Content="nullsoft"/>
                                                            <ComboBoxItem Content="portable"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Architecture *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <ComboBox x:Name="cmbArch0" Style="{StaticResource ThemedComboBox}">
                                                            <ComboBoxItem Content="x64" IsSelected="True"/>
                                                            <ComboBoxItem Content="x86"/>
                                                            <ComboBoxItem Content="arm64"/>
                                                            <ComboBoxItem Content="neutral"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Scope" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <ComboBox x:Name="cmbScope0" Style="{StaticResource ThemedComboBox}">
                                                            <ComboBoxItem Content="machine"/>
                                                            <ComboBoxItem Content="user"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Local File Picker + SHA256 -->
                                                <TextBlock Text="Local Installer File *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Browse or drag &amp; drop a file to generate SHA256 hash. Use the Upload tab to push to blob storage (auto-fills URL below), or enter an external vendor URL manually." FontSize="9.5" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                <Border x:Name="dropZoneInstaller0" AllowDrop="True" Background="Transparent"
                                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                                        CornerRadius="8" Padding="4" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="txtLocalFile0" Style="{StaticResource ThemedTextBox}" IsReadOnly="True" Grid.Column="0"
                                                                 ToolTip="Select the installer file to compute its SHA256 hash. Also syncs to Upload tab."/>
                                                        <Button x:Name="btnBrowseFile0" Style="{StaticResource GhostButton}" Content="Browse..." Grid.Column="1" Margin="6,0,0,0" Padding="12,5"/>
                                                    </Grid>
                                                </Border>
                                                <TextBlock x:Name="lblHash0" Text="" FontSize="10" FontFamily="Cascadia Code, Consolas"
                                                           Foreground="{DynamicResource ThemeGreenAccent}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                                <!-- Installer URL -->
                                                <TextBlock Text="Installer URL *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="txtInstallerUrl0" Style="{StaticResource ThemedTextBox}" Grid.Column="0"
                                                             ToolTip="Auto-filled after uploading via the Upload tab, or enter a vendor download URL manually"/>
                                                    <Button x:Name="btnTestUrl0" Style="{StaticResource GhostButton}" Content="Test" Grid.Column="1"
                                                            Margin="6,0,0,0" Padding="10,5" ToolTip="Check if URL is reachable (HEAD request)"/>
                                                    <Button x:Name="btnHashUrl0" Style="{StaticResource GhostButton}" Grid.Column="2"
                                                            Margin="4,0,0,0" Padding="10,5"
                                                            ToolTip="Download installer from URL and stage for upload to storage account">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock Text="Download" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button x:Name="btnCancelDownload" Style="{StaticResource GhostButton}" Grid.Column="3"
                                                            Margin="4,0,0,0" Padding="8,5" Visibility="Collapsed"
                                                            ToolTip="Cancel the current download">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="{DynamicResource ThemeError}"/>
                                                    </Button>
                                                </Grid>

                                                <!-- Installer switches -->
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Silent Switch" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txtSilent0" Style="{StaticResource ThemedTextBox}" ToolTip="e.g., /S or /quiet"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Silent w/ Progress Switch" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txtSilentProgress0" Style="{StaticResource ThemedTextBox}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Upgrade Behavior" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <ComboBox x:Name="cmbUpgrade0" Style="{StaticResource ThemedComboBox}">
                                                            <ComboBoxItem Content="install"/>
                                                            <ComboBoxItem Content="uninstallPrevious"/>
                                                            <ComboBoxItem Content="deny"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Elevation Requirement" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <ComboBox x:Name="cmbElevation0" Style="{StaticResource ThemedComboBox}">
                                                            <ComboBoxItem Content="elevatesSelf"/>
                                                            <ComboBoxItem Content="elevationRequired"/>
                                                            <ComboBoxItem Content="elevationProhibited"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Product Code" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txtProductCode0" Style="{StaticResource ThemedTextBox}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Commands (comma-sep)" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txtCommands0" Style="{StaticResource ThemedTextBox}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Text="File Extensions (comma-sep)" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtFileExt0" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"/>

                                                <!-- Custom & Interactive Switches -->
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Custom Switch" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txtCustomSwitch0" Style="{StaticResource ThemedTextBox}"
                                                                 ToolTip="Arbitrary extra switches (e.g. /NORESTART or -DeploymentType Install)"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Interactive Switch" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txtInteractive0" Style="{StaticResource ThemedTextBox}"
                                                                 ToolTip="Switch for interactive install mode"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Log & Repair Switches -->
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Log Switch" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txtLog0" Style="{StaticResource ThemedTextBox}"
                                                                 ToolTip="Switch/path to write installer log (e.g. /log &quot;C:\Temp\install.log&quot;)"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Repair Switch" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txtRepair0" Style="{StaticResource ThemedTextBox}"
                                                                 ToolTip="Switch for repair install (e.g. /repair or /f)"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Install Modes -->
                                                <TextBlock Text="Install Modes" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,6"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <CheckBox x:Name="chkModeInteractive" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,16,0">
                                                        <TextBlock Text="Interactive" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                    </CheckBox>
                                                    <CheckBox x:Name="chkModeSilent" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,16,0">
                                                        <TextBlock Text="Silent" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                    </CheckBox>
                                                    <CheckBox x:Name="chkModeSilentProgress" Style="{StaticResource ToggleSwitch}" IsChecked="False">
                                                        <TextBlock Text="Silent w/ Progress" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                    </CheckBox>
                                                </StackPanel>

                                                <!-- Platform -->
                                                <TextBlock Text="Platform" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,6"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <CheckBox x:Name="chkPlatformDesktop" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,16,0">
                                                        <TextBlock Text="Windows.Desktop" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                    </CheckBox>
                                                    <CheckBox x:Name="chkPlatformUniversal" Style="{StaticResource ToggleSwitch}" IsChecked="False">
                                                        <TextBlock Text="Windows.Universal" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                    </CheckBox>
                                                </StackPanel>

                                                <!-- Minimum OS Version -->
                                                <TextBlock Text="Minimum OS Version" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtMinOSVersion0" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                                         ToolTip="Minimum Windows version required (e.g. 10.0.17763.0)"/>

                                                <!-- Expected Return Codes -->
                                                <TextBlock Text="Expected Return Codes" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtExpectedReturnCodes0" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                                         ToolTip="Comma-separated code:behavior pairs (e.g. 1641:rebootRequired, 3010:rebootRequired, 1602:installInProgress)"/>

                                                <!-- Install Location Required (portable/zip) -->
                                                <CheckBox x:Name="chkInstallLocationRequired" Style="{StaticResource ToggleSwitch}" IsChecked="False" Margin="0,0,0,10"
                                                          ToolTip="When checked, WinGet will require the user to specify an install path via --location. Useful for portable tools you want placed in a specific directory.">
                                                    <TextBlock Text="Require custom install location (--location)" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                </CheckBox>

                                                <!-- Apps and Features Entry -->
                                                <Border Background="{DynamicResource ThemeCardAltBg}" CornerRadius="8"
                                                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                                                        Padding="14,10" Margin="0,4,0,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                                       Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Text="APPS AND FEATURES ENTRY (Add/Remove Programs)" FontSize="10" FontWeight="Bold"
                                                                       Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="Display Name" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                                <TextBox x:Name="txtAFDisplayName0" Style="{StaticResource ThemedTextBox}"
                                                                         ToolTip="Name shown in Add/Remove Programs"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Display Publisher" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                                <TextBox x:Name="txtAFPublisher0" Style="{StaticResource ThemedTextBox}"
                                                                         ToolTip="Publisher shown in Add/Remove Programs"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="Display Version" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                                <TextBox x:Name="txtAFDisplayVersion0" Style="{StaticResource ThemedTextBox}"
                                                                         ToolTip="Version shown in Add/Remove Programs"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Product Code" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                                <TextBox x:Name="txtAFProductCode0" Style="{StaticResource ThemedTextBox}"
                                                                         ToolTip="Registry product code in Add/Remove Programs"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Nested Installer Section (shown when type=zip) -->
                                                <Border x:Name="pnlNestedInstaller" Visibility="Collapsed"
                                                        Background="{DynamicResource ThemeCardAltBg}" CornerRadius="8"
                                                        BorderBrush="{DynamicResource ThemeAccentDim}" BorderThickness="1"
                                                        Padding="14,10" Margin="0,4,0,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                                       Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Text="NESTED INSTALLER (inside ZIP)" FontSize="10" FontWeight="Bold"
                                                                       Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="Nested Installer Type *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                                <ComboBox x:Name="cmbNestedType0" Style="{StaticResource ThemedComboBox}">
                                                                    <ComboBoxItem Content="exe" IsSelected="True"/>
                                                                    <ComboBoxItem Content="msi"/>
                                                                    <ComboBoxItem Content="msix"/>
                                                                    <ComboBoxItem Content="inno"/>
                                                                    <ComboBoxItem Content="nullsoft"/>
                                                                    <ComboBoxItem Content="burn"/>
                                                                    <ComboBoxItem Content="wix"/>
                                                                    <ComboBoxItem Content="portable"/>
                                                                </ComboBox>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Portable Command Alias" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                                <TextBox x:Name="txtPortableAlias0" Style="{StaticResource ThemedTextBox}"
                                                                         ToolTip="CLI alias for portable apps (e.g. myapp)"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <TextBlock Text="Relative File Path *" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txtNestedPath0" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,4"
                                                                 ToolTip="Path to the installer inside the ZIP (e.g. Deploy-Application.exe or setup.exe)"/>
                                                        <TextBlock Text="The path inside the ZIP archive to the actual installer executable"
                                                                   FontSize="9" Foreground="{DynamicResource ThemeTextDisabled}" FontStyle="Italic"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Added Installers Summary -->
                                    <Border x:Name="pnlInstallerSummary" Visibility="Collapsed"
                                            Background="{DynamicResource ThemeCardAltBg}" CornerRadius="8"
                                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                                            Padding="10,8" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="ADDED INSTALLERS" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,6"/>
                                            <ListView x:Name="lstInstallerEntries" Background="Transparent" BorderThickness="0"
                                                      Foreground="{DynamicResource ThemeTextBody}" MaxHeight="180"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button x:Name="btnAddInstaller" Style="{StaticResource GhostButton}" Content="+ Add Another Installer"
                                                HorizontalAlignment="Left" Margin="0,0,8,0"/>
                                        <Button x:Name="btnRemoveLastInstaller" Style="{StaticResource GhostButton}" Content="Remove Last"
                                                HorizontalAlignment="Left" Margin="0,0,8,0" Visibility="Collapsed"/>
                                        <Button x:Name="btnEditInstaller" Style="{StaticResource GhostButton}" Padding="6,4" Margin="0,0,4,0"
                                                Visibility="Collapsed" ToolTip="Edit selected installer">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                                        </Button>
                                        <Button x:Name="btnMoveInstallerUp" Style="{StaticResource GhostButton}" Padding="6,4" Margin="0,0,4,0"
                                                Visibility="Collapsed" ToolTip="Move up">
                                            <TextBlock Text="&#xE70E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                                        </Button>
                                        <Button x:Name="btnMoveInstallerDown" Style="{StaticResource GhostButton}" Padding="6,4"
                                                Visibility="Collapsed" ToolTip="Move down">
                                            <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel x:Name="lblMultiInstallerHint" Orientation="Horizontal" Margin="0,-12,0,16" Visibility="Collapsed">
                                        <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                   Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="Multi-installer package: use the Upload tab to download &amp; upload all installers at once."
                                                   FontSize="9.5" Foreground="{DynamicResource ThemeAccentLight}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    </StackPanel> <!-- /secInstallerBody -->

                                    <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,20"/>

                                    <!-- Step 3b: Dependencies (Collapsible) -->
                                    <Border x:Name="secDepsHeader" Cursor="Hand" Background="Transparent" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="secDepsChevron" Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="10" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="DEPENDENCIES (optional)" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeAccentLight}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="secDepsBody" Visibility="Collapsed">
                                        <TextBlock Text="Package Dependencies (one per line: Id | MinVersion)" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtPackageDeps" Style="{StaticResource ThemedTextBox}" AcceptsReturn="True"
                                                 TextWrapping="Wrap" Height="60" Margin="0,0,0,10"
                                                 ToolTip="e.g., Microsoft.VCRedist.2015+.x64 | 14.0"/>
                                        <TextBlock Text="Windows Features (comma-separated)" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtWindowsFeatures" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                                 ToolTip="e.g., NetFx3, IIS-WebServer"/>
                                        <TextBlock Text="Windows Libraries (comma-separated)" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtWindowsLibs" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                                 ToolTip="e.g., Microsoft.UI.Xaml.2.7"/>
                                        <TextBlock Text="External Dependencies (comma-separated)" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtExternalDeps" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,20"
                                                 ToolTip="e.g., .NET 8 Runtime"/>
                                    </StackPanel>

                                    <!-- Step 3c: Uninstall (Collapsible) -->
                                    <Border x:Name="secUninstallHeader" Cursor="Hand" Background="Transparent" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="secUninstallChevron" Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="10" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="UNINSTALL INFO (optional)" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeAccentLight}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel x:Name="secUninstallBody" Visibility="Collapsed">
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Uninstall Command" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtUninstallCmd" Style="{StaticResource ThemedTextBox}"
                                                         ToolTip="e.g., MsiExec.exe /X{product-code}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Uninstall Silent Switch" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="txtUninstallSilent" Style="{StaticResource ThemedTextBox}"
                                                         ToolTip="e.g., /quiet /norestart"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,20"/>

                                    <!-- Step 4: Actions -->
                                    <TextBlock Text="ACTIONS" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,0,12"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button x:Name="btnSaveToDisk" Style="{StaticResource AccentButton}" Padding="16,8" Margin="0,0,8,0" ToolTip="Ctrl+S">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Save to Disk" FontSize="12" Foreground="White"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnPublish" Style="{StaticResource GreenButton}" Padding="16,8" Margin="0,0,8,0" IsEnabled="False" ToolTip="Ctrl+Shift+P">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE898;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Publish to REST Source" FontSize="12" Foreground="White"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnSaveConfig" Style="{StaticResource GhostButton}" Content="Save as Config" Padding="12,6"/>
                                    </StackPanel>

                                    <!-- YAML Preview -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="YAML PREVIEW" FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                        <Button x:Name="btnCopyYaml" Grid.Column="1" Style="{StaticResource GhostButton}" Padding="8,4"
                                                ToolTip="Copy YAML to clipboard">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                           Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="Copy" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <TextBox x:Name="txtYamlPreview" Style="{StaticResource ThemedTextBox}"
                                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                             FontFamily="Cascadia Code, Consolas" FontSize="11"
                                             Height="300" VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             Background="{DynamicResource ThemeOutputBg}" Margin="0,0,0,20"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- TAB: EDIT MANIFEST -->
                            <ScrollViewer x:Name="pnlTabEdit" VerticalScrollBarVisibility="Auto" Padding="24,16" Visibility="Collapsed">
                                <StackPanel MaxWidth="700">
                                    <TextBlock Text="EDIT MANIFEST" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Load a package config from the left panel, or use the buttons below to load from disk."
                                               FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,16" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button x:Name="btnLoadFromDisk" Style="{StaticResource AccentButton}" Padding="16,8" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xED25;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Load from Disk" FontSize="12" Foreground="White"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnLoadFromConfig" Style="{StaticResource GhostButton}" Content="Load from Config" Padding="12,6"/>
                                    </StackPanel>

                                    <!-- Edit fields placeholder — populated programmatically when a config is loaded -->
                                    <Border x:Name="pnlEditFields" Visibility="Collapsed" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            CornerRadius="12" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock x:Name="lblEditPkgId" Text="" FontSize="14" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="lblEditPkgVersion" Text="" FontSize="12"
                                                       Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,0,12"/>
                                            <TextBox x:Name="txtEditYaml" Style="{StaticResource ThemedTextBox}"
                                                     AcceptsReturn="True" TextWrapping="NoWrap"
                                                     FontFamily="Cascadia Code, Consolas" FontSize="11"
                                                     Height="400" VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     Background="{DynamicResource ThemeOutputBg}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                <Button x:Name="btnEditSave" Style="{StaticResource AccentButton}" Content="Save" Padding="16,6" Margin="0,0,8,0"/>
                                                <Button x:Name="btnEditPublish" Style="{StaticResource GreenButton}" Content="Publish" Padding="16,6" IsEnabled="False"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- TAB: UPLOAD PACKAGE -->
                            <ScrollViewer x:Name="pnlTabUpload" VerticalScrollBarVisibility="Auto" Padding="24,16" Visibility="Collapsed">
                                <StackPanel MaxWidth="700">
                                    <TextBlock Text="UPLOAD PACKAGE" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Select a local installer file to compute its SHA256 hash and optionally upload it to Azure Blob Storage."
                                               FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                    <!-- BATCH INSTALLER OPERATIONS -->
                                    <Border x:Name="pnlBatchOps" Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="14,12" Margin="0,0,0,20" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="BATCH INSTALLER OPERATIONS" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="lblBatchCount" Text="" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,10"/>
                                            <ListView x:Name="lstBatchInstallers" Background="Transparent" BorderThickness="0"
                                                      Foreground="{DynamicResource ThemeTextBody}" MaxHeight="200" Margin="0,0,0,10"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                                            <ProgressBar x:Name="prgBatch" Height="4" Margin="0,0,0,6" Visibility="Collapsed"
                                                         Background="{DynamicResource ThemeSurfaceBg}" Foreground="{DynamicResource ThemeAccent}"/>
                                            <TextBlock x:Name="lblBatchProgress" Text="" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,10"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="btnDownloadAll" Style="{StaticResource AccentButton}" Padding="14,7" Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Download All" FontSize="11" Foreground="White"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="btnUploadAll" Style="{StaticResource GreenButton}" Padding="14,7" Margin="0,0,8,0" IsEnabled="False">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE898;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Upload All" FontSize="11" Foreground="White"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="btnCancelBatch" Style="{StaticResource GhostButton}" Padding="8,5" Visibility="Collapsed"
                                                        ToolTip="Cancel batch operation">
                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="{DynamicResource ThemeError}"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,16"/>

                                    <!-- File Selection -->
                                    <TextBlock Text="Local Installer File" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <Border x:Name="dropZoneUpload" AllowDrop="True" Background="Transparent"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            CornerRadius="8" Padding="4" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="txtUploadFile" Style="{StaticResource ThemedTextBox}" IsReadOnly="True" Grid.Column="0"/>
                                            <Button x:Name="btnBrowseUpload" Style="{StaticResource GhostButton}" Content="Browse..." Grid.Column="1" Margin="6,0,0,0" Padding="12,5"/>
                                        </Grid>
                                    </Border>

                                    <!-- Hash Result -->
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="SHA256 HASH" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="lblUploadHash" Text="Select a file to compute hash..."
                                                       FontSize="11" FontFamily="Cascadia Code, Consolas"
                                                       Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="lblUploadSize" Text="" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextDim}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,16"/>

                                    <!-- Upload Destination -->
                                    <TextBlock Text="UPLOAD DESTINATION" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,0,12"/>

                                    <TextBlock Text="Storage Account" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbUploadStorage" Style="{StaticResource ThemedComboBox}" Margin="0,0,0,10"/>

                                    <TextBlock Text="Container" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbUploadContainer" Style="{StaticResource ThemedComboBox}" Margin="0,0,0,10"/>

                                    <TextBlock Text="Blob Path" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtBlobPath" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                             ToolTip="Auto-generated: packages/PkgId/Version/filename"/>

                                    <!-- Progress -->
                                    <ProgressBar x:Name="prgUpload" Height="4" Margin="0,0,0,6" Visibility="Collapsed"
                                                 Background="{DynamicResource ThemeSurfaceBg}" Foreground="{DynamicResource ThemeAccent}"/>
                                    <TextBlock x:Name="lblUploadProgress" Text="" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,16"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button x:Name="btnUpload" Style="{StaticResource GreenButton}" Padding="16,8" Margin="0,0,8,0" IsEnabled="False">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE898;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Upload to Blob" FontSize="12" Foreground="White"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnCopyHash" Style="{StaticResource GhostButton}" Content="Copy Hash" Padding="12,6" IsEnabled="False"/>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,8,0,16"/>

                                    <!-- BLOB BROWSER -->
                                    <Border x:Name="pnlBlobBrowser" Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="14,12" Margin="0,0,0,20">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="BLOB BROWSER" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                                <Button x:Name="btnRefreshBlobs" Grid.Column="1" Style="{StaticResource GhostButton}" Padding="6,3" Margin="0,0,4,0"
                                                        ToolTip="Refresh blob list">
                                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                               Foreground="{DynamicResource ThemeTextMuted}"/>
                                                </Button>
                                                <Button x:Name="btnDeleteBlob" Grid.Column="2" Style="{StaticResource GhostButton}" Padding="6,3"
                                                        ToolTip="Delete selected blob" IsEnabled="False">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                               Foreground="{DynamicResource ThemeError}"/>
                                                </Button>
                                            </Grid>
                                            <TextBlock x:Name="lblBlobCount" Text="Select a container to browse blobs" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,8"/>
                                            <ListView x:Name="lstBlobBrowser" Background="Transparent" BorderThickness="0"
                                                      Foreground="{DynamicResource ThemeTextBody}" MaxHeight="250" Margin="0"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                      ItemContainerStyle="{StaticResource ConfigListItem}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- TAB: MANAGE PACKAGES -->
                            <ScrollViewer x:Name="pnlTabManage" VerticalScrollBarVisibility="Auto" Padding="24,16" Visibility="Collapsed">
                                <StackPanel MaxWidth="700">
                                    <TextBlock Text="MANAGE PACKAGES" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Query your private WinGet REST source and remove packages, versions, blobs, or local configs."
                                               FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                    <!-- Query / Refresh -->
                                    <Border Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="14,10" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="lblManageSourceName" Text="REST Source: (not set)" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextPrimary}"/>
                                                <TextBlock x:Name="lblManagePkgCount" Text="" FontSize="10"
                                                           Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                                                <TextBlock x:Name="lblManageCacheAge" Text="" FontSize="9"
                                                           Foreground="{DynamicResource ThemeTextDim}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button x:Name="btnRefreshManage" Grid.Column="1" Style="{StaticResource AccentButton}" Padding="16,8"
                                                    ToolTip="Force refresh — bypass cache and re-query the REST source">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Refresh" FontSize="12" Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Search/Filter + Sort -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtManageSearch" Style="{StaticResource ThemedTextBox}" Grid.Column="0"
                                                 ToolTip="Filter packages by ID or name"/>
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="{DynamicResource ThemeTextDisabled}" VerticalAlignment="Center"
                                                   Grid.Column="0" HorizontalAlignment="Right" Margin="0,0,10,0" IsHitTestVisible="False"/>
                                        <ComboBox x:Name="cmbManageSort" Style="{StaticResource ThemedComboBox}" Grid.Column="1"
                                                  Width="130" Margin="8,0,0,0" ToolTip="Sort packages">
                                            <ComboBoxItem Content="Name A→Z" IsSelected="True"/>
                                            <ComboBoxItem Content="Name Z→A"/>
                                            <ComboBoxItem Content="Most Versions"/>
                                            <ComboBoxItem Content="Fewest Versions"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Package List -->
                                    <TextBlock Text="PUBLISHED PACKAGES" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            MinHeight="120" MaxHeight="500" Margin="0,0,0,16">
                                        <Grid>
                                            <!-- Empty State with Illustration -->
                                            <StackPanel x:Name="lblManageEmpty" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                                <TextBlock Text="&#xEA37;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="36"
                                                           Foreground="{DynamicResource ThemeTextFaintest}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                <TextBlock Text="No packages loaded" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextDisabled}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                <TextBlock Text="Click 'Query Packages' to list packages from the REST source."
                                                           FontSize="11" Foreground="{DynamicResource ThemeTextDisabled}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <ListView x:Name="lstManagePackages" Background="Transparent" BorderThickness="0"
                                                      Foreground="{DynamicResource ThemeTextBody}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                      Visibility="Collapsed"/>
                                        </Grid>
                                    </Border>

                                    <!-- Selected Package Details -->
                                    <Border x:Name="pnlManageDetails" Visibility="Collapsed" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock x:Name="lblManagePkgId" Text="" FontSize="14" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="lblManageVersions" Text="" FontSize="12"
                                                       Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                            <!-- Version selector for per-version removal -->
                                            <TextBlock Text="Version to Remove" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="cmbManageVersion" Style="{StaticResource ThemedComboBox}" Margin="0,0,0,12"/>

                                            <!-- Cleanup options -->
                                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,12"/>
                                            <TextBlock Text="CLEANUP OPTIONS" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,8"/>

                                            <CheckBox x:Name="chkDeleteBlob" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,6" IsChecked="False">
                                                <TextBlock Text="Also delete installer blob from Azure Storage" FontSize="11"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <CheckBox x:Name="chkDeleteConfig" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,12" IsChecked="False">
                                                <TextBlock Text="Also delete local package config (.json)" FontSize="11"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>

                                            <!-- Actions -->
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="btnNewVersion" Style="{StaticResource AccentButton}" Padding="16,8" Margin="0,0,8,0"
                                                        ToolTip="Create a new version of this package, pre-filling metadata from the latest version">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="New Version" FontSize="12" Foreground="White"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="btnDiffVersions" Style="{StaticResource GhostButton}" Padding="12,8" Margin="0,0,8,0"
                                                        ToolTip="Compare two versions side-by-side">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                                   Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Diff" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="btnImportToCreate" Style="{StaticResource GhostButton}" Padding="12,8" Margin="0,0,8,0"
                                                        ToolTip="Fetch full manifest from REST source and populate Create tab for editing">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                                   Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Import to Create" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="btnRemoveVersion" Style="{StaticResource DangerGhostButton}" Padding="16,8" Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                                   Foreground="{DynamicResource ThemeError}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Remove Version" FontSize="12" Foreground="{DynamicResource ThemeError}"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="btnRemovePackage" Style="{StaticResource DangerGhostButton}" Padding="16,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                                   Foreground="{DynamicResource ThemeError}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Remove Entire Package" FontSize="12" Foreground="{DynamicResource ThemeError}"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Progress/Status -->
                                    <ProgressBar x:Name="prgManage" Height="4" Margin="0,0,0,6" Visibility="Collapsed"
                                                 Background="{DynamicResource ThemeSurfaceBg}" Foreground="{DynamicResource ThemeAccent}"/>
                                    <TextBlock x:Name="lblManageStatus" Text="" FontSize="10"
                                               Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,16"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- TAB: DEPLOY SOURCE -->
                            <ScrollViewer x:Name="pnlTabDeploy" VerticalScrollBarVisibility="Auto" Padding="24,16" Visibility="Collapsed">
                                <StackPanel MaxWidth="700">
                                    <!-- Header with PREVIEW badge -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Deploy WinGet REST Source to Azure" FontSize="18" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextPrimary}"/>
                                        <Border CornerRadius="6" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="{DynamicResource ThemeAccentLight}" BorderThickness="1">
                                            <TextBlock Text="PREVIEW" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeAccentLight}"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Intro section -->
                                    <Border Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12" Padding="14,10" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,6">
                                                <Run FontWeight="SemiBold">What does this do?</Run><LineBreak/>
                                                Deploys a private WinGet REST source backed by Azure Functions + Cosmos DB.
                                                Once deployed, users can install packages from your custom repository using
                                                <Run FontFamily="Consolas" FontSize="11">winget install &lt;pkg&gt; --source &lt;YourSource&gt;</Run>.
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}">
                                                <Run FontWeight="SemiBold">How it works:</Run>
                                                This wraps the official Microsoft
                                                <Run FontFamily="Consolas" FontSize="10">Deploy-WinGetSource.ps1</Run> script.
                                                Fill in the parameters below, optionally save as a profile for reuse, then click Deploy.
                                                Output will appear in the bottom panel.
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Deployment Profile selector -->
                                    <Border Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Deployment Profile" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="cmbDeployProfile" Style="{StaticResource ThemedComboBox}"
                                                          ToolTip="Select a saved deployment configuration"/>
                                            </StackPanel>
                                            <Button x:Name="btnSaveDeployProfile" Style="{StaticResource GhostButton}" Grid.Column="1"
                                                    Padding="10,6" Margin="8,14,0,0" ToolTip="Save current parameters as profile">
                                                <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                            </Button>
                                            <Button x:Name="btnDeleteDeployProfile" Style="{StaticResource GhostButton}" Grid.Column="2"
                                                    Padding="10,6" Margin="4,14,0,0" ToolTip="Delete selected profile">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                                           Foreground="{DynamicResource ThemeError}"/>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Core Parameters -->
                                    <TextBlock Text="CORE PARAMETERS" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Source Name" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Unique name for your WinGet source. Used as the Azure Function App name and REST endpoint identifier. Must be 3-24 chars, lowercase alphanumeric only."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtDeployName" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                                     Text="corpwinget" Tag="e.g. corpwinget, myorgpkgs"/>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                    <TextBlock Text="Resource Group" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Azure resource group (created if it doesn't exist)" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="txtDeployRG" Style="{StaticResource ThemedTextBox}" Text="rg-winget-prod-001" Tag="e.g. rg-winget-prod-001"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                    <TextBlock Text="Region" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Azure region for all resources" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4"/>
                                                    <ComboBox x:Name="cmbDeployRegion" Style="{StaticResource ThemedComboBox}">
                                                        <ComboBoxItem Content="westeurope" IsSelected="True"/>
                                                        <ComboBoxItem Content="northeurope"/>
                                                        <ComboBoxItem Content="eastus"/>
                                                        <ComboBoxItem Content="eastus2"/>
                                                        <ComboBoxItem Content="westus2"/>
                                                        <ComboBoxItem Content="westus3"/>
                                                        <ComboBoxItem Content="centralus"/>
                                                        <ComboBoxItem Content="uksouth"/>
                                                        <ComboBoxItem Content="ukwest"/>
                                                        <ComboBoxItem Content="southeastasia"/>
                                                        <ComboBoxItem Content="australiaeast"/>
                                                        <ComboBoxItem Content="japaneast"/>
                                                        <ComboBoxItem Content="canadacentral"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                    <TextBlock Text="Performance Tier" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Developer = free tier, Basic/Enhanced = production" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                    <ComboBox x:Name="cmbDeployTier" Style="{StaticResource ThemedComboBox}">
                                                        <ComboBoxItem Content="Developer" IsSelected="True"/>
                                                        <ComboBoxItem Content="Basic"/>
                                                        <ComboBoxItem Content="Enhanced"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                    <TextBlock Text="Authentication" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="None = public, Entra ID = requires sign-in" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                    <ComboBox x:Name="cmbDeployAuth" Style="{StaticResource ThemedComboBox}">
                                                        <ComboBoxItem Content="None" IsSelected="True"/>
                                                        <ComboBoxItem Content="MicrosoftEntraId"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="Source Display Name" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Friendly name shown to users in 'winget source list'. Can contain spaces."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtDeployDisplayName" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,10"
                                                     Text="CorpWinGet" Tag="e.g. Corporate WinGet, IT App Store"/>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                    <TextBlock Text="Publisher Name" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Embedded in REST source metadata" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="txtDeployPublisherName" Style="{StaticResource ThemedTextBox}"
                                                             Tag="e.g. Contoso IT (auto-detected if empty)"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                    <TextBlock Text="Publisher Email" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Embedded in REST source metadata" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="txtDeployPublisherEmail" Style="{StaticResource ThemedTextBox}"
                                                             Tag="e.g. admin@contoso.com (auto-detected if empty)"/>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="Cosmos DB Region" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Optional. Deploy Cosmos DB to a different region than the main resources. Useful when the primary region has capacity constraints (e.g. West Europe rejects new accounts)."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="cmbDeployCosmosRegion" Style="{StaticResource ThemedComboBox}" Margin="0,0,0,10">
                                                <ComboBoxItem Content="(Same as Region)" IsSelected="True"/>
                                                <ComboBoxItem Content="westeurope"/>
                                                <ComboBoxItem Content="northeurope"/>
                                                <ComboBoxItem Content="eastus"/>
                                                <ComboBoxItem Content="eastus2"/>
                                                <ComboBoxItem Content="westus2"/>
                                                <ComboBoxItem Content="westus3"/>
                                                <ComboBoxItem Content="centralus"/>
                                                <ComboBoxItem Content="uksouth"/>
                                                <ComboBoxItem Content="ukwest"/>
                                                <ComboBoxItem Content="southeastasia"/>
                                                <ComboBoxItem Content="australiaeast"/>
                                                <ComboBoxItem Content="japaneast"/>
                                                <ComboBoxItem Content="canadacentral"/>
                                            </ComboBox>

                                            <TextBlock Text="Manifest Seed Path" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Optional. Folder with YAML manifests to pre-populate the source after deployment. Leave empty to deploy an empty source."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txtDeployManifestPath" Style="{StaticResource ThemedTextBox}" Grid.Column="0"
                                                         Tag="e.g. C:\Manifests\Production"/>
                                                <Button x:Name="btnDeployBrowseManifests" Style="{StaticResource GhostButton}" Grid.Column="1"
                                                        Padding="10,6" Margin="6,0,0,0">
                                                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Resource Name Overrides (Advanced) -->
                                    <Border x:Name="pnlResourceOverrides" Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="ADVANCED: RESOURCE NAME OVERRIDES" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Override the default naming convention if your organization uses non-standard resource names. Leave blank to use standard prefixes (func-, kv-, apim-, st, asp-)." 
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                    <TextBlock Text="Function App Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                    <TextBox x:Name="txtOverrideFuncApp" Style="{StaticResource ThemedTextBox}" Tag="e.g. func-corpwinget"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                    <TextBlock Text="Key Vault Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                    <TextBox x:Name="txtOverrideKeyVault" Style="{StaticResource ThemedTextBox}" Tag="e.g. kv-corpwinget"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                    <TextBlock Text="Storage Account Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                    <TextBox x:Name="txtOverrideStorage" Style="{StaticResource ThemedTextBox}" Tag="e.g. stcorpwinget"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                    <TextBlock Text="APIM Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                    <TextBox x:Name="txtOverrideAPIM" Style="{StaticResource ThemedTextBox}" Tag="e.g. apim-corpwinget"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                    <TextBlock Text="App Service Plan Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                    <TextBox x:Name="txtOverrideASP" Style="{StaticResource ThemedTextBox}" Tag="e.g. asp-corpwinget"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Tags -->
                                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,4,0,10"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="&#xE1CB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="RESOURCE TAGS" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Tags applied to all deployed resources. Add key-value pairs like Azure portal."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <!-- Azure-style tag rows -->
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Name" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="1" Text="Value" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextDim}" Margin="6,0,0,0"/>
                                            </Grid>
                                            <StackPanel x:Name="pnlTagRows">
                                                <!-- Tag rows are added dynamically from PS1 -->
                                            </StackPanel>
                                            <Button x:Name="btnAddTagRow" Cursor="Hand" HorizontalAlignment="Left" Margin="0,4,0,0"
                                                    Background="Transparent" BorderThickness="0" Padding="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                               Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Add tag" FontSize="11" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <!-- Options -->
                                    <TextBlock Text="OPTIONS" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <CheckBox x:Name="chkDeploySkipAPIM" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Skip API Management" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Skips creating APIM gateway — clients connect directly to the Function App. Saves cost but loses rate limiting and caching."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,10"/>

                                            <CheckBox x:Name="chkDeploySkipManifestSeed" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Skip manifest seeding after deployment" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Deploy infrastructure only — do not publish manifests even if a Manifest Seed Path is specified above. Useful for initial setup where you want to publish packages later."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,10"/>

                                            <CheckBox x:Name="chkDeployRegisterSource" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Register source locally after deployment" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Automatically runs 'winget source add' on this machine so you can immediately install packages from the new source."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,10"/>

                                            <CheckBox x:Name="chkDeployCosmosZoneRedundant" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Cosmos DB zone redundancy" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Enables availability zone redundancy for Cosmos DB. Recommended for production; increases cost. Not needed for dev/test."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,10"/>

                                            <CheckBox x:Name="chkDeployEnablePrivateEndpoints" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Enable Private Endpoints" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Creates Azure Private Endpoints for Function App, Cosmos DB, Key Vault, and Storage. Restricts access to VNet only."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,6"/>

                                            <!-- Private Endpoint fields (shown when PE checkbox is checked) -->
                                            <StackPanel x:Name="pnlPrivateEndpointFields" Visibility="Collapsed" Margin="18,0,0,10">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                        <TextBlock Text="VNet Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                        <TextBox x:Name="txtDeployVNetName" Style="{StaticResource ThemedTextBox}" Tag="e.g. vnet-corp-001"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                        <TextBlock Text="Subnet Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                        <TextBox x:Name="txtDeploySubnetName" Style="{StaticResource ThemedTextBox}" Text="snet-privateendpoints" Tag="snet-privateendpoints"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="VNet Resource Group (if different)" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                <TextBox x:Name="txtDeployVNetRG" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,6" Tag="Leave empty to use deploy RG"/>
                                                <CheckBox x:Name="chkDeployRegisterDnsZones" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                    <TextBlock Text="Create Private DNS Zones" FontSize="11"
                                                               Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                </CheckBox>
                                            </StackPanel>

                                            <CheckBox x:Name="chkDeployWhatIf" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Dry run (WhatIf)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Validates everything but does not actually deploy. Use this to preview what would be created."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,10"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Deployment Target Info -->
                                    <Border x:Name="pnlDeployTarget" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE753;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                       Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Target:" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="lblDeployTargetSub" Text="Not connected" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Action Buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Button x:Name="btnRunDeploy" Style="{StaticResource AccentButton}" Padding="20,10" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Deploy WinGet Source" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnDeployCancel" Style="{StaticResource GhostButton}" Padding="16,10"
                                                Visibility="Collapsed" ToolTip="Cancel running operation">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                           Foreground="{DynamicResource ThemeWarning}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Cancel" FontSize="13" Foreground="{DynamicResource ThemeWarning}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <!-- Status -->
                                    <ProgressBar x:Name="prgDeploy" IsIndeterminate="True" Height="4" Margin="0,0,0,8" Visibility="Collapsed"
                                                 Background="{DynamicResource ThemeSurfaceBg}" Foreground="{DynamicResource ThemeAccent}"/>
                                    <TextBlock x:Name="lblDeployStatus" Text="" FontSize="11"
                                               Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap"/>

                                    <!-- ═══════ DISCOVER DEPLOYMENTS ═══════ -->
                                    <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,20,0,16"/>
                                    <TextBlock Text="DISCOVER EXISTING DEPLOYMENTS" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Scan your Azure subscription for existing WinGet REST source deployments (Function Apps with the WinGet naming pattern). Discovered sources can be loaded into the form above for redeployment or removal."
                                               FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button x:Name="btnDiscoverDeploys" Style="{StaticResource GhostButton}" Padding="14,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE773;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                                   Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Scan Subscription" FontSize="12" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock x:Name="lblDiscoverStatus" Text="" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"
                                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="prgDiscover" IsIndeterminate="True" Height="3" Margin="0,0,0,6" Visibility="Collapsed"
                                                         Background="{DynamicResource ThemeSurfaceBg}" Foreground="{DynamicResource ThemeAccent}"/>
                                            <ListView x:Name="lstDiscoveredDeploys" Visibility="Collapsed"
                                                      Background="Transparent" BorderThickness="0"
                                                      MaxHeight="200" Margin="0">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListViewItem">
                                                                    <Border Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="8"
                                                                            Padding="10,6" Margin="0,2">
                                                                        <ContentPresenter/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                            </ListView>
                                            <TextBlock x:Name="lblDiscoverEmpty" Text="" FontSize="11" Visibility="Collapsed"
                                                       Foreground="{DynamicResource ThemeTextDim}" FontStyle="Italic" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- ═══════ REMOVE SOURCE TAB ═══════ -->
                            <ScrollViewer x:Name="pnlTabRemove" VerticalScrollBarVisibility="Auto" Padding="24,16" Visibility="Collapsed">
                                <StackPanel MaxWidth="700">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Remove WinGet REST Source from Azure" FontSize="18" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextPrimary}"/>
                                        <Border CornerRadius="6" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="{DynamicResource ThemeError}" BorderThickness="1">
                                            <TextBlock Text="DESTRUCTIVE" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeError}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Permanently delete all Azure resources for a WinGet REST source deployment. This removes the Function App, Cosmos DB, Storage, Key Vault, APIM, App Config, and Entra ID registrations."
                                               FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                    <!-- Deployment Profile selector (shared with Deploy tab) -->
                                    <Border Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Load from Deployment Profile" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Select a saved deployment profile to auto-fill source name, resource group, and resource names below."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="cmbRemoveProfile" Style="{StaticResource ThemedComboBox}"
                                                      ToolTip="Select a saved deployment profile to populate removal fields"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Source Identity -->
                                    <TextBlock Text="SOURCE IDENTITY" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <!-- Source Name + Resource Group: Grid with aligned rows -->
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- Labels -->
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Source Name *" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Resource Group *" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                                <!-- Descriptions (row stretches to tallest) -->
                                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Top"
                                                           Text="The name used during deployment (without func- prefix). Must match the original deployment name."
                                                           FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Top"
                                                           Text="Azure resource group containing all deployed resources."
                                                           FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                <!-- Controls (aligned at bottom) -->
                                                <ComboBox Grid.Row="2" Grid.Column="0" x:Name="cmbRemoveName" Style="{StaticResource ThemedComboBox}" IsEditable="True"
                                                          ToolTip="Select a discovered source or type a name (without func- prefix)"/>
                                                <ComboBox Grid.Row="2" Grid.Column="2" x:Name="cmbRemoveRG" Style="{StaticResource ThemedComboBox}" IsEditable="True"
                                                          ToolTip="Select from discovered resource groups or type a name"/>
                                            </Grid>
                                            <TextBlock Text="Display Name (optional)" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Friendly name shown in 'winget source list'. Used to identify the local source registration to remove."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txtRemoveDisplayName" Style="{StaticResource ThemedTextBox}" Margin="0,0,0,0"
                                                     Tag="e.g. Corporate WinGet" ToolTip="Used to identify the local winget source registration to remove"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Resource Name Overrides (optional) -->
                                    <TextBlock Text="RESOURCE NAME OVERRIDES" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Only needed if the deployment used non-standard resource names. Auto-filled from the source name using the standard naming convention (func-, kv-, st, apim-)."
                                               FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Function App Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,2"/>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Key Vault Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,2"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Default: func-{name}" FontSize="10" Foreground="{DynamicResource ThemeTextDisabled}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Default: kv-{name}" FontSize="10" Foreground="{DynamicResource ThemeTextDisabled}" Margin="0,0,0,3"/>
                                                <ComboBox Grid.Row="2" Grid.Column="0" x:Name="cmbRemoveOverrideFuncApp" Style="{StaticResource ThemedComboBox}" IsEditable="True" Tag="e.g. func-corpwinget"/>
                                                <ComboBox Grid.Row="2" Grid.Column="2" x:Name="cmbRemoveOverrideKeyVault" Style="{StaticResource ThemedComboBox}" IsEditable="True" Tag="e.g. kv-corpwinget"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Storage Account Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,2"/>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Text="APIM Name" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,2"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Default: st{name} (no hyphens)" FontSize="10" Foreground="{DynamicResource ThemeTextDisabled}" Margin="0,0,0,3"/>
                                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Default: apim-{name}" FontSize="10" Foreground="{DynamicResource ThemeTextDisabled}" Margin="0,0,0,3"/>
                                                <ComboBox Grid.Row="2" Grid.Column="0" x:Name="cmbRemoveOverrideStorage" Style="{StaticResource ThemedComboBox}" IsEditable="True" Tag="e.g. stcorpwinget"/>
                                                <ComboBox Grid.Row="2" Grid.Column="2" x:Name="cmbRemoveOverrideAPIM" Style="{StaticResource ThemedComboBox}" IsEditable="True" Tag="e.g. apim-corpwinget"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Remove Options -->
                                    <TextBlock Text="OPTIONS" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <CheckBox x:Name="chkRemoveSkipSourceRemoval" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Skip local source removal" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Don't run 'winget source remove' — only delete Azure resources."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,10"/>

                                            <CheckBox x:Name="chkRemoveSkipEntraCleanup" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Skip Entra ID app registration cleanup" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Keep Entra ID (Azure AD) app registrations and service principals intact."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,10"/>

                                            <CheckBox x:Name="chkRemoveSkipSoftDeletePurge" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Skip purging soft-deleted resources" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Don't purge soft-deleted APIM, Key Vault, or App Service resources. They'll remain recoverable for the retention period."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,10"/>

                                            <CheckBox x:Name="chkRemovePurgeOnly" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,4">
                                                <TextBlock Text="Purge only (skip RG and Entra deletion)" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </CheckBox>
                                            <TextBlock Text="Only clean up soft-deleted resources from a previous removal. Useful when RG was already deleted but soft-deletes remain."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="48,0,0,10"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Target Subscription -->
                                    <Border Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE753;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                       Foreground="{DynamicResource ThemeError}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Target:" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="lblRemoveTargetSub" Text="Not connected" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Action Buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Button x:Name="btnRunRemove" Style="{StaticResource DangerGhostButton}" Padding="20,10" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                           Foreground="{DynamicResource ThemeError}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Remove WinGet Source" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeError}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnRemoveCancel" Style="{StaticResource GhostButton}" Padding="16,10"
                                                Visibility="Collapsed" ToolTip="Cancel running operation">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                           Foreground="{DynamicResource ThemeWarning}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Cancel" FontSize="13" Foreground="{DynamicResource ThemeWarning}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <!-- Status -->
                                    <ProgressBar x:Name="prgRemove" IsIndeterminate="True" Height="4" Margin="0,0,0,8" Visibility="Collapsed"
                                                 Background="{DynamicResource ThemeSurfaceBg}" Foreground="{DynamicResource ThemeError}"/>
                                    <TextBlock x:Name="lblRemoveStatus" Text="" FontSize="11"
                                               Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ═══════ BACKUP / RESTORE TAB ═══════ -->
                            <ScrollViewer x:Name="pnlTabBackup" VerticalScrollBarVisibility="Auto" Padding="24,16" Visibility="Collapsed">
                                <StackPanel MaxWidth="860">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Backup &amp; Restore" FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextPrimary}"/>
                                        <Border CornerRadius="6" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center"
                                                BorderBrush="{DynamicResource ThemeAccentLight}" BorderThickness="1">
                                            <TextBlock Text="PREVIEW" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeAccentLight}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,16">
                                        <Run>Download all manifests from a WinGet REST source and/or blobs from a storage account into a local backup folder.</Run>
                                        <Run>Restore uploads the backup back to a target source — useful for environment migration (DEV → PROD) or disaster recovery.</Run>
                                    </TextBlock>

                                    <!-- BACKUP section -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="3" Height="12" Background="{DynamicResource ThemeAccent}" CornerRadius="1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="BACKUP" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextDim}"/>
                                    </StackPanel>
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <!-- Backup Target Selection -->
                                            <TextBlock Text="Backup Target" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <TextBlock Text="Choose what to back up. REST Source downloads all package manifests via API. Storage Account downloads the packages container."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <CheckBox x:Name="chkBackupRestSource" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,16,0">
                                                    <TextBlock Text="REST Source Manifests" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                </CheckBox>
                                                <CheckBox x:Name="chkBackupStorage" Style="{StaticResource ToggleSwitch}" IsChecked="True">
                                                    <TextBlock Text="Storage Account Blobs" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                                </CheckBox>
                                            </StackPanel>

                                            <!-- Backup REST Source Name -->
                                            <TextBlock Text="REST Source Function Name" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                            <TextBlock Text="The Azure Function App name for your WinGet REST source. Select from discovered sources or type a custom name."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="cmbBackupRestSource" Style="{StaticResource EditableComboBox}" Margin="0,0,0,10"
                                                      ToolTip="Select or type a REST source Function App name"/>

                                            <!-- Backup Storage Account -->
                                            <TextBlock Text="Storage Account Name" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Name of the Azure Storage Account to back up. Select from discovered accounts or type a custom name."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="cmbBackupStorageAcct" Style="{StaticResource EditableComboBox}" Margin="0,0,0,10"
                                                      ToolTip="Select or type a Storage Account name"/>

                                            <!-- Backup Folder -->
                                            <TextBlock Text="Backup Folder" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Local folder where backups will be saved. A timestamped subfolder is created automatically."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txtBackupFolder" Style="{StaticResource ThemedTextBox}" Grid.Column="0"
                                                         Tag="e.g. C:\Backups\WinGet"/>
                                                <Button x:Name="btnBrowseBackupFolder" Style="{StaticResource GhostButton}" Grid.Column="1"
                                                        Padding="10,6" Margin="6,0,0,0">
                                                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                                </Button>
                                            </Grid>

                                            <!-- Backup Actions -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button x:Name="btnRunBackup" Style="{StaticResource AccentButton}" Padding="16,8" Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Backup Now" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock x:Name="lblBackupStatus" Text="" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="prgBackup" Height="3" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"
                                                         Background="{DynamicResource ThemeSurfaceBg}" Foreground="{DynamicResource ThemeAccent}" Margin="0,0,0,10"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- RESTORE section -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="3" Height="12" Background="{DynamicResource ThemeAccent}" CornerRadius="1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="RESTORE" FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextDim}"/>
                                    </StackPanel>
                                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Select a backup folder to restore manifests and/or storage blobs to a target deployment. The backup_metadata.json inside the folder is read to determine what was backed up."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                            <!-- Restore Source Folder -->
                                            <TextBlock Text="Backup Folder to Restore" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txtRestoreFolder" Style="{StaticResource ThemedTextBox}" Grid.Column="0"
                                                         Tag="e.g. C:\Backups\WinGet\corpwinget_20260313_143022"/>
                                                <Button x:Name="btnBrowseRestoreFolder" Style="{StaticResource GhostButton}" Grid.Column="1"
                                                        Padding="10,6" Margin="6,0,0,0">
                                                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                                </Button>
                                            </Grid>

                                            <!-- Restore Targets -->
                                            <TextBlock Text="Restore Target" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,2"/>
                                            <TextBlock Text="Where to restore. Defaults to the original source names from the backup, but you can override to restore to a different environment."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                    <TextBlock Text="Target REST Source" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                    <ComboBox x:Name="cmbRestoreRestTarget" Style="{StaticResource EditableComboBox}"
                                                              ToolTip="Select or type a target REST source"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                    <TextBlock Text="Target Storage Account" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,3"/>
                                                    <ComboBox x:Name="cmbRestoreStorageTarget" Style="{StaticResource EditableComboBox}"
                                                              ToolTip="Select or type a target Storage Account"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Restore Actions -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button x:Name="btnRunRestore" Style="{StaticResource AccentButton}" Padding="16,8" Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Restore Now" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock x:Name="lblRestoreStatus" Text="" FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="prgRestore" Height="3" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"
                                                         Background="{DynamicResource ThemeSurfaceBg}" Foreground="{DynamicResource ThemeAccent}" Margin="0,0,0,4"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <!-- ROW 3: BOTTOM PANEL SPLITTER -->
        <GridSplitter x:Name="splitterBottom" Grid.Row="3" Height="4" Background="Transparent"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center" Cursor="SizeNS"
                      ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

        <!-- ROW 4: BOTTOM LOG PANEL (VS Code-style) -->
        <Border x:Name="pnlBottomPanel" Grid.Row="4" Background="{DynamicResource ThemePanelBg}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Header bar -->
                <Border Grid.Row="0" Background="{DynamicResource ThemeDeepBg}" Padding="12,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="1" Text="OUTPUT" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                        <Button x:Name="btnClearLog" Style="{StaticResource IconButton}" Grid.Column="3" Width="24" Height="24" ToolTip="Clear output">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                        </Button>
                        <Button x:Name="btnToggleBottomSize" Style="{StaticResource IconButton}" Grid.Column="4" Width="24" Height="24" ToolTip="Maximize/Restore panel">
                            <TextBlock x:Name="icoToggleBottomSize" Text="&#xE740;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                        </Button>
                        <Button x:Name="btnHideBottom" Style="{StaticResource IconButton}" Grid.Column="5" Width="24" Height="24" ToolTip="Hide panel">
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                        </Button>
                    </Grid>
                </Border>
                <!-- Heatmap timeline strip -->
                <Canvas x:Name="cnvHeatmap" Grid.Row="1" Background="{DynamicResource ThemeDeepBg}" ClipToBounds="True"/>
                <!-- Log content + minimap -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="14"/>
                    </Grid.ColumnDefinitions>
                    <ScrollViewer x:Name="logScroller" Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="12,6"
                                  Background="{DynamicResource ThemeOutputBg}">
                        <RichTextBox x:Name="rtbActivityLog" Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                     FontSize="10" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource ThemeTextMuted}"
                                     IsDocumentEnabled="False"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <FlowDocument x:Name="docActivityLog" PageWidth="5000">
                                <Paragraph x:Name="paraLog" Margin="0" LineHeight="16"/>
                            </FlowDocument>
                        </RichTextBox>
                    </ScrollViewer>
                    <Border Grid.Column="1" Background="{DynamicResource ThemeBorderCard}"/>
                    <Canvas x:Name="cnvMinimap" Grid.Column="2" Background="{DynamicResource ThemeDeepBg}" ClipToBounds="True"/>
                </Grid>
            </Grid>
        </Border>

        <!-- CONFETTI CANVAS (spans entire window, above everything) -->
        <Canvas x:Name="cnvConfetti" Grid.Row="0" Grid.RowSpan="6" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="9999"/>

        <!-- ROW 5: STATUS BAR -->
        <Border Grid.Row="5" Background="{DynamicResource ThemeDeepBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="statusDot" Width="6" Height="6" Fill="{DynamicResource ThemeTextDim}" Margin="0,0,6,0"/>
                    <TextBlock x:Name="lblStatus" Text="Ready" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="|" Foreground="{DynamicResource ThemeTextFaintest}" Margin="10,0" VerticalAlignment="Center" FontSize="10"/>
                <TextBlock x:Name="lblPackageCount" Grid.Column="2" Text="" FontSize="10" Foreground="{DynamicResource ThemeTextDisabled}" VerticalAlignment="Center"/>

                <!-- Quality meter -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="Quality:" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Border Background="{DynamicResource ThemeDeepBg}" CornerRadius="3" Width="60" Height="6" VerticalAlignment="Center">
                        <Border x:Name="barQuality" Background="{DynamicResource ThemeSuccess}" CornerRadius="3" Height="6" HorizontalAlignment="Left" Width="0"/>
                    </Border>
                    <TextBlock x:Name="lblQualityPct" Text="" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeSuccess}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Streak display -->
                <TextBlock x:Name="lblStreak" Grid.Column="4" Text="" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBlock x:Name="lblRegion" Grid.Column="5" Text="" FontSize="10" Foreground="{DynamicResource ThemeAccentLight}" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="lblVersion" Grid.Column="6" Text="v0.1.0-alpha" FontSize="10" Foreground="{DynamicResource ThemeTextDisabled}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
