<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:cp="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="PresentationOptions"
        Title="Device Decommissioner" Height="860" Width="1240"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowState="Maximized"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        Background="{DynamicResource ThemeAppBg}" Foreground="{DynamicResource ThemeTextBody}"
        FontFamily="Inter, Segoe UI Variable Display, Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="4" GlassFrameThickness="1" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ============================================================ -->
        <!-- THEME BRUSHES (Dark defaults, mutated at runtime for Light)   -->
        <!-- ============================================================ -->
        <SolidColorBrush x:Key="ThemeAppBg"           Color="#111111" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemePanelBg"         Color="#1A1A1A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeCardBg"          Color="#222222" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeCardAltBg"       Color="#252528" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeInputBg"         Color="#141414" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeDeepBg"          Color="#0D0D0D" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeOutputBg"        Color="#080808" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSurfaceBg"       Color="#2A2A2A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeHoverBg"         Color="#333333" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSelectedBg"      Color="#2E2E32" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemePressedBg"       Color="#181818" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccent"          Color="#0078D4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentHover"     Color="#1A8AD4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentLight"     Color="#60CDFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentDim"       Color="#004578" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeGreenAccent"     Color="#00C853" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentText"      Color="#FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextPrimary"     Color="#FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextBody"        Color="#E0E0E0" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextSecondary"   Color="#CCCCCC" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextMuted"       Color="#AAAAAA" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextDim"         Color="#888888" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextDisabled"    Color="#555555" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorder"          Color="#2A2A2A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderCard"      Color="#333333" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderElevated"  Color="#3E3E3E" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderHover"     Color="#505050" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeScrollThumb"     Color="#444444" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeScrollTrack"     Color="#22FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSuccess"         Color="#00C853" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeWarning"         Color="#FFB900" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeError"           Color="#D13438" PresentationOptions:Freeze="False"/>

        <!-- ============================================================ -->
        <!-- DOTTED BACKGROUND PATTERN (theme-mutated via DotColorBrush)    -->
        <!-- ============================================================ -->
        <SolidColorBrush x:Key="DotColorBrush" Color="#22808080" PresentationOptions:Freeze="False"/>
        <DrawingBrush x:Key="DotGridBrush" TileMode="Tile"
                      Viewport="0,0,44,44" ViewportUnits="Absolute"
                      Viewbox="0,0,44,44" ViewboxUnits="Absolute"
                      PresentationOptions:Freeze="False">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="{DynamicResource DotColorBrush}">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="22,22" RadiusX="1.3" RadiusY="1.3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- ============================================================ -->
        <!-- RADIAL GLOW (subtle accent halo at top-center)                -->
        <!-- ============================================================ -->
        <SolidColorBrush x:Key="GlowColorBrush" Color="#10005A9E" PresentationOptions:Freeze="False"/>

        <!-- ============================================================ -->
        <!-- DISCOVERY CARD (hover-lit border, matches WMM card surface)    -->
        <!-- ============================================================ -->
        <Style x:Key="DiscoveryCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource ThemeCardBg}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="14,12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{DynamicResource ThemeHoverBg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!-- DATA GRID STYLES (PolicyPilot-style: dark, alternating rows)   -->
        <!-- ============================================================ -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource ThemeSurfaceBg}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DarkColumnHeader" TargetType="{x:Type cp:DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource ThemeDeepBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeSelectedBg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeSelectedBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell text styles for status symbols ✓ / ✗ / - -->
        <Style x:Key="HistoryStatusCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="✓">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeSuccess}"/>
                </Trigger>
                <Trigger Property="Text" Value="✗">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeError}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Mode pill for dry-run / real -->
        <Style x:Key="ModePillCell" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Background" Value="{DynamicResource ThemeAccentDim}"/>
        </Style>

        <!-- Inventory check status cell (Found/Not found/Error/Sign in) -->
        <Style x:Key="InventoryStatusCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="Found">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeSuccess}"/>
                </Trigger>
                <Trigger Property="Text" Value="Not found">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                </Trigger>
                <Trigger Property="Text" Value="Error">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeError}"/>
                </Trigger>
                <Trigger Property="Text" Value="Sign in">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeWarning}"/>
                </Trigger>
                <Trigger Property="Text" Value="N/A">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!-- TAB BUTTON (underlined active state)                          -->
        <!-- ============================================================ -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================ -->
        <!-- DRY-RUN PILL TOGGLE                                            -->
        <!-- ============================================================ -->
        <Style x:Key="DryRunToggle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bdr" CornerRadius="14" Padding="{TemplateBinding Padding}"
                                Background="{DynamicResource ThemeInputBg}"
                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="swTrack" Width="26" Height="14" CornerRadius="7"
                                        Background="{DynamicResource ThemeBorderHover}" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border x:Name="swKnob" Width="10" Height="10" CornerRadius="5"
                                            Background="White" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bdr"     Property="Background"  Value="{DynamicResource ThemeAccentDim}"/>
                                <Setter TargetName="bdr"     Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="swTrack" Property="Background"  Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="swKnob"  Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="swKnob"  Property="Margin"      Value="0,0,2,0"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================ -->
        <!-- SCROLLBAR (10px, rounded, themed)                              -->
        <!-- ============================================================ -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Background="{DynamicResource ThemeScrollTrack}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder" Background="{DynamicResource ThemeScrollThumb}" CornerRadius="4" MinHeight="40" Margin="1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ThemeAccentLight}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ThemeTextPrimary}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="GridRoot" Property="Height" Value="10"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="10"/>
                                <Setter Property="MinHeight" Value="10"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TITLE BAR BUTTON -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeSurfaceBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#B90D1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACCENT BUTTON (Gradient blue with glow) -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#005A9E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#0078D4" Direction="270" ShadowDepth="0" BlurRadius="10" Opacity="0.25"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A8AD4" Offset="0"/>
                                            <GradientStop Color="#0067C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bdr" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#0078D4" Direction="270" ShadowDepth="0" BlurRadius="16" Opacity="0.40"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#005A9E" Offset="0"/>
                                            <GradientStop Color="#004578" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="bdr" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER ACCENT BUTTON (Gradient red with glow) -->
        <Style x:Key="DangerAccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="22,11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#D13438" Offset="0"/>
                                    <GradientStop Color="#A4262C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#D13438" Direction="270" ShadowDepth="0" BlurRadius="12" Opacity="0.30"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E81E25" Offset="0"/>
                                            <GradientStop Color="#B71C22" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bdr" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#D13438" Direction="270" ShadowDepth="0" BlurRadius="20" Opacity="0.50"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#A4262C" Offset="0"/>
                                            <GradientStop Color="#7A1B20" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="bdr" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST BUTTON -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER GHOST BUTTON -->
        <Style x:Key="DangerGhostButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent" BorderBrush="{DynamicResource ThemeBorderCard}"
                                BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#20D13438"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeError}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeError}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ICON BUTTON -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXTBOX (themed, focus ring) -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource ThemeAccent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeBorderHover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeDeepBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PASSWORDBOX -->
        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimary}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource ThemeAccent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type PasswordBox}">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeBorderHover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CHECKBOX -->
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="16" Height="16" CornerRadius="4"
                                    Background="{DynamicResource ThemeInputBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="check" Text="&#xE73E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="11" Foreground="White" Visibility="Collapsed"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RADIO BUTTON -->
        <Style TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="16" Height="16" VerticalAlignment="Center">
                                <Ellipse x:Name="outer" Stroke="{DynamicResource ThemeBorderCard}" StrokeThickness="1"
                                         Fill="{DynamicResource ThemeInputBg}"/>
                                <Ellipse x:Name="inner" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}" Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="outer" Property="Stroke" Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="inner" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outer" Property="Stroke" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- THEMED TOOLTIP -->
        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="{DynamicResource ThemeDeepBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToolTip}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- THEMED GRIDSPLITTER (subtle resting bar, accent on hover/drag) -->
        <Style TargetType="{x:Type GridSplitter}">
            <Setter Property="Background" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridSplitter}">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeAccentDim}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============================================================ -->
        <!-- MAIN LAYOUT                                                    -->
        <!-- ============================================================ -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>   <!-- 0: Title bar -->
            <RowDefinition Height="*"/>    <!-- 1: Main content -->
            <RowDefinition x:Name="rowSplitter" Height="4"/>    <!-- 2: Splitter -->
            <RowDefinition x:Name="rowLog" Height="160"/>  <!-- 3: Log panel -->
            <RowDefinition Height="28"/>   <!-- 4: Status bar -->
        </Grid.RowDefinitions>

        <!-- ===== TITLE BAR ===== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeDeepBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border Background="{DynamicResource ThemeAccent}" CornerRadius="4" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="lblTitle" Text="Device Decommissioner" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblTitleVersion" Text="v0.1.0-alpha" FontSize="9" Margin="8,0,0,0"
                               Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                    <Border CornerRadius="4" Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center"
                            BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                        <TextBlock Text="EXPERIMENTAL" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnHelp" Style="{StaticResource TitleBarButton}" Content="&#xE897;" ToolTip="Help"/>
                    <Button x:Name="btnSettings" Style="{StaticResource TitleBarButton}" Content="&#xE713;" ToolTip="Settings"/>
                    <Button x:Name="btnThemeToggle" Style="{StaticResource TitleBarButton}" Content="&#xE706;" ToolTip="Toggle theme"/>
                    <Button x:Name="btnMinimize" Style="{StaticResource TitleBarButton}" Content="&#xE921;" ToolTip="Minimize"/>
                    <Button x:Name="btnMaximize" Style="{StaticResource TitleBarButton}" Content="&#xE922;" ToolTip="Maximize"/>
                    <Button x:Name="btnClose" Style="{StaticResource TitleBarCloseButton}" Content="&#xE8BB;" ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT (toolbar + scrolling content) ===== -->
        <Grid Grid.Row="1" Background="{DynamicResource ThemeAppBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>   <!-- 0: Auth toolbar -->
                <RowDefinition x:Name="rowProgress" Height="0"/>  <!-- 1: Global progress (auto-shows) -->
                <RowDefinition Height="*"/>    <!-- 2: Content -->
            </Grid.RowDefinitions>

            <!-- Subtle glow tint overlay (covers entire content area) -->
            <Border Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource GlowColorBrush}" IsHitTestVisible="False"/>

            <!-- ===== AUTH TOOLBAR ===== -->
            <Border Grid.Row="0" Background="{DynamicResource ThemeSidebarBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>   <!-- Auth pill -->
                        <ColumnDefinition Width="Auto"/>   <!-- Tenant info -->
                        <ColumnDefinition Width="*"/>      <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/>   <!-- Sign In -->
                        <ColumnDefinition Width="Auto"/>   <!-- Sign Out -->
                    </Grid.ColumnDefinitions>
                    <!-- Auth status badge -->
                    <Border Grid.Column="0" CornerRadius="12" Padding="10,4" Height="28" MinWidth="160"
                            Background="{DynamicResource ThemeInputBg}"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="authDot" Width="8" Height="8"
                                     Fill="{DynamicResource ThemeError}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblAuthStatus" Text="Not signed in"
                                       FontSize="11" Foreground="{DynamicResource ThemeTextBody}"
                                       MaxWidth="260" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Tenant info -->
                    <Border Grid.Column="1" Margin="10,0,0,0" CornerRadius="12" Padding="10,4" Height="28"
                            Background="{DynamicResource ThemeInputBg}"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" VerticalAlignment="Center"
                            x:Name="bdrTenantInfo" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblTenantInfo" Text="" FontSize="11"
                                       Foreground="{DynamicResource ThemeTextSecondary}"
                                       MaxWidth="320" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Sign In (interactive Connect-MgGraph; cached for session) -->
                    <Button Grid.Column="3" x:Name="btnEntraSignIn" Style="{StaticResource AccentButton}" Padding="16,6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sign in to Entra" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Sign Out -->
                    <Button Grid.Column="4" x:Name="btnEntraSignOut" Style="{StaticResource DangerGhostButton}" Content="Sign out"
                            Padding="12,5" Margin="6,0,0,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ===== SCROLLING CONTENT (rail + sidebar + content) ===== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>                          <!-- 0: Icon rail -->
                    <ColumnDefinition x:Name="colSidebar" Width="260"/>    <!-- 1: Sidebar -->
                    <ColumnDefinition Width="*"/>                           <!-- 2: Content -->
                </Grid.ColumnDefinitions>

                <!-- ===== ICON RAIL ===== -->
                <Border Grid.Column="0" Background="{DynamicResource ThemeSidebarBg}"
                        BorderBrush="{DynamicResource ThemeSidebarBorder}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                            <Button x:Name="btnRailHamburger" Style="{StaticResource IconButton}" Width="32" Height="32" Margin="6,0,6,6" ToolTip="Toggle sidebar">
                                <TextBlock Text="&#xE700;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button x:Name="btnRailDevice" Style="{StaticResource IconButton}" Width="32" Height="32" Margin="6,0,6,2" ToolTip="Home — return to decommission view">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource ThemeAccentLight}"/>
                            </Button>
                            <Button x:Name="btnRailBulk" Style="{StaticResource IconButton}" Width="32" Height="32" Margin="6,0,6,2" ToolTip="Inventory check (read-only multi-device lookup)">
                                <TextBlock Text="&#xE762;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button x:Name="btnRailHistory" Style="{StaticResource IconButton}" Width="32" Height="32" Margin="6,0,6,2" ToolTip="Decommission history">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button x:Name="btnRailAchievements" Style="{StaticResource IconButton}" Width="32" Height="32" Margin="6,0,6,2" ToolTip="Achievements">
                                <TextBlock Text="&#xE735;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button x:Name="btnRailSettings" Style="{StaticResource IconButton}" Width="32" Height="32" Margin="6,0,6,2" ToolTip="Settings">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                        </StackPanel>
                        <Button x:Name="btnRailHelp" DockPanel.Dock="Bottom" Style="{StaticResource IconButton}" Width="32" Height="32" Margin="6,0,6,8" ToolTip="Help">
                            <TextBlock Text="&#xE897;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"/>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- ===== SIDEBAR (RECENT DEVICES) ===== -->
                <Border x:Name="pnlSidebar" Grid.Column="1" Background="{DynamicResource ThemePanelBg}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="12,10,8,8">
                            <Button x:Name="btnClearRecent" DockPanel.Dock="Right" Style="{StaticResource IconButton}" Width="22" Height="22" ToolTip="Clear all recent devices">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                            </Button>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource ThemeAccentLight}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="RECENT DEVICES" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                        <ListBox Grid.Row="1" x:Name="lstRecentDevices"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 HorizontalContentAlignment="Stretch" Padding="4,0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,3"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bdr" Background="{DynamicResource ThemeCardBg}"
                                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                                        CornerRadius="6" Padding="10,7" SnapsToDevicePixels="True">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                                        <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeBorderHover}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeSelectedBg}"/>
                                                        <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        <TextBlock Grid.Row="2" x:Name="lblRecentEmpty" Text="No recent lookups yet. Devices appear here after you search."
                                   FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap"
                                   Margin="12,0,12,12" Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- ===== CONTENT COLUMN ===== -->
                <Grid Grid.Column="2">
                    <Border Background="{DynamicResource DotGridBrush}" IsHitTestVisible="False"/>
                    <ScrollViewer x:Name="svMainContent" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="32,24">
                        <StackPanel x:Name="pnlMain">

                    <!-- HEADER -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Decommission a device" FontSize="19" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextPrimary}"/>
                        <TextBlock Text="Look up a device, review where it exists, then remove it from the selected directories."
                                   FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- PREREQUISITES CALL-OUT (shown when required PowerShell modules are missing) -->
                    <Border x:Name="pnlPrereqs" Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12"
                            BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1"
                            Padding="14,10" Margin="0,0,0,12" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#33FFB900" Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{DynamicResource ThemeWarning}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Required PowerShell modules are missing" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThemeTextPrimary}"/>
                                <TextBlock x:Name="lblPrereqsDetail" Text="" FontSize="11"
                                           Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="btnInstallGraph" Style="{StaticResource AccentButton}" Padding="12,6" Margin="0,0,6,0" Visibility="Collapsed"
                                        ToolTip="Install Microsoft.Graph PowerShell SDK for the current user">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Install Microsoft.Graph" FontSize="11" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnPrereqHelp" Style="{StaticResource GhostButton}" Padding="10,6" Content="How do I fix the rest?"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ENTRA SIGN-IN CALL-OUT (shown when not signed in; hidden once cached MgContext is present) -->
                    <Border x:Name="pnlEntraCallout" Background="{DynamicResource ThemeCardAltBg}" CornerRadius="12"
                            BorderBrush="{DynamicResource ThemeAccentDim}" BorderThickness="1"
                            Padding="14,10" Margin="0,0,0,12" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="{DynamicResource ThemeAccentDim}" Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{DynamicResource ThemeAccentLight}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Sign in to Entra to enable Entra ID and Intune lookups" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThemeTextPrimary}"/>
                                <TextBlock Text="One sign-in is reused for the rest of this session. Without it the Entra and Intune cards will be skipped."
                                           FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button x:Name="btnEntraSignInCallout" Grid.Column="2" Style="{StaticResource AccentButton}" Padding="16,8" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                               Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sign in to Entra" FontSize="12" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- LOOKUP CARD -->
                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="8"
                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="18,14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="DEVICE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <TextBox x:Name="txtDeviceId" Padding="10,9" FontSize="14"
                                             ToolTip="Device hostname (sAMAccountName / Intune device name) or AzureAD device ObjectId"/>
                                    <TextBlock x:Name="lblDeviceIdHint" Text="e.g. LAPTOP-ABC123 or 00000000-0000-0000-0000-000000000000"
                                               IsHitTestVisible="False" Foreground="{DynamicResource ThemeTextDim}" FontSize="13" FontStyle="Italic"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Button x:Name="btnLookup" Grid.Column="2" Style="{StaticResource AccentButton}" Content="Look up"/>
                                <Button x:Name="btnCancelLookup" Grid.Column="2" Style="{StaticResource DangerGhostButton}" Content="Cancel" Visibility="Collapsed"/>
                                <Button x:Name="btnClearLookup" Grid.Column="4" Style="{StaticResource GhostButton}" Content="Clear"/>
                            </Grid>
                            <TextBlock Text="Tip: matched against AD sAMAccountName, Intune deviceName, Entra displayName, SCCM ResourceName. Use * for wildcards (e.g. LAPTOP-* or *123)."
                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- DISCOVERY GRID (4 system cards) -->
                    <UniformGrid Columns="5" Rows="1" Margin="0,0,0,10" x:Name="pnlDiscoveryGrid">

                        <!-- AD CARD -->
                        <Border Style="{StaticResource DiscoveryCard}" Margin="0,0,4,0">
                            <StackPanel>
                                <DockPanel>
                                    <CheckBox x:Name="chkTargetAD" IsChecked="True" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                                    <Button x:Name="btnCopyAD" DockPanel.Dock="Right" Style="{StaticResource IconButton}" Width="20" Height="20" ToolTip="Copy AD result" Visibility="Collapsed" Margin="0,0,4,0">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                                    </Button>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE748;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Active Directory" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                                <Border x:Name="pillAD" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="dotAD" Width="8" Height="8" Fill="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblADStatus" Text="Idle" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="lblADDetail" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="prgAD" Height="2" IsIndeterminate="True" Margin="0,6,0,0" Visibility="Collapsed"
                                             Foreground="{DynamicResource ThemeAccent}" Background="{DynamicResource ThemeSurfaceBg}" BorderThickness="0"/>
                            </StackPanel>
                        </Border>

                        <!-- ENTRA CARD -->
                        <Border Style="{StaticResource DiscoveryCard}" Margin="2,0,2,0">
                            <StackPanel>
                                <DockPanel>
                                    <CheckBox x:Name="chkTargetEntra" IsChecked="True" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                                    <Button x:Name="btnCopyEntra" DockPanel.Dock="Right" Style="{StaticResource IconButton}" Width="20" Height="20" ToolTip="Copy Entra result" Visibility="Collapsed" Margin="0,0,4,0">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                                    </Button>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Entra ID" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                                <Border x:Name="pillEntra" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="dotEntra" Width="8" Height="8" Fill="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblEntraStatus" Text="Idle" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="lblEntraDetail" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="prgEntra" Height="2" IsIndeterminate="True" Margin="0,6,0,0" Visibility="Collapsed"
                                             Foreground="{DynamicResource ThemeAccent}" Background="{DynamicResource ThemeSurfaceBg}" BorderThickness="0"/>
                            </StackPanel>
                        </Border>

                        <!-- INTUNE CARD -->
                        <Border Style="{StaticResource DiscoveryCard}" Margin="2,0,2,0">
                            <StackPanel>
                                <DockPanel>
                                    <CheckBox x:Name="chkTargetIntune" IsChecked="True" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                                    <Button x:Name="btnCopyIntune" DockPanel.Dock="Right" Style="{StaticResource IconButton}" Width="20" Height="20" ToolTip="Copy Intune result" Visibility="Collapsed" Margin="0,0,4,0">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                                    </Button>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE950;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Intune" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                                <Border x:Name="pillIntune" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="dotIntune" Width="8" Height="8" Fill="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblIntuneStatus" Text="Idle" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="lblIntuneDetail" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="prgIntune" Height="2" IsIndeterminate="True" Margin="0,6,0,0" Visibility="Collapsed"
                                             Foreground="{DynamicResource ThemeAccent}" Background="{DynamicResource ThemeSurfaceBg}" BorderThickness="0"/>
                            </StackPanel>
                        </Border>

                        <!-- SCCM CARD -->
                        <Border Style="{StaticResource DiscoveryCard}" Margin="4,0,0,0">
                            <StackPanel>
                                <DockPanel>
                                    <CheckBox x:Name="chkTargetSCCM" IsChecked="True" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                                    <Button x:Name="btnCopySCCM" DockPanel.Dock="Right" Style="{StaticResource IconButton}" Width="20" Height="20" ToolTip="Copy SCCM result" Visibility="Collapsed" Margin="0,0,4,0">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                                    </Button>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7F8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                        <TextBlock Text="SCCM" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                                <Border x:Name="pillSCCM" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="dotSCCM" Width="8" Height="8" Fill="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblSCCMStatus" Text="Idle" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="lblSCCMDetail" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="prgSCCM" Height="2" IsIndeterminate="True" Margin="0,6,0,0" Visibility="Collapsed"
                                             Foreground="{DynamicResource ThemeAccent}" Background="{DynamicResource ThemeSurfaceBg}" BorderThickness="0"/>
                            </StackPanel>
                        </Border>

                        <!-- AUTOPILOT CARD -->
                        <Border Style="{StaticResource DiscoveryCard}" Margin="4,0,0,0">
                            <StackPanel>
                                <DockPanel>
                                    <CheckBox x:Name="chkTargetAutopilot" IsChecked="False" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                                    <Button x:Name="btnCopyAutopilot" DockPanel.Dock="Right" Style="{StaticResource IconButton}" Width="20" Height="20" ToolTip="Copy Autopilot result" Visibility="Collapsed" Margin="0,0,4,0">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                                    </Button>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE966;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Autopilot" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                                <Border x:Name="pillAutopilot" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="dotAutopilot" Width="8" Height="8" Fill="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblAutopilotStatus" Text="Idle" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="lblAutopilotDetail" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="prgAutopilot" Height="2" IsIndeterminate="True" Margin="0,6,0,0" Visibility="Collapsed"
                                             Foreground="{DynamicResource ThemeAccent}" Background="{DynamicResource ThemeSurfaceBg}" BorderThickness="0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- CREDENTIALS CARD -->
                    <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="8" BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="18,14" Margin="0,0,0,12">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button x:Name="btnEditCredsAD" Style="{StaticResource GhostButton}" Padding="10,5" FontSize="11" ToolTip="Set / replace AD credentials (DPAPI per-user)">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="Set AD creds" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="btnEditCredsSCCM" Style="{StaticResource GhostButton}" Padding="10,5" FontSize="11" Margin="6,0,0,0" ToolTip="Set / replace SCCM credentials (DPAPI per-user)">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="Set SCCM creds" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Text="CREDENTIALS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                            </DockPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- AD -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Active Directory" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                                    <Border x:Name="bdrCredAD" Background="{DynamicResource ThemeInputBg}" CornerRadius="6" BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="10,7">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="dotCredAD" Width="8" Height="8" Fill="{DynamicResource ThemeWarning}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="lblCredAD" Text="Not configured" FontSize="11" Foreground="{DynamicResource ThemeTextBody}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <!-- Entra -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Entra ID" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                                    <Border Background="{DynamicResource ThemeInputBg}" CornerRadius="6" BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="10,7">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="dotCredEntra" Width="8" Height="8" Fill="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Interactive sign-in" FontSize="11" Foreground="{DynamicResource ThemeTextBody}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <!-- Intune -->
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Intune" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                                    <Border Background="{DynamicResource ThemeInputBg}" CornerRadius="6" BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="10,7">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="dotCredIntune" Width="8" Height="8" Fill="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Interactive sign-in" FontSize="11" Foreground="{DynamicResource ThemeTextBody}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <!-- SCCM -->
                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="SCCM" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                                    <Border x:Name="bdrCredSCCM" Background="{DynamicResource ThemeInputBg}" CornerRadius="6" BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="10,7">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="dotCredSCCM" Width="8" Height="8" Fill="{DynamicResource ThemeWarning}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="lblCredSCCM" Text="Not configured" FontSize="11" Foreground="{DynamicResource ThemeTextBody}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ACTION ROW -->
                    <Border BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,12,0,0">
                    <DockPanel>
                        <Button x:Name="btnDecommission" DockPanel.Dock="Right" Style="{StaticResource DangerAccentButton}" IsEnabled="False" Padding="22,10" MinWidth="232" HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="lblDecommissionIcon" Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblDecommissionLabel" Text="Decommission selected" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnRefresh" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <ToggleButton x:Name="chkDryRun" DockPanel.Dock="Right" Style="{StaticResource DryRunToggle}" Margin="0,0,12,0" VerticalAlignment="Center"
                                      ToolTip="Dry run validates connectivity / lookup-result completeness for every selected system without calling any destructive cmdlet.">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Dry run" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>
                        <TextBlock x:Name="lblActionHint" Text="Look up a device to enable decommissioning."
                                   FontSize="11" Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                    </DockPanel>
                    </Border>

                </StackPanel>
                    </ScrollViewer>

                    <!-- ===== IN-APP SETTINGS VIEW (tabbed) ===== -->
                    <Grid x:Name="pnlSettingsView" Visibility="Collapsed" Background="{DynamicResource ThemeAppBg}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- Header -->
                            <RowDefinition Height="Auto"/>   <!-- Tab strip -->
                            <RowDefinition Height="*"/>      <!-- Tab content -->
                            <RowDefinition Height="Auto"/>   <!-- Action row -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Margin="32,24,32,12">
                            <DockPanel>
                                <Button x:Name="btnSettingsBack" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Padding="10,5" ToolTip="Close settings without saving">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Back" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel>
                                    <TextBlock Text="Settings" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                    <TextBlock Text="Configure how Device Decommissioner connects to each directory and how the app behaves."
                                               FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>

                        <!-- Tab strip -->
                        <Border Grid.Row="1" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1" Padding="24,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="setTabGeneral" Style="{StaticResource TabButton}" Content="General" BorderBrush="{DynamicResource ThemeAccent}" Foreground="{DynamicResource ThemeTextPrimary}" FontWeight="SemiBold"/>
                                <Button x:Name="setTabAD"      Style="{StaticResource TabButton}" Content="Active Directory"/>
                                <Button x:Name="setTabEntra"   Style="{StaticResource TabButton}" Content="Entra ID"/>
                                <Button x:Name="setTabIntune"  Style="{StaticResource TabButton}" Content="Intune"/>
                                <Button x:Name="setTabSCCM"    Style="{StaticResource TabButton}" Content="SCCM"/>
                                <Button x:Name="setTabAppearance" Style="{StaticResource TabButton}" Content="Appearance"/>
                            </StackPanel>
                        </Border>

                        <!-- Tab content -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="32,20,32,16">
                            <Grid HorizontalAlignment="Left" MaxWidth="720">
                                <!-- GENERAL tab -->
                                <StackPanel x:Name="setPaneGeneral">
                                    <TextBlock Text="Application" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Settings file" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBlock x:Name="lblSettingsFilePath" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,2,0,12" TextWrapping="Wrap"/>
                                    <TextBlock Text="Recent devices file" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBlock x:Name="lblRecentFilePath"   Text="" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,2,0,12" TextWrapping="Wrap"/>
                                    <TextBlock Text="Log file" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBlock x:Name="lblLogFilePath"      Text="" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,2,0,16" TextWrapping="Wrap"/>
                                    <TextBlock Text="Persistent across sessions. The log auto-rotates at 2 MB." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                    <TextBlock Text="Audit trail file" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBlock x:Name="lblAuditFilePath"    Text="" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,2,0,12" TextWrapping="Wrap"/>
                                    <TextBlock Text="Appended after every decommission (including dry-runs). Never auto-rotated." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                    <TextBlock Text="Safety" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,8,0,8"/>
                                    <TextBlock Text="Recently-active threshold (days)" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBox x:Name="txtSetRecentDays" Padding="10,7" Margin="0,4,0,2" MaxWidth="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Warn before decommissioning a device whose last logon/sync is within this many days (default 7)." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                    <TextBlock Text="Data" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,8,0,8"/>
                                    <Button x:Name="btnExportAudit" Style="{StaticResource GhostButton}" Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEDE1;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="Export audit trail as CSV" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Text="Exports decommission-history.json to a CSV file for management reporting." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,2,0,12" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- AD tab -->
                                <StackPanel x:Name="setPaneAD" Visibility="Collapsed">
                                    <TextBlock Text="Active Directory" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Domain controller (optional)" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBox x:Name="txtSetADServer" Padding="10,7" Margin="0,4,0,2"/>
                                    <TextBlock Text="Preferred DC FQDN. Leave blank to use the nearest discoverable DC." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16" TextWrapping="Wrap"/>
                                    <TextBlock Text="Search base (DN)" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBox x:Name="txtSetADSearchBase" Padding="10,7" Margin="0,4,0,2"/>
                                    <TextBlock Text="e.g. OU=Computers,DC=contoso,DC=com. Blank = search the whole domain." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16" TextWrapping="Wrap"/>
                                    <CheckBox x:Name="chkSetADEnabled" Content="Enable Active Directory by default"/>
                                    <TextBlock Text="Controls the default state of the AD checkbox on the lookup view. You can still toggle per-lookup." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="22,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Entra tab -->
                                <StackPanel x:Name="setPaneEntra" Visibility="Collapsed">
                                    <TextBlock Text="Entra ID" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Tenant ID (optional)" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBox x:Name="txtSetEntraTenant" Padding="10,7" Margin="0,4,0,2"/>
                                    <TextBlock Text="Pin sign-in to a specific tenant. Blank = home tenant of the signed-in account." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16" TextWrapping="Wrap"/>
                                    <CheckBox x:Name="chkSetEntraEnabled" Content="Enable Entra ID by default"/>
                                    <TextBlock Text="Sign-in is shared with Intune (one Microsoft Graph context covers both)." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="22,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Intune tab -->
                                <StackPanel x:Name="setPaneIntune" Visibility="Collapsed">
                                    <TextBlock Text="Intune" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="chkSetIntuneEnabled" Content="Enable Intune by default"/>
                                    <TextBlock Text="Removes the Intune managed-device record only. It does NOT wipe or retire the device." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="22,2,0,16" TextWrapping="Wrap"/>
                                    <CheckBox x:Name="chkSetAutopilotEnabled" Content="Enable Autopilot by default"/>
                                    <TextBlock Text="Removes the Windows Autopilot device identity. Requires DeviceManagementServiceConfig.ReadWrite.All scope." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="22,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- SCCM tab -->
                                <StackPanel x:Name="setPaneSCCM" Visibility="Collapsed">
                                    <TextBlock Text="Configuration Manager (SCCM)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Site server FQDN" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBox x:Name="txtSetSCCMServer" Padding="10,7" Margin="0,4,0,2"/>
                                    <TextBlock Text="Primary site server FQDN. Required for any SCCM operation." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16" TextWrapping="Wrap"/>
                                    <TextBlock Text="Site code" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <TextBox x:Name="txtSetSCCMSite" MaxLength="3" Padding="10,7" Margin="0,4,0,2" Width="120" HorizontalAlignment="Left"/>
                                    <TextBlock Text="1-3 alphanumeric characters (e.g. PR1)." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16" TextWrapping="Wrap"/>
                                    <CheckBox x:Name="chkSetSCCMEnabled" Content="Enable SCCM by default"/>
                                    <TextBlock Text="Requires the Configuration Manager console (ConfigurationManager.psd1) installed on this machine." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="22,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Appearance tab -->
                                <StackPanel x:Name="setPaneAppearance" Visibility="Collapsed">
                                    <TextBlock Text="Appearance" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Theme" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,2">
                                        <RadioButton x:Name="rbThemeDark"  GroupName="Theme" Content="Dark"  IsChecked="True" Margin="0,0,16,0"/>
                                        <RadioButton x:Name="rbThemeLight" GroupName="Theme" Content="Light"/>
                                    </StackPanel>
                                    <TextBlock Text="Theme preference is saved per Windows user." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- Action row -->
                        <Border Grid.Row="3" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="24,12" Background="{DynamicResource ThemePanelBg}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnSettingsCancel" Style="{StaticResource GhostButton}" Content="Cancel" Margin="0,0,8,0"/>
                                <Button x:Name="btnSettingsSave"   Style="{StaticResource AccentButton}" Content="Save changes"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ===== INVENTORY CHECK VIEW (read-only multi-device lookup) ===== -->
                    <Grid x:Name="pnlBulkView" Visibility="Collapsed" Background="{DynamicResource ThemeAppBg}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Header -->
                        <DockPanel Grid.Row="0" Margin="24,16,24,0">
                            <Button x:Name="btnBulkBack" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Back" Padding="12,6"/>
                            <StackPanel>
                                <TextBlock Text="Inventory check" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                <TextBlock Text="Paste hostnames (one per line) to see which directories each device exists in. Read-only — no deletions."
                                           FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DockPanel>
                        <!-- Input + action -->
                        <Grid Grid.Row="1" Margin="24,12,24,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="txtBulkInput" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Height="100" Padding="10,8" FontFamily="Cascadia Code, Consolas"
                                         FontSize="12" ToolTip="Paste hostnames, one per line"/>
                                <TextBlock x:Name="lblBulkInputHint" IsHitTestVisible="False"
                                           Foreground="{DynamicResource ThemeTextDim}" FontSize="12" FontStyle="Italic"
                                           Padding="14,12" TextWrapping="Wrap" VerticalAlignment="Top">
                                    <Run Text="Paste hostnames here, one per line —"/><LineBreak/>
                                    <Run Text="LAPTOP-ABC123"/><LineBreak/>
                                    <Run Text="DESKTOP-X1"/><LineBreak/>
                                    <Run Text="TABLET-Z5"/>
                                </TextBlock>
                            </Grid>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Button x:Name="btnBulkRun" Style="{StaticResource AccentButton}" Content="Run inventory check" Padding="16,8" Margin="0,0,0,6"/>
                                <Button x:Name="btnBulkCopy" Style="{StaticResource GhostButton}" Content="Copy results" Padding="12,6"/>
                            </StackPanel>
                        </Grid>
                        <!-- Results grid -->
                        <Border Grid.Row="2" Margin="24,0,24,16" Background="{DynamicResource ThemeCardBg}" CornerRadius="8"
                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                            <Grid>
                                <DataGrid x:Name="dgBulkResults"
                                          Style="{StaticResource DarkDataGrid}"
                                          ColumnHeaderStyle="{StaticResource DarkColumnHeader}"
                                          CellStyle="{StaticResource DarkDataGridCell}"
                                          RowStyle="{StaticResource DarkDataGridRow}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="*" MinWidth="140"/>
                                        <DataGridTemplateColumn Header="AD" Width="80" SortMemberPath="AD">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding AD}" Style="{StaticResource InventoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Entra" Width="80" SortMemberPath="Entra">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding Entra}" Style="{StaticResource InventoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Intune" Width="80" SortMemberPath="Intune">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding Intune}" Style="{StaticResource InventoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Autopilot" Width="80" SortMemberPath="Autopilot">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding Autopilot}" Style="{StaticResource InventoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="SCCM" Width="80" SortMemberPath="SCCM">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding SCCM}" Style="{StaticResource InventoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <!-- Empty-state overlay -->
                                <StackPanel x:Name="pnlBulkEmpty" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE762;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                                               Foreground="{DynamicResource ThemeTextDim}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No results yet" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,12,0,4" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Paste hostnames above (one per line) and click Run inventory check."
                                               FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== HISTORY VIEW (decommission audit trail) ===== -->
                    <Grid x:Name="pnlHistoryView" Visibility="Collapsed" Background="{DynamicResource ThemeAppBg}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="24,16,24,0">
                            <Button x:Name="btnHistoryBack" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Back" Padding="12,6"/>
                            <Button x:Name="btnHistoryRefresh" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Padding="10,6" Margin="0,0,6,0" ToolTip="Refresh from disk">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="Refresh" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel>
                                <TextBlock Text="Decommission history" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                <TextBlock x:Name="lblHistoryDetail" Text="" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                        <Grid Grid.Row="1" Margin="24,12,24,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="txtHistoryFilter" Padding="10,7" FontSize="12"
                                         ToolTip="Filter by device name, operator, or system"/>
                                <TextBlock x:Name="lblHistoryFilterHint" Text="Filter by device, operator, or date…"
                                           IsHitTestVisible="False" Foreground="{DynamicResource ThemeTextDim}" FontSize="12" FontStyle="Italic"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                <CheckBox x:Name="chkHistoryHideDryRun" Content="Hide dry-runs" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button x:Name="btnHistoryLookup" Style="{StaticResource AccentButton}" Padding="12,6" Content="Look up selected"/>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="2" Margin="24,0,24,16" Background="{DynamicResource ThemeCardBg}" CornerRadius="8"
                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                            <Grid>
                                <DataGrid x:Name="dgHistory"
                                          Style="{StaticResource DarkDataGrid}"
                                          ColumnHeaderStyle="{StaticResource DarkColumnHeader}"
                                          CellStyle="{StaticResource DarkDataGridCell}"
                                          RowStyle="{StaticResource DarkDataGridRow}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="When" Binding="{Binding When}" Width="160"/>
                                        <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="*" MinWidth="140"/>
                                        <DataGridTextColumn Header="Operator" Binding="{Binding Operator}" Width="180"/>
                                        <DataGridTemplateColumn Header="Mode" Width="80" SortMemberPath="Mode">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ModePillCell}">
                                                        <TextBlock Text="{Binding Mode}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="AD" Width="60" SortMemberPath="AD">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding AD}" Style="{StaticResource HistoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Entra" Width="60" SortMemberPath="Entra">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding Entra}" Style="{StaticResource HistoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Intune" Width="60" SortMemberPath="Intune">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding Intune}" Style="{StaticResource HistoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Autopilot" Width="80" SortMemberPath="Autopilot">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding Autopilot}" Style="{StaticResource HistoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="SCCM" Width="60" SortMemberPath="SCCM">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><TextBlock Text="{Binding SCCM}" Style="{StaticResource HistoryStatusCell}"/></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <!-- Empty-state overlay -->
                                <StackPanel x:Name="pnlHistoryEmpty" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="40"
                                               Foreground="{DynamicResource ThemeTextDim}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No decommissions yet" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,12,0,4" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Run a real or dry-run decommission to populate this view."
                                               FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== ACHIEVEMENTS VIEW ===== -->
                    <Grid x:Name="pnlAchievementsView" Visibility="Collapsed" Background="{DynamicResource ThemeAppBg}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="24,16,24,0">
                            <Button x:Name="btnAchievementsBack" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Content="Back" Padding="12,6"/>
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Achievements" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                    <Border Background="{DynamicResource ThemeAccentDim}" CornerRadius="10" Padding="10,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="lblAchievementsCount" Text="0/30" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeAccentLight}"/>
                                    </Border>
                                </DockPanel>
                                <TextBlock Text="Earned by using the tool. Hover any badge for details. Locked badges are dim until unlocked."
                                           FontSize="12" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                        <ScrollViewer Grid.Row="1" Margin="24,12,24,16" VerticalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="pnlAchievementsGrid" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Global progress shimmer (own row - never overlays content) -->
            <Grid Grid.Row="1" x:Name="pnlGlobalProgress" Visibility="Collapsed" ClipToBounds="True">
                <Border Height="22" Background="{DynamicResource ThemeSurfaceBg}"/>
                <Border Height="22">
                    <Border.Background>
                        <LinearGradientBrush MappingMode="RelativeToBoundingBox" StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0.0"/>
                            <GradientStop Color="#0078D4" Offset="0.15"/>
                            <GradientStop Color="#60CDFF" Offset="0.35"/>
                            <GradientStop Color="#0078D4" Offset="0.55"/>
                            <GradientStop Color="Transparent" Offset="0.7"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="shimmerTranslate" X="-500"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="shimmerTranslate" Storyboard.TargetProperty="X"
                                                     From="-500" To="1300" Duration="0:0:2.0"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>
                <TextBlock x:Name="lblGlobalProgress" Text="" FontSize="11" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="Black" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>

            <!-- Toast host (top-right) -->
            <StackPanel Grid.Row="2" x:Name="pnlToastHost" Margin="0,12,16,0" VerticalAlignment="Top" HorizontalAlignment="Right" IsHitTestVisible="False"/>

            <!-- ===== MODAL OVERLAY ===== -->
            <Grid Grid.Row="0" Grid.RowSpan="3" x:Name="pnlModalOverlay" Visibility="Collapsed" Background="#CC000000">
                <Border Background="{DynamicResource ThemeCardBg}" BorderBrush="{DynamicResource ThemeBorderElevated}" BorderThickness="1"
                        CornerRadius="12" Padding="28,22" MaxWidth="640" MaxHeight="720" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="8" BlurRadius="40" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- icon + title -->
                            <RowDefinition Height="Auto"/>   <!-- intro message -->
                            <RowDefinition Height="*"/>      <!-- scrollable details + warnings -->
                            <RowDefinition Height="Auto"/>   <!-- text/pwd input prompt -->
                            <RowDefinition Height="Auto"/>   <!-- input -->
                            <RowDefinition Height="Auto"/>   <!-- buttons -->
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock x:Name="lblModalIcon" Text="&#xE7BA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="20" Foreground="{DynamicResource ThemeWarning}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblModalTitle" Text="Confirm" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextPrimary}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Grid.Row="1" x:Name="lblModalMessage" Text="" FontSize="12" Foreground="{DynamicResource ThemeTextBody}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <ScrollViewer Grid.Row="2" x:Name="pnlModalDetailsScroll" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="380">
                            <StackPanel>
                                <ItemsControl x:Name="pnlModalDetails">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource ThemeInputBg}" BorderBrush="{DynamicResource ThemeBorderCard}"
                                                    BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,4">
                                                        <Border Background="{DynamicResource ThemeAccentDim}" CornerRadius="3" Padding="6,1" DockPanel.Dock="Left">
                                                            <TextBlock Text="{Binding System}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeAccentLight}"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0"
                                                                   Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <ItemsControl ItemsSource="{Binding Fields}" Margin="2,2,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,1,0,1">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="100"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="11"
                                                                               Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Top"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11"
                                                                               Foreground="{DynamicResource ThemeTextBody}" TextWrapping="Wrap"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl x:Name="pnlModalWarnings" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#332D0A" BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1"
                                                    CornerRadius="6" Padding="10,7" Margin="0,0,0,4">
                                                <DockPanel>
                                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{DynamicResource ThemeWarning}" VerticalAlignment="Top" Margin="0,1,8,0"/>
                                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource ThemeTextBody}"
                                                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Copyable command/code snippets — used by the prereq help modal -->
                                <ItemsControl x:Name="pnlModalCommands" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11"
                                                           Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{DynamicResource ThemeDeepBg}" BorderBrush="{DynamicResource ThemeBorderCard}"
                                                            BorderThickness="1" CornerRadius="4">
                                                        <TextBox Text="{Binding Command, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                                                                 Background="Transparent" Foreground="{DynamicResource ThemeAccentLight}"
                                                                 FontFamily="Cascadia Code, Consolas" FontSize="11" Padding="10,7"
                                                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MaxHeight="80"/>
                                                    </Border>
                                                    <Button Grid.Column="1" Tag="{Binding Command}"
                                                            Style="{StaticResource IconButton}" Width="32" Height="32" Margin="6,0,0,0"
                                                            ToolTip="Copy command to clipboard">
                                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                        <TextBlock Grid.Row="3" x:Name="lblModalInputPrompt" Text="" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,12,0,4" Visibility="Collapsed"/>
                        <TextBox Grid.Row="4" x:Name="txtModalInput" Visibility="Collapsed" Margin="0,0,0,12" Padding="10,7"/>
                        <PasswordBox Grid.Row="4" x:Name="pwdModalInput" Visibility="Collapsed" Margin="0,0,0,12" Padding="10,7"/>
                        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnModalCancel" Style="{StaticResource GhostButton}" Content="Cancel" Margin="0,0,8,0"/>
                            <Button x:Name="btnModalConfirm" Style="{StaticResource AccentButton}" Content="OK"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== SETTINGS VIEW IS NOW INLINE (see pnlSettingsView in content column) ===== -->
            <!-- ===== BULK + HISTORY VIEWS are also nested inside the content column (Grid.Column=2) ===== -->
        </Grid>

        <!-- ===== SPLITTER ===== -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"/>

        <!-- ===== LOG PANEL ===== -->
        <Border Grid.Row="3" Background="{DynamicResource ThemeOutputBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Background="{DynamicResource ThemeDeepBg}">
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center"/>
                        <TextBlock Text="OUTPUT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextSecondary}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,8,0">
                        <Button x:Name="btnClearLog" Style="{StaticResource IconButton}" Width="26" Height="22" ToolTip="Clear log">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"/>
                        </Button>
                        <Button x:Name="btnCopyLog" Style="{StaticResource IconButton}" Width="26" Height="22" ToolTip="Copy log to clipboard">
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"/>
                        </Button>
                        <Button x:Name="btnToggleLog" Style="{StaticResource IconButton}" Width="26" Height="22" ToolTip="Hide output panel" Margin="4,0,0,0">
                            <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
                <RichTextBox Grid.Row="1" x:Name="rtbLog"
                             Background="{DynamicResource ThemeOutputBg}"
                             Foreground="{DynamicResource ThemeTextMuted}"
                             FontFamily="Cascadia Code, Consolas" FontSize="10"
                             BorderThickness="0" IsReadOnly="True"
                             Padding="12,6"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto">
                    <RichTextBox.Document>
                        <FlowDocument PageWidth="2000" LineHeight="16">
                            <Paragraph x:Name="logParagraph"/>
                        </FlowDocument>
                    </RichTextBox.Document>
                </RichTextBox>
            </Grid>
        </Border>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="4" Background="{DynamicResource ThemeDeepBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Ellipse x:Name="statusDot" Width="8" Height="8" Fill="{DynamicResource ThemeGreenAccent}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblStatus" Text="Ready" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="lblStatusDetail" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextDim}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <Button x:Name="btnRestoreLog" Style="{StaticResource IconButton}" Height="22" Padding="8,0" Margin="0,0,8,0" ToolTip="Show output panel" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center"/>
                            <TextBlock Text="OUTPUT" FontSize="10" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="lblVersion" Text="v0.1.0" FontSize="10" Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== CONFETTI CANVAS (spans entire window, click-through, top z-order) ===== -->
        <Canvas x:Name="cnvConfetti" Grid.Row="0" Grid.RowSpan="5" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="9999"/>
    </Grid>
</Window>
