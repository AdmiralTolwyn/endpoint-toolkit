<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PolicyPilot"
    Width="1440" Height="920"
    MinWidth="1060" MinHeight="720"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
    RenderOptions.BitmapScalingMode="HighQuality"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- THEME BRUSHES (Dark default — swapped at runtime by PS1) -->
        <SolidColorBrush x:Key="ThemeAppBg"            Color="#FF111113"/>
        <SolidColorBrush x:Key="ThemePanelBg"          Color="#FF18181B"/>
        <SolidColorBrush x:Key="ThemeCardBg"           Color="#F01E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBg"          Color="#FF141414"/>
        <SolidColorBrush x:Key="ThemeDeepBg"           Color="#FF0D0D0D"/>
        <SolidColorBrush x:Key="ThemeAccent"           Color="#FF0078D4"/>
        <SolidColorBrush x:Key="ThemeAccentHover"      Color="#FF1A8AD4"/>
        <SolidColorBrush x:Key="ThemeAccentLight"      Color="#FF60CDFF"/>
        <SolidColorBrush x:Key="ThemeGreenAccent"      Color="#FF00C853"/>
        <SolidColorBrush x:Key="ThemeTextPrimary"      Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeTextBody"         Color="#FFE0E0E0"/>
        <SolidColorBrush x:Key="ThemeTextSecondary"    Color="#FFA1A1AA"/>
        <SolidColorBrush x:Key="ThemeTextMuted"        Color="#FFB0B0B8"/>
        <SolidColorBrush x:Key="ThemeTextDim"          Color="#FFA0A0A8"/>
        <SolidColorBrush x:Key="ThemeHoverBg"          Color="#FF27272B"/>
        <SolidColorBrush x:Key="ThemeSelectedBg"       Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="ThemePressedBg"        Color="#FF1A1A1A"/>
        <SolidColorBrush x:Key="ThemeError"            Color="#FFFF5000"/>
        <SolidColorBrush x:Key="ThemeWarning"          Color="#FFF59E0B"/>
        <SolidColorBrush x:Key="ThemeSuccess"          Color="#FF00C853"/>
        <SolidColorBrush x:Key="ThemeBorder"           Color="#19FFFFFF"/>
        <SolidColorBrush x:Key="ThemeBorderCard"       Color="#19FFFFFF"/>
        <SolidColorBrush x:Key="ThemeBorderElevated"   Color="#FF333333"/>
        <SolidColorBrush x:Key="ThemeScrollTrack"      Color="#08FFFFFF"/>
        <SolidColorBrush x:Key="ThemeScrollThumb"      Color="#40FFFFFF"/>
        <SolidColorBrush x:Key="ThemeOutputBg"         Color="#FF0F0F11"/>
        <SolidColorBrush x:Key="ThemeBorderSubtle"     Color="#19FFFFFF"/>

        <!-- Additional theme brushes (parity with WinGetManifestManager) -->
        <SolidColorBrush x:Key="ThemeCardAltBg"        Color="#F01A1A1A"/>
        <SolidColorBrush x:Key="ThemeSurfaceBg"        Color="#FF1F1F23"/>
        <SolidColorBrush x:Key="ThemeTextDisabled"     Color="#FF505058"/>
        <SolidColorBrush x:Key="ThemeTextFaintest"     Color="#FF9A9AA2"/>
        <SolidColorBrush x:Key="ThemeAccentDim"        Color="#1A0078D4"/>
        <SolidColorBrush x:Key="ThemeErrorDim"         Color="#20FF5000"/>
        <SolidColorBrush x:Key="ThemeBorderHover"      Color="#FF444444"/>
        <SolidColorBrush x:Key="ThemeSidebarBg"        Color="#FF111113"/>
        <SolidColorBrush x:Key="ThemeSidebarBorder"    Color="#00000000"/>
        <SolidColorBrush x:Key="ThemeProgressEdge"     Color="#18FFFFFF"/>

        <!-- Severity colors -->
        <SolidColorBrush x:Key="SeverityConflict"      Color="#FFFF5000"/>
        <SolidColorBrush x:Key="SeverityRedundant"     Color="#FFF59E0B"/>
        <SolidColorBrush x:Key="SeverityInfo"          Color="#FF60CDFF"/>

        <!-- Filter indicator colors (semantic, shared across themes) -->
        <SolidColorBrush x:Key="FilterGreen"            Color="#FF6BCB77"/>
        <SolidColorBrush x:Key="FilterRed"              Color="#FFFF6B6B"/>
        <SolidColorBrush x:Key="FilterYellow"           Color="#FFFFD93D"/>
        <SolidColorBrush x:Key="FilterCyan"             Color="#FF4FC3F7"/>
        <SolidColorBrush x:Key="FilterPurple"           Color="#FFBA68C8"/>
        <SolidColorBrush x:Key="FilterOrange"           Color="#FFFFB74D"/>
        <SolidColorBrush x:Key="FilterBlue"             Color="#FF90CAF9"/>
        <SolidColorBrush x:Key="FilterLightGreen"       Color="#FFA5D6A7"/>
        <SolidColorBrush x:Key="FilterLightPurple"      Color="#FFCE93D8"/>
        <SolidColorBrush x:Key="FilterBadgeBg"          Color="#FF2C2C30"/>
        <SolidColorBrush x:Key="FilterBadgeText"        Color="#FFB0B0B8"/>
        <SolidColorBrush x:Key="AdminBannerBg"          Color="#30F59E0B"/>
        <SolidColorBrush x:Key="CategoryBadgeBg"        Color="#409333EA"/>

        <!-- Effects -->
        <DropShadowEffect x:Key="AccentGlow"  Color="#0078D4" BlurRadius="16" ShadowDepth="0" Opacity="0.35"/>
        <DropShadowEffect x:Key="CardShadow"  Color="Black"   BlurRadius="8"  ShadowDepth="2" Opacity="0.2"/>
        <DropShadowEffect x:Key="PopupShadow" Color="Black"   BlurRadius="16" ShadowDepth="4" Opacity="0.4"/>

        <!-- DOT GRID PATTERN (tiled, pure XAML) -->
        <DrawingBrush x:Key="DotGridBrush" TileMode="Tile" Viewport="0,0,44,44" ViewportUnits="Absolute"
                      Viewbox="0,0,44,44" ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <SolidColorBrush Color="#1EFFFFFF"/>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="22,22" RadiusX="1.3" RadiusY="1.3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Title bar button -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeSurfaceBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Title bar close button (red hover) -->
        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#B90D1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button (small square) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SCROLLVIEWER: hide the corner rectangle when both scrollbars are visible -->
        <Style TargetType="{x:Type ScrollViewer}">
            <Style.Resources>
                <Style TargetType="Rectangle">
                    <Setter Property="Fill" Value="Transparent"/>
                </Style>
            </Style.Resources>
        </Style>

        <!-- SCROLLBAR (Minimal 8px, rounded thumb, themed) — applies globally -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Background="{DynamicResource ThemeScrollTrack}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder"
                                                        Background="{DynamicResource ThemeScrollThumb}"
                                                        CornerRadius="4" MinHeight="30" Margin="1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background"
                                                                Value="{DynamicResource ThemeAccentLight}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background"
                                                                Value="{DynamicResource ThemeTextPrimary}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="GridRoot" Property="Height" Value="8"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="8"/>
                                <Setter Property="MinHeight" Value="8"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button hover template -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBd" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="NavBd" Property="Background" Value="{DynamicResource ThemeSelectedBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="AccBd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#005A9E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#0078D4" Direction="270" ShadowDepth="0" BlurRadius="10" Opacity="0.25"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AccBd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A8AD4" Offset="0"/>
                                            <GradientStop Color="#0067C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="AccBd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#0078D4" Direction="270" ShadowDepth="0" BlurRadius="16" Opacity="0.40"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="AccBd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="GhBd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GhBd" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter pill style -->
        <Style x:Key="FilterPill" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextMuted}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PillBd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PillBd" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="PillBd" Property="Background" Value="{DynamicResource ThemeAccent}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="PillBd" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource ThemeAccent}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="TbBd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    CornerRadius="6">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <Border x:Name="FocusBar" Height="2" VerticalAlignment="Bottom"
                                    CornerRadius="0,0,6,6" Margin="2,0,2,0"
                                    Background="Transparent"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="TbBd" Property="BorderBrush"
                                        Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="FocusBar" Property="Background"
                                        Value="{DynamicResource ThemeAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Switch (CheckBox) -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="40" Height="20">
                                <Border x:Name="Track" Background="{DynamicResource ThemeBorderElevated}"
                                        CornerRadius="10"/>
                                <Canvas Width="40" Height="20" ClipToBounds="True">
                                    <Border x:Name="Knob" Width="16" Height="16" CornerRadius="8"
                                            Background="White" Canvas.Top="2" Canvas.Left="2">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="KnobTranslate" X="0"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Canvas>
                            </Grid>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"
                                        Value="{DynamicResource ThemeAccent}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark ComboBoxItem -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="CiBd" Background="Transparent"
                                Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="CiCheck" Grid.Column="1" Text="&#xE73E;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource ThemeAccent}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="CiBd" Property="Background"
                                        Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CiBd" Property="Background"
                                        Value="{DynamicResource ThemeSelectedBg}"/>
                                <Setter TargetName="CiCheck" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox ToggleButton -->
        <ControlTemplate x:Key="CbToggleBtn" TargetType="ToggleButton">
            <Border x:Name="CbRoot" Background="{DynamicResource ThemeInputBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" CornerRadius="6"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="28"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1">
                        <Path x:Name="CbArrow" Data="M0,0 L4,4 8,0"
                              Stroke="{DynamicResource ThemeTextMuted}" StrokeThickness="1.5"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="CbRoot" Property="BorderBrush"
                            Value="{DynamicResource ThemeAccent}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="CbRoot" Property="BorderBrush"
                            Value="{DynamicResource ThemeAccent}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Dark ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource CbToggleBtn}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="12,0,30,0" IsHitTestVisible="False"/>
                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{DynamicResource ThemePanelBg}"
                                        BorderBrush="{DynamicResource ThemeBorderElevated}" BorderThickness="1"
                                        CornerRadius="6" Margin="0,4,0,0" Padding="4"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="320">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4" Opacity="0.4"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Group Expander (sleek chevron, no default circle toggle) -->
        <Style x:Key="GroupExpander" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="{DynamicResource ThemeDeepBg}" CornerRadius="6" Padding="2,0"
                                    Cursor="Hand">
                                <ToggleButton x:Name="HeaderToggle" IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Focusable="False" OverridesDefaultStyle="True">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" Padding="4,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="Chevron" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                                               Foreground="{DynamicResource ThemeTextMuted}"/>
                                                    <ContentPresenter Content="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" RecognizesAccessKey="True"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter TargetName="Chevron" Property="Text" Value="&#xE76C;"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Border>
                            <ContentPresenter x:Name="ExpandSite" DockPanel.Dock="Bottom"
                                              Visibility="Visible"
                                              Focusable="False"/>
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid styles -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#08FFFFFF"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DarkColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ThemeDeepBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" VerticalAlignment="Center"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                    <Path x:Name="SortArrow" Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0"
                                          Fill="{DynamicResource ThemeTextMuted}" Visibility="Collapsed"
                                          RenderTransformOrigin="0.5,0.5"/>
                                </Grid>
                            </Border>
                            <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left" Width="6" Cursor="SizeWE">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent" Width="6">
                                            <Rectangle x:Name="grip" Width="1" HorizontalAlignment="Center" Fill="Transparent"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="grip" Property="Fill" Value="{DynamicResource ThemeAccent}"/>
                                                <Setter TargetName="grip" Property="Width" Value="2"/>
                                            </Trigger>
                                            <Trigger Property="IsDragging" Value="True">
                                                <Setter TargetName="grip" Property="Fill" Value="{DynamicResource ThemeAccent}"/>
                                                <Setter TargetName="grip" Property="Width" Value="2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                            <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right" Width="6" Cursor="SizeWE">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent" Width="6">
                                            <Rectangle x:Name="grip" Width="1" HorizontalAlignment="Center" Fill="{DynamicResource ThemeBorder}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="grip" Property="Fill" Value="{DynamicResource ThemeAccent}"/>
                                                <Setter TargetName="grip" Property="Width" Value="2"/>
                                            </Trigger>
                                            <Trigger Property="IsDragging" Value="True">
                                                <Setter TargetName="grip" Property="Fill" Value="{DynamicResource ThemeAccent}"/>
                                                <Setter TargetName="grip" Property="Width" Value="2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data" Value="M 0 4 L 3.5 0 L 7 4 Z"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data" Value="M 0 0 L 3.5 4 L 7 0 Z"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeSelectedBg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeSelectedBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- ===== MAIN LAYOUT ===== -->
    <Border x:Name="WindowBorder" CornerRadius="8" BorderBrush="{DynamicResource ThemeBorderElevated}" BorderThickness="1" Background="{DynamicResource ThemeAppBg}" Opacity="0">
        <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="200" MinHeight="80"/>
                    <RowDefinition Height="22"/>
                </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="{DynamicResource ThemeDeepBg}" CornerRadius="8,8,0,0">
                <DockPanel Margin="14,0">
                    <!-- App icon + title -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TitleText" Text="PolicyPilot" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center"/>
                        <Border Background="{DynamicResource ThemeAccent}" CornerRadius="3" Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="VersionBadge" Text="v0.1.0" FontSize="9.5" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <Border CornerRadius="4" Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center"
                                BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                            <TextBlock Text="EXPERIMENTAL" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                        </Border>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnHelp" Style="{StaticResource TitleBarButton}" Content="?" FontSize="13" FontFamily="Segoe UI" FontWeight="Bold" ToolTip="Help &amp; Keyboard Shortcuts" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="BtnThemeToggle" Style="{StaticResource TitleBarButton}" Content="&#x2600;" FontSize="13" FontFamily="Segoe UI" ToolTip="Toggle Light/Dark Mode" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="BtnMinimize" Style="{StaticResource TitleBarButton}" Content="&#xE921;" ToolTip="Minimize window"/>
                        <Button x:Name="BtnMaximize" Style="{StaticResource TitleBarButton}" ToolTip="Maximize / Restore window">
                            <TextBlock x:Name="MaximizeIcon" Text="&#xE922;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                        <Button x:Name="BtnClose" Style="{StaticResource TitleBarCloseButton}" Content="&#xE8BB;" ToolTip="Close PolicyPilot"/>
                    </StackPanel>

                    <!-- Domain + status -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="DomainBadge" Text="" FontSize="10.5" Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" ToolTip="Connected domain or tenant — shows current AD domain or Intune tenant"/>
                        <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="{DynamicResource ThemeTextMuted}" Margin="10,0,4,0" VerticalAlignment="Center" ToolTip="Green = scan complete, Yellow = scanning, Red = error, Gray = idle"/>
                        <TextBlock x:Name="StatusText" Text="Ready" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" ToolTip="Current operation status"/>
                    </StackPanel>
                </DockPanel>
            </Border>

                <!-- ROW 1: GLOBAL PROGRESS BAR -->
                <Grid x:Name="pnlGlobalProgress" Grid.Row="1" Visibility="Collapsed" ClipToBounds="True">
                    <!-- Background track -->
                    <Border Height="22" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="0"/>
                    <!-- Indeterminate shimmer (animated gradient band) -->
                    <Border x:Name="brdGlobalShimmer" Height="22" CornerRadius="0">
                        <Border.Background>
                            <LinearGradientBrush x:Name="shimmerBrush" StartPoint="0,0" EndPoint="1,0"
                                                 MappingMode="RelativeToBoundingBox" SpreadMethod="Pad">
                                <GradientStop Color="Transparent"  Offset="0.0"/>
                                <GradientStop Color="#0078D4"      Offset="0.15"/>
                                <GradientStop Color="#60CDFF"      Offset="0.35"/>
                                <GradientStop Color="#0078D4"      Offset="0.55"/>
                                <GradientStop Color="Transparent"  Offset="0.7"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="shimmerTranslate" X="-400"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="shimmerTranslate" Storyboard.TargetProperty="X"
                                                         From="-500" To="1200" Duration="0:0:2.0" AutoReverse="False"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <!-- Subtle top/bottom edge lines for depth -->
                    <Border Height="22" BorderThickness="0,1,0,1"
                            BorderBrush="{DynamicResource ThemeProgressEdge}" IsHitTestVisible="False"/>
                    <!-- Centered label overlay -->
                    <TextBlock x:Name="lblGlobalProgress" Text="" FontSize="11" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="Black" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>


            <!-- ===== BODY: NAV + SIDEBAR + CONTENT ===== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition x:Name="SidebarColumn" Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT NAV RAIL ===== -->
                <Border Grid.Column="0" Background="{DynamicResource ThemeDeepBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                    <DockPanel Margin="6,8" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Top">
                        <Button x:Name="BtnHamburger" Style="{StaticResource NavButton}" Padding="0,10" HorizontalContentAlignment="Center"
                                ToolTip="Toggle sidebar (Ctrl+B)">
                            <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="4,6"/>
                        <Button x:Name="NavDashboard" AutomationProperties.Name="Dashboard" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="Dashboard — Overview &amp; stats (Ctrl+1)">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button x:Name="NavGPOList" AutomationProperties.Name="GPO List" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="GPO List — All Group Policy Objects (Ctrl+2)">
                            <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button x:Name="NavSettings" AutomationProperties.Name="Settings" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="All Settings — Flat setting view (Ctrl+3)">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button x:Name="NavConflicts" AutomationProperties.Name="Conflicts" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="Conflicts — Duplicate &amp; conflicting settings (Ctrl+4)">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button x:Name="NavIntuneApps" AutomationProperties.Name="Intune Apps" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="Intune Apps — Managed app installations (Ctrl+5)">
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button x:Name="NavReport" AutomationProperties.Name="Report" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="Report — Generate documentation (Ctrl+6)">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button x:Name="NavIMELogs" AutomationProperties.Name="IME Logs" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="IME Logs — Live Intune Management Extension log viewer (Ctrl+7)">
                            <TextBlock Text="&#xE7C4;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button x:Name="NavGPOLogs" AutomationProperties.Name="GPO Logs" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="GPO Logs — Live Group Policy log viewer (Ctrl+8)">
                            <TextBlock Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button x:Name="NavMDMSync" AutomationProperties.Name="MDM Sync" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="MDM Sync — OMA-DM / SyncML diagnostic event viewer (Ctrl+9)">
                            <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <Button x:Name="NavTools" AutomationProperties.Name="Tools" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="Tools — Registry links, decoders, status codes (Ctrl+0)">
                            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                        </Button>
                        <!-- Spacer -->
                        <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="4,10"/>
                        <Button x:Name="NavAppSettings" AutomationProperties.Name="App Settings" Style="{StaticResource NavButton}" Padding="0,12" HorizontalContentAlignment="Center"
                                ToolTip="App Settings — Theme, domain overrides, prerequisites, security baselines (Ctrl+,)">
                            <TextBlock Text="&#xE115;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ===== LEFT SIDEBAR ===== -->
                <Border x:Name="SidebarBorder" Grid.Column="1" Background="{DynamicResource ThemePanelBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!-- Sidebar: Dashboard -->
                            <StackPanel x:Name="SidebarDashboard" Visibility="Visible" Margin="16,16">
                                <TextBlock Text="DASHBOARD" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                <TextBlock Text="Run a policy scan, review MDM enrollment data, and monitor device compliance at a glance" FontSize="9" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Scan mode selector -->
                                <TextBlock Text="SCAN MODE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbScanMode" Style="{StaticResource DarkComboBox}" ToolTip="Choose what to scan — Local (LGPO), Active Directory (domain GPOs), Intune/MDM (enrolled device policies), or All" Margin="0,0,0,4" SelectedIndex="0"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Intune / Endpoint Manager" Tag="Intune"/>
                                    <ComboBoxItem Content="Local Machine (gpresult)" Tag="Local"/>
                                    <ComboBoxItem Content="Active Directory (RSAT)" Tag="AD"/>
                                    <ComboBoxItem Content="Combined (Co-managed)" Tag="Combined"/>
                                </ComboBox>
                                <TextBlock Text="Local reads gpresult, AD queries domain GPOs via RSAT, Intune reads MDM registry" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <!-- Scan button -->
                                <Button x:Name="BtnScanGPOs" Style="{StaticResource AccentButton}" HorizontalAlignment="Stretch" Margin="0,0,0,16"
                                        ToolTip="Scan Intune/MDM policies from local registry">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE149;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="BtnScanText" Text="Scan Intune Policies" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <!-- Progress -->
                                <StackPanel x:Name="ScanProgressPanel" Visibility="Collapsed" Margin="0,0,0,14">
                                    <ProgressBar x:Name="ScanProgressBar" Height="4" Minimum="0" Maximum="100" Value="0"
                                                 Foreground="{DynamicResource ThemeAccent}" Background="{DynamicResource ThemeInputBg}"/>
                                    <TextBlock x:Name="ScanProgressText" Text="Scanning..." FontSize="10.5"
                                               Foreground="{DynamicResource ThemeTextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Scan summary -->
                                <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="LAST SCAN" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="DashLastScanTime" Text="No scan performed" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                        <TextBlock x:Name="DashDomainName" Text="" FontSize="10.5" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- MDM Enrollment -->
                                <Border x:Name="MdmEnrollmentCard" Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="MDM ENROLLMENT" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="MdmProviderText" Text="" FontSize="11" Foreground="{DynamicResource ThemeAccent}"/>
                                        <TextBlock x:Name="MdmUPNText" Text="" FontSize="10.5" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,2,0,0"/>
                                        <TextBlock x:Name="MdmEnrollTypeText" Text="" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                                        <TextBlock x:Name="MdmStateText" Text="" FontSize="10" Foreground="{DynamicResource ThemeSuccess}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- LAPS Status -->
                                <Border x:Name="LapsStatusCard" Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="LAPS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Backup" FontSize="10.5" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            <TextBlock x:Name="LapsBackupText" Grid.Column="1" Text="" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource ThemeAccent}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Password Age" FontSize="10.5" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            <TextBlock x:Name="LapsPasswordAgeText" Grid.Column="1" Text="" FontSize="10.5" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Complexity" FontSize="10.5" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            <TextBlock x:Name="LapsComplexityText" Grid.Column="1" Text="" FontSize="10.5" Foreground="{DynamicResource ThemeTextPrimary}" TextWrapping="Wrap" MaxWidth="140" TextAlignment="Right"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Post-auth" FontSize="10.5" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            <TextBlock x:Name="LapsPostAuthText" Grid.Column="1" Text="" FontSize="10.5" Foreground="{DynamicResource ThemeTextPrimary}" TextWrapping="Wrap" MaxWidth="140" TextAlignment="Right"/>
                                        </Grid>
                                        <TextBlock x:Name="LapsLastRotationText" Text="" FontSize="9.5" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Certificate Inventory -->
                                <Border x:Name="CertInventoryCard" Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="CERTIFICATES" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Managed certs" FontSize="10.5" Foreground="{DynamicResource ThemeTextSecondary}"/>
