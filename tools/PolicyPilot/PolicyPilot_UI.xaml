                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Active GPOs" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
