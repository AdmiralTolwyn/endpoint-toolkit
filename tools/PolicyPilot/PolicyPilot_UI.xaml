                                         ToolTip="Search log text" VerticalContentAlignment="Center"/>
                                <TextBlock x:Name="GpoSearchCount" Grid.Column="2" Text="" FontSize="9.5"
                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center" Margin="6,0"/>
                                <Button x:Name="BtnGpoSearchPrev" Grid.Column="3" Style="{StaticResource IconButton}" Width="22" Height="22"
                                        ToolTip="Previous match">
                                    <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                                <Button x:Name="BtnGpoSearchNext" Grid.Column="4" Style="{StaticResource IconButton}" Width="22" Height="22"
                                        ToolTip="Next match">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                                <Button x:Name="BtnGpoWrapToggle" Grid.Column="5" Style="{StaticResource IconButton}" Width="22" Height="22"
                                        ToolTip="Toggle word wrap" Margin="2,0,0,0">
                                    <TextBlock Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                                <Button x:Name="BtnGpoClearLog" Grid.Column="6" Style="{StaticResource IconButton}" Width="22" Height="22"
                                        ToolTip="Clear log display" Margin="4,0,0,0">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Log output ListBox (virtualized) -->
                        <Border Grid.Row="3" Margin="24,6,24,20" CornerRadius="8"
                                Background="{DynamicResource ThemeOutputBg}" BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                </Grid.ColumnDefinitions>
                                <ListBox x:Name="lbGpoLogs"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True"
                                         Background="Transparent" BorderThickness="0"
                                         FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="12"
                                         Foreground="{DynamicResource ThemeTextMuted}"
                                         SelectionMode="Single" Padding="14,10"
                                         HorizontalContentAlignment="Stretch"/>
                                <!-- Minimap gutter -->
                                <Canvas x:Name="cnvGpoMinimap" Grid.Column="1" Background="{DynamicResource ThemeDeepBg}"
                                        ToolTip="Click to jump" Cursor="Hand" ClipToBounds="True"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== PANEL: MDM SYNC ===== -->
                    <Grid x:Name="PanelMDMSync" Visibility="Collapsed" Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Margin="24,20,24,0">
                            <TextBlock Text="MDM Sync Viewer" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="MdmLogSubtitle" Text="OMA-DM / SyncML &#x2014; MDM diagnostic event viewer showing sync activity, CSP operations, and policy delivery results. Toggle live tail in the sidebar."
                                       FontSize="12.5" Foreground="{DynamicResource ThemeTextSecondary}"/>
                        </StackPanel>

                        <!-- Heatmap bar (hidden until data) -->
                        <Canvas x:Name="cnvMdmHeatmap" Grid.Row="1" Height="14" Margin="24,10,24,0" Visibility="Collapsed"
                                Background="{DynamicResource ThemeDeepBg}" ToolTip="Error/warning distribution" ClipToBounds="True"/>

                        <!-- Search bar -->
                        <Border Grid.Row="2" Background="{DynamicResource ThemeDeepBg}" Margin="24,6,24,0" CornerRadius="6" Padding="8,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center" Margin="4,0,6,0"/>
                                <TextBox x:Name="TxtMdmSearch" Grid.Column="1" Style="{StaticResource DarkTextBox}"
                                         Height="24" FontSize="11" Background="Transparent" BorderThickness="0"
                                         ToolTip="Search MDM events (Ctrl+F)" VerticalContentAlignment="Center"/>
                                <TextBlock x:Name="MdmSearchCount" Grid.Column="2" Text="" FontSize="9.5"
                                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center" Margin="6,0"/>
                                <Button x:Name="BtnMdmSearchPrev" Grid.Column="3" Style="{StaticResource IconButton}" Width="22" Height="22"
                                        ToolTip="Previous match">
                                    <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                                <Button x:Name="BtnMdmSearchNext" Grid.Column="4" Style="{StaticResource IconButton}" Width="22" Height="22"
                                        ToolTip="Next match">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                                <Button x:Name="BtnMdmWrapToggle" Grid.Column="5" Style="{StaticResource IconButton}" Width="22" Height="22"
                                        ToolTip="Toggle word wrap" Margin="2,0,0,0">
                                    <TextBlock Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                                <Button x:Name="BtnMdmClearLog" Grid.Column="6" Style="{StaticResource IconButton}" Width="22" Height="22"
                                        ToolTip="Clear log display" Margin="4,0,0,0">
