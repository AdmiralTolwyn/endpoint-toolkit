                            <TextBlock Text="Report Preview" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                            <TextBlock Text="Preview and export scan results. Generate HTML documentation with full policy detail, or export CSV/JSON for analysis in Excel or automation scripts." FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0"/>
