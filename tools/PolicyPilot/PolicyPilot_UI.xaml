                                <TextBlock x:Name="ReportPreviewText" FontFamily="Cascadia Mono,Consolas,Courier New" Text="Run a scan and click 'Export HTML Report' to generate documentation."
                                           FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap"
                                           Padding="24,20" LineHeight="22"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- ===== PANEL: IME LOGS ===== -->
