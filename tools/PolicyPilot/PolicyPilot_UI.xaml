                    <!-- ===== PANEL: APP SETTINGS ===== -->

                    <!-- ===== PANEL: TOOLS ===== -->
                    <Grid x:Name="PanelTools" Visibility="Collapsed" Margin="24,20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel MaxWidth="700">
                            <TextBlock Text="Tools" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,6"/>
                            <TextBlock Text="Quick access to registry locations, decoders, and diagnostic utilities." FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,20"/>

                            <!-- Registry Quick-Links -->
                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="REGISTRY QUICK-LINKS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Jump directly to critical MDM/Intune registry hives in regedit. Essential for verifying that policies from Intune actually landed on the device, checking enrollment state, and diagnosing why a configuration profile may not be applying." FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <WrapPanel>
                                        <Button x:Name="BtnRegPolicyManager2" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Padding="12,8" ToolTip="HKLM\SOFTWARE\Microsoft\PolicyManager&#x0a;&#x0a;The central MDM policy store where Intune writes all device configuration policies. Each sub-key maps to a CSP area (e.g., WiFi, BitLocker, Defender). Check here to verify whether a policy actually arrived on the device after sync."><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="PolicyManager" VerticalAlignment="Center"/></StackPanel></Button>
                                        <Button x:Name="BtnRegEnrollments2" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Padding="12,8" ToolTip="HKLM\SOFTWARE\Microsoft\Enrollments&#x0a;&#x0a;MDM enrollment records keyed by enrollment GUID. Contains the UPN, provider ID (e.g., MS DM Server), enrollment type (Device/User), and SyncML endpoint URLs. Essential for diagnosing enrollment failures or verifying which MDM authority owns the device."><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Enrollments" VerticalAlignment="Center"/></StackPanel></Button>
                                        <Button x:Name="BtnRegProvisioning2" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Padding="12,8" ToolTip="HKLM\SOFTWARE\Microsoft\Provisioning&#x0a;&#x0a;Provisioning package metadata and the NodeCache — the local mirror of all CSP settings the MDM server has sent. Also stores SyncML transaction logs and reboot-required URI lists. Key location for verifying expected vs. actual policy values."><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Provisioning" VerticalAlignment="Center"/></StackPanel></Button>
                                        <Button x:Name="BtnRegIME2" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Padding="12,8" ToolTip="HKLM\SOFTWARE\Microsoft\IntuneManagementExtension&#x0a;&#x0a;The Intune Management Extension (sidecar agent) stores Win32 app install results, PowerShell script execution status, remediation outcomes, and detection results here. Check sub-keys like Win32Apps and Policies to debug app deployment failures."><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="IME" VerticalAlignment="Center"/></StackPanel></Button>
                                        <Button x:Name="BtnRegDeclaredConfig2" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Padding="12,8" ToolTip="HKLM\SOFTWARE\Microsoft\DeclaredConfiguration&#x0a;&#x0a;The new Declared Configuration (WinDC) pipeline — Intune's next-gen policy delivery that replaces traditional SyncML for supported scenarios. Stores desired-state documents, compliance drift detection results, and refresh timestamps. Relatively new; not all policies use this path yet."><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="DeclaredConfig" VerticalAlignment="Center"/></StackPanel></Button>
                                        <Button x:Name="BtnRegDesktopAppMgmt2" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Padding="12,8" ToolTip="HKLM\SOFTWARE\Microsoft\EnterpriseDesktopAppManagement&#x0a;&#x0a;Win32 app lifecycle tracking — install status, detection results, enforcement state, and retry counts for each app ID. Sub-keys are organized by enrollment GUID and app GUID. The go-to location when an app shows 'Failed' in Company Portal but you need the actual error code."><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Desktop App Mgmt" VerticalAlignment="Center"/></StackPanel></Button>
                                        <Button x:Name="BtnRegRebootURIs2" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Padding="12,8" ToolTip="HKLM\SOFTWARE\Microsoft\Provisioning\SyncML\RebootRequiredURIs&#x0a;&#x0a;Lists OMA-URI paths whose last CSP operation requires a device reboot to take effect. If a policy change seems to have no effect, check here — the device may be waiting for a reboot that the user keeps deferring. Common for BitLocker, Defender, and kernel-level settings."><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Reboot URIs" VerticalAlignment="Center"/></StackPanel></Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Status Code Lookup -->
                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="STATUS CODE LOOKUP" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Translate cryptic MDM status codes, SyncML result codes (200, 400, 500-series), and Win32 HRESULT error codes into human-readable explanations. Saves time when reading MDM diagnostic logs or the Event Viewer." FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtStatusCode2" Style="{StaticResource DarkTextBox}" Height="32" ToolTip="Enter numeric code (e.g., 200, 404, -2147024891)"/>
                                        <Button x:Name="BtnLookupStatus2" Grid.Column="1" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Padding="16,6" ToolTip="Look up the status/error code and show its meaning"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Lookup" VerticalAlignment="Center" FontWeight="SemiBold"/></StackPanel></Button>
                                    </Grid>
                                    <TextBlock x:Name="StatusCodeResult2" Text="" FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Base64 Decoder -->
                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="BASE64 DECODER" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Decode Base64-encoded payloads commonly found in MDM logs, Intune policy bodies, and certificate data. The output is automatically checked for JSON and pretty-printed if detected, making it easy to inspect policy values or diagnostic blobs." FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <TextBox x:Name="TxtBase64Input2" Style="{StaticResource DarkTextBox}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" ToolTip="Paste Base64-encoded content here"/>
                                    <Button x:Name="BtnDecodeBase642" Style="{StaticResource AccentButton}" HorizontalAlignment="Left" Margin="0,8,0,0" Padding="16,6" ToolTip="Decode Base64 text and auto-detect JSON for pretty-printing"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Decode" VerticalAlignment="Center" FontWeight="SemiBold"/></StackPanel></Button>
                                    <TextBox x:Name="Base64Result2" Style="{StaticResource DarkTextBox}" Height="120" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Cascadia Code,Consolas,monospace" FontSize="11" Margin="0,8,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- SyncML ETW Trace -->
                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="SYNCML ETW TRACE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Capture real-time OMA-DM / SyncML protocol messages using ETW tracing. Start a trace, trigger a device sync (Settings &gt; Accounts &gt; Access work or school &gt; Info &gt; Sync), then stop to see the raw SyncML XML exchanged between the device and Intune. Invaluable for diagnosing policy delivery failures, sync errors, and CSP-level rejections. Requires elevation." FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button x:Name="BtnEtwStart2" Style="{StaticResource AccentButton}" Padding="16,6" Margin="0,0,8,0" ToolTip="Start ETW trace session for OMA-DM provider"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Start Trace" VerticalAlignment="Center" FontWeight="SemiBold"/></StackPanel></Button>
                                        <Button x:Name="BtnEtwStop2" Style="{StaticResource GhostButton}" Padding="16,6" Margin="0,0,8,0" IsEnabled="False" ToolTip="Stop trace and parse SyncML events"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Stop &amp; Analyze" VerticalAlignment="Center"/></StackPanel></Button>
                                        <Button x:Name="BtnEtwClear2" Content="Clear" Style="{StaticResource GhostButton}" Padding="12,6" ToolTip="Clear trace output"/>
                                    </StackPanel>
                                    <TextBlock x:Name="EtwTraceStatus2" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource ThemeDeepBg}" CornerRadius="6" Padding="8" Margin="0,4,0,0">
                                        <ScrollViewer x:Name="EtwResultScroller" VerticalScrollBarVisibility="Auto" MaxHeight="500">
                                            <TextBox x:Name="EtwResultBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                                     FontFamily="Cascadia Code,Consolas,monospace" FontSize="11"
                                                     BorderThickness="0" Background="Transparent"
                                                     Foreground="{DynamicResource ThemeTextSecondary}"/>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Autopilot Hash Decoder -->
                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="AUTOPILOT HARDWARE HASH DECODER" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Decode the 4KB Autopilot hardware hash (from Get-WindowsAutopilotInfo or CSV export) into its TLV (Type-Length-Value) components: SMBIOS serial number, UUID, MAC address, disk serial, TPM version, and firmware details. Useful for verifying device identity before or after Autopilot registration, or diagnosing hash-mismatch enrollment failures." FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <TextBox x:Name="TxtAutopilotHash2" Style="{StaticResource DarkTextBox}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" ToolTip="Paste the full Autopilot hardware hash"/>
                                    <Button x:Name="BtnDecodeAutopilot2" Style="{StaticResource AccentButton}" HorizontalAlignment="Left" Margin="0,8,0,0" Padding="16,6" ToolTip="Parse the TLV structure to extract SMBIOS, MAC, TPM info"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Decode Hash" VerticalAlignment="Center" FontWeight="SemiBold"/></StackPanel></Button>
                                    <TextBox x:Name="AutopilotResult2" Style="{StaticResource DarkTextBox}" Height="150" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Cascadia Code,Consolas,monospace" FontSize="11" Margin="0,8,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- WiFi / VPN Profile Viewer -->
                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="NETWORK PROFILES" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Enumerate WiFi profiles stored on this device (via netsh) and VPN connections (via Get-VpnConnection). Shows SSIDs, authentication types, and connection modes. Helpful for verifying that Intune-pushed WiFi/VPN profiles deployed correctly, or for capturing profile details before a device wipe." FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button x:Name="BtnLoadWifi2" Style="{StaticResource AccentButton}" Padding="16,6" Margin="0,0,8,0" ToolTip="List all saved WiFi profiles via netsh wlan show profiles"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE701;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="WiFi Profiles" VerticalAlignment="Center" FontWeight="SemiBold"/></StackPanel></Button>
                                        <Button x:Name="BtnLoadVpn2" Style="{StaticResource GhostButton}" Padding="16,6" ToolTip="List VPN connections configured via Get-VpnConnection"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE839;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="VPN Connections" VerticalAlignment="Center"/></StackPanel></Button>
                                    </StackPanel>
                                    <TextBox x:Name="NetworkProfileResult" Style="{StaticResource DarkTextBox}" Height="200" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Cascadia Code,Consolas,monospace" FontSize="11" Margin="0,4,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- Node Cache Explorer -->
                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="MDM NODE CACHE EXPLORER" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Browse the MDM Node Cache at HKLM\SOFTWARE\Microsoft\Provisioning\NodeCache — the local registry mirror of all CSP (Configuration Service Provider) settings the MDM server has pushed. Shows expected vs. actual values, OMA-URI paths, and sync timestamps. Critical for verifying that a policy's intended value actually persisted on the device after sync." FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <Button x:Name="BtnLoadNodeCache2" Style="{StaticResource AccentButton}" HorizontalAlignment="Left" Padding="16,6" ToolTip="Read HKLM\SOFTWARE\Microsoft\Provisioning\NodeCache registry entries"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Load Node Cache" VerticalAlignment="Center" FontWeight="SemiBold"/></StackPanel></Button>
                                    <TextBlock x:Name="NodeCacheStatus2" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,8,0,0"/>
                                    <Border Background="{DynamicResource ThemeDeepBg}" CornerRadius="6" Padding="8" Margin="0,4,0,0">
                                        <ScrollViewer x:Name="NodeCacheScroller" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                                            <TextBox x:Name="NodeCacheResultBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                                     FontFamily="Cascadia Code,Consolas,monospace" FontSize="11"
                                                     BorderThickness="0" Background="Transparent"
                                                     Foreground="{DynamicResource ThemeTextSecondary}"/>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Background Log Export -->
                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="BACKGROUND LOG EXPORT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Start a background log stream that captures every PolicyPilot action, scan result, and error to a timestamped file on your Desktop. Toggle on before reproducing an issue, then toggle off and share the log file with support. All Write-DebugLog output is mirrored to the file in real time." FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <Button x:Name="BtnBgLogToggle2" Style="{StaticResource AccentButton}" HorizontalAlignment="Left" Padding="16,6" ToolTip="Stream all debug log output to a timestamped file on Desktop"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Enable Background Logging" VerticalAlignment="Center" FontWeight="SemiBold"/></StackPanel></Button>
                                    <TextBlock x:Name="BgLogStatus2" Text="" FontSize="11" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        </ScrollViewer>
                    </Grid>
                    <Grid x:Name="PanelAppSettings" Visibility="Collapsed" Margin="24,20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel MaxWidth="600">
                            <TextBlock Text="App Settings" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,20"/>
                            <TextBlock Text="Configure application preferences. Settings are saved automatically." FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,20"/>

                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="PREREQUISITES STATUS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Verifies that RSAT, the GroupPolicy PowerShell module, administrator privileges, and Active Directory domain connectivity are available. Some scan modes require these components." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="PrereqDetailStatus" Text="Checking..." FontSize="12" Foreground="{DynamicResource ThemeTextBody}" TextWrapping="Wrap"/>
                                    <Button x:Name="BtnRecheckPrereqs" Content="Re-check Prerequisites" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,12,0,0" ToolTip="Re-scan for RSAT, GroupPolicy module, admin privileges, and domain connectivity"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="SECURITY BASELINE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Import a known-good configuration as a baseline, then compare future scans against it to detect drift. Export your current scan as a new baseline template." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="BaselineStatus" Text="No baseline loaded" FontSize="11.5" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,0,0,10" AutomationProperties.Name="Baseline compliance status"/>
                                    <Button x:Name="BtnImportBaseline" Content="Import Baseline" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" ToolTip="Import a JSON baseline file for compliance comparison" AutomationProperties.Name="Import security baseline"/>
                                    <Button x:Name="BtnExportBaseline" Content="Export as Baseline" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" ToolTip="Export current scan settings as a baseline template" AutomationProperties.Name="Export current settings as baseline"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="20" Margin="0,0,0,12"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ABOUT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,12"/>
                                    <TextBlock x:Name="AboutText" Text="PolicyPilot v0.1.0&#x0a;Endpoint policy audit and configuration workbench — scans GPO, Intune/MDM, and CSP policies, generates documentation, and detects conflicts."
                                               FontSize="12" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" LineHeight="20"/>
                                    <TextBlock Text="&#x0a;Built for Intune admins, endpoint engineers, and security teams. Reads local registry, MDMDiagReport.xml, event logs, and IME logs to provide a unified view of the device's policy state." FontSize="11" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" LineHeight="18" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>


            <!-- ROW 3: GRID SPLITTER (resize console) -->
            <GridSplitter x:Name="splitterBottom" Grid.Row="3" Height="4" HorizontalAlignment="Stretch"
                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                          Background="{DynamicResource ThemeBorder}" Cursor="SizeNS"/>

            <!-- ROW 4: CONSOLE / OUTPUT PANEL (VS Code style) -->
            <Border x:Name="pnlBottomPanel" Grid.Row="4" Background="{DynamicResource ThemePanelBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Header bar -->
                    <Border Grid.Row="0" Background="{DynamicResource ThemeDeepBg}" Padding="12,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource ThemeAccentLight}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="1" Text="OUTPUT" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                            <Button x:Name="btnClearLog" Style="{StaticResource IconButton}" Grid.Column="3" ToolTip="Clear output">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                            </Button>
                            <Button x:Name="btnHideBottom" Style="{StaticResource IconButton}" Grid.Column="4" ToolTip="Hide panel">
                                <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                            </Button>
                        </Grid>
                    </Border>
                    <!-- Log content -->
                    <ScrollViewer x:Name="logScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,6"
                                  Background="{DynamicResource ThemeOutputBg}">
                        <RichTextBox x:Name="rtbActivityLog" Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                     FontSize="10" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource ThemeTextMuted}"
                                     IsDocumentEnabled="False"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <FlowDocument x:Name="docActivityLog" PageWidth="5000">
                                <Paragraph x:Name="paraLog" Margin="0" LineHeight="16"/>
                            </FlowDocument>
                        </RichTextBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ROW 5: STATUS BAR -->
            <Border Grid.Row="5" Background="{DynamicResource ThemeDeepBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="12,0" CornerRadius="0,0,8,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="statusBarDot" Width="6" Height="6" Fill="{DynamicResource ThemeTextDim}" Margin="0,0,6,0"/>
                        <TextBlock x:Name="lblStatusBar" Text="Ready" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="|" Foreground="{DynamicResource ThemeTextFaintest}" Margin="10,0" VerticalAlignment="Center" FontSize="10"/>
                    <TextBlock x:Name="lblStatusDetail" Grid.Column="2" Text="" FontSize="10" Foreground="{DynamicResource ThemeTextDisabled}" VerticalAlignment="Center"/>
                    <Button x:Name="btnToggleConsole" Style="{StaticResource IconButton}" Grid.Column="3" Width="24" Height="20" ToolTip="Toggle output panel">
                        <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="9"
                                   Foreground="{DynamicResource ThemeTextMuted}"/>
                    </Button>
                    <TextBlock x:Name="lblVersionBar" Grid.Column="4" Text="v0.1.0" FontSize="10" Foreground="{DynamicResource ThemeTextDisabled}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </Grid>
            </Border>

            <!-- ===== TOAST NOTIFICATION ===== -->
            <!-- ===== CONFETTI CANVAS ===== -->
            <Canvas x:Name="cnvConfetti" Grid.Row="2" Grid.RowSpan="4" Panel.ZIndex="998"
                    Visibility="Collapsed" IsHitTestVisible="False" ClipToBounds="True"/>

            <Border x:Name="ToastBorder" Grid.Row="2" Grid.RowSpan="4" Panel.ZIndex="999" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,16,24,0" Width="340" CornerRadius="10"
                    Background="{DynamicResource ThemeCardBg}" Effect="{StaticResource PopupShadow}"
                    BorderBrush="{DynamicResource ThemeBorderElevated}" BorderThickness="1"
                    IsHitTestVisible="False">
                <Border.RenderTransform>
                    <TranslateTransform X="400" Y="0"/>
                </Border.RenderTransform>
                <Grid>
                    <Border x:Name="ToastAccentBar" Width="3" HorizontalAlignment="Left" CornerRadius="3,0,0,3"
                            Background="{DynamicResource ThemeAccent}"/>
                    <StackPanel Orientation="Horizontal" Margin="14,12">
                        <TextBlock x:Name="ToastIcon" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                   Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Top" Margin="0,2,12,0"/>
                        <StackPanel>
                            <TextBlock x:Name="ToastTitle" Text="" FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextPrimary}"/>
                            <TextBlock x:Name="ToastMessage" Text="" FontSize="11.5"
                                       Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


