                        </StackPanel>

                        <!-- Stat Cards Row -->
                        <Grid Grid.Row="1" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card: Active GPOs -->
                            <Border Grid.Column="0" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="18,16"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Effect="{StaticResource CardShadow}"
                                    ToolTip="Number of GPOs with GpoStatus = AllSettingsEnabled or one section enabled">
                                <StackPanel>
                                    <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource ThemeAccent}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="StatActiveGPOs" Text="—" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                    <TextBlock Text="Active GPOs" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Total Settings -->
                            <Border Grid.Column="2" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="18,16"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Effect="{StaticResource CardShadow}"
                                    ToolTip="Total individual policy settings configured across all GPOs">
                                <StackPanel>
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource ThemeGreenAccent}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="StatTotalSettings" Text="—" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                    <TextBlock Text="Total Settings" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Conflicts -->
                            <Border Grid.Column="4" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="18,16"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Effect="{StaticResource CardShadow}"
                                    ToolTip="Settings configured with DIFFERENT values in multiple GPOs — may cause unexpected behavior">
                                <StackPanel>
                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource ThemeError}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="StatConflicts" Text="—" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                    <TextBlock Text="Conflicts" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Redundant -->
                            <Border Grid.Column="6" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="18,16"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Effect="{StaticResource CardShadow}"
                                    ToolTip="Settings configured with IDENTICAL values in multiple GPOs — cleanup candidates">
                                <StackPanel>
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource ThemeWarning}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="StatRedundant" Text="—" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                    <TextBlock Text="Redundant" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Unlinked -->
                            <Border Grid.Column="8" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="18,16"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Effect="{StaticResource CardShadow}"
                                    ToolTip="GPOs that are not linked to any OU/Site/Domain — orphan candidates">
                                <StackPanel>
                                    <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="StatUnlinked" Text="—" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                                    <TextBlock Text="Unlinked" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Getting Started / Top conflicts preview -->
                        <!-- Chart Widgets -->
                        <Border Grid.Row="2" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="16,12" Margin="0,0,0,16"
                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Visibility="Collapsed" x:Name="ChartPanel">
                            <Canvas x:Name="ChartCanvas" Height="280" Width="240" ClipToBounds="True" AutomationProperties.Name="Dashboard charts"/>
                        </Border>
                        <Grid Grid.Row="3">
                            <!-- Empty state: Getting Started -->
                            <Border x:Name="DashEmptyState" Visibility="Visible" Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="40,30"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
                                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{DynamicResource ThemeAccent}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="Welcome to PolicyPilot" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="Scan local policies or Active Directory to discover Group Policy Objects, generate documentation, and detect duplicate or conflicting settings."
                                               FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,24"/>

                                    <!-- Steps -->
                                    <StackPanel HorizontalAlignment="Left" Margin="20,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource ThemeAccent}" Margin="0,0,12,0">
                                                <TextBlock Text="1" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Select scan mode and click the scan button" FontSize="12.5" Foreground="{DynamicResource ThemeTextBody}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource ThemeAccent}" Margin="0,0,12,0">
                                                <TextBlock Text="2" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Review GPOs, settings, and conflicts" FontSize="12.5" Foreground="{DynamicResource ThemeTextBody}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource ThemeAccent}" Margin="0,0,12,0">
                                                <TextBlock Text="3" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Export HTML documentation or CSV reports" FontSize="12.5" Foreground="{DynamicResource ThemeTextBody}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button x:Name="BtnGetStarted" Style="{StaticResource AccentButton}" HorizontalAlignment="Center" Margin="0,20,0,0"
                                            ToolTip="Start scanning policies">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="BtnGetStartedText" Text="Scan Intune Policies" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="  &#x2192;" FontSize="14"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Data state: Top conflicts preview -->
                            <Border x:Name="DashDataState" Visibility="Collapsed" Background="{DynamicResource ThemeCardBg}" CornerRadius="12" Padding="20,16"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="Top Issues" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" DockPanel.Dock="Left"/>
                                        <Button x:Name="BtnViewAllConflicts" Content="View All &#x2192;" Style="{StaticResource GhostButton}" DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="12,5" FontSize="11" ToolTip="Switch to the Conflicts tab to see the full list"/>
                                    </DockPanel>
                                    <DataGrid x:Name="DashTopConflictsGrid" Grid.Row="1" Style="{StaticResource DarkDataGrid}"
                                              ColumnHeaderStyle="{StaticResource DarkColumnHeader}" CellStyle="{StaticResource DarkDataGridCell}" RowStyle="{StaticResource DarkDataGridRow}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                                            <DataGridTextColumn Header="Setting" Binding="{Binding SettingKey}" Width="*"/>
                                            <DataGridTextColumn Header="GPOs Affected" Binding="{Binding GPOCount}" Width="110"/>
                                            <DataGridTextColumn Header="Winner" Binding="{Binding WinnerGPO}" Width="180"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ===== PANEL: GPO LIST ===== -->
                    <Grid x:Name="PanelGPOList" Visibility="Collapsed" Margin="24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="GPO List" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                            <TextBlock Text="All discovered Group Policy Objects. Click a row to see details in the sidebar. Use filters to narrow by status or scope." FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock x:Name="GPOListSubtitle" Text="All discovered Group Policy Objects &#x2014; click column headers to sort, right-click rows for actions" FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border x:Name="GPOListEmptyState" Grid.Row="1" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="30,40" VerticalAlignment="Center" HorizontalAlignment="Center"
                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                                <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="No GPOs loaded" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Run a scan to discover Group Policy Objects from your local machine, Active Directory domain, or Intune tenant." FontSize="12.5" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="GPOListGrid" Grid.Row="1" Visibility="Collapsed" Style="{StaticResource DarkDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}" CellStyle="{StaticResource DarkDataGridCell}" RowStyle="{StaticResource DarkDataGridRow}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="GPO Name" Binding="{Binding DisplayName}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="GPO status — AllSettingsEnabled, AllSettingsDisabled, UserSettingsDisabled, or ComputerSettingsDisabled"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="Settings" Binding="{Binding SettingCount}" Width="80">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="Number of individual policy settings configured in this GPO"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="Links" Binding="{Binding LinkCount}" Width="60">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="Number of OU/Site/Domain locations this GPO is linked to — 0 means orphaned"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="Created" Binding="{Binding CreationTime}" Width="140">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="When this GPO was first created in AD"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="Modified" Binding="{Binding ModificationTime}" Width="140">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="Last time this GPO was edited — stale GPOs may be cleanup candidates"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- ===== PANEL: ALL SETTINGS ===== -->
                    <Grid x:Name="PanelSettings" Visibility="Collapsed" Margin="24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto" MinHeight="0"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="All Settings" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                            <TextBlock Text="Every individual policy setting across all GPOs. Filter by configuration state, scope, or category to find gaps and non-default values." FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock x:Name="SettingsSubtitle" Text="Every policy setting across all sources &#x2014; grouped by Intune category, click group headers to collapse, hover cells for full text" FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border x:Name="SettingsEmptyState" Grid.Row="1" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="30,40" VerticalAlignment="Center" HorizontalAlignment="Center"
                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="No settings loaded" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Run a scan to discover configured policy settings. Results will be grouped by Intune category with conflict and default-value analysis." FontSize="12.5" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="SettingsGrid" Grid.Row="1" Visibility="Collapsed" Style="{StaticResource DarkDataGrid}"
                                  VirtualizingStackPanel.IsVirtualizing="False" EnableRowVirtualization="False" ScrollViewer.CanContentScroll="False"
                                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}" CellStyle="{StaticResource DarkDataGridCell}" RowStyle="{StaticResource DarkDataGridRow}">
                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <Expander IsExpanded="True" Style="{StaticResource GroupExpander}">
                                                            <Expander.Header>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                                    <TextBlock x:Name="GroupIcon" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource ThemeAccentLight}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="&#xE8CB;"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="Endpoint Security">
                                                                                        <Setter Property="Text" Value="&#xE72E;"/>
                                                                                        <Setter Property="Foreground" Value="#FF6B6B"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="Account Protection">
                                                                                        <Setter Property="Text" Value="&#xE77B;"/>
                                                                                        <Setter Property="Foreground" Value="#FFD93D"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="Device Compliance">
                                                                                        <Setter Property="Text" Value="&#xE73E;"/>
                                                                                        <Setter Property="Foreground" Value="#6BCB77"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="Windows Update">
                                                                                        <Setter Property="Text" Value="&#xE777;"/>
                                                                                        <Setter Property="Foreground" Value="#4FC3F7"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="App Management">
                                                                                        <Setter Property="Text" Value="&#xE71D;"/>
                                                                                        <Setter Property="Foreground" Value="#BA68C8"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="Registry Settings">
                                                                                        <Setter Property="Text" Value="&#xE74C;"/>
                                                                                        <Setter Property="Foreground" Value="#FFB74D"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="Configuration Profiles">
                                                                                        <Setter Property="Text" Value="&#xE713;"/>
                                                                                        <Setter Property="Foreground" Value="#90CAF9"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="ADMX Profiles">
                                                                                        <Setter Property="Text" Value="&#xE7EF;"/>
                                                                                        <Setter Property="Foreground" Value="#A5D6A7"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="Group Policy">
                                                                                        <Setter Property="Text" Value="&#xE8FC;"/>
                                                                                        <Setter Property="Foreground" Value="#CE93D8"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Name}" Value="Provisioning Packages">
                                                                                        <Setter Property="Text" Value="&#xE7B8;"/>
                                                                                        <Setter Property="Foreground" Value="#FFB74D"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" FontSize="13.5" VerticalAlignment="Center"/>
                                                                    <Border Background="{DynamicResource FilterBadgeBg}" CornerRadius="8" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding ItemCount, StringFormat='{}{0}'}" Foreground="{DynamicResource FilterBadgeText}" FontSize="11"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Expander.Header>
                                                            <ItemsPresenter/>
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Policy Name" Width="2*" SortMemberPath="PolicyName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PolicyName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding PolicyName}" Padding="0,2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Value" Width="*" SortMemberPath="ValueData">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ValueData}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ValueData}" Padding="0,2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Default" Binding="{Binding DefaultValue}" Width="70">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="The Windows default value for this setting before any GPO modifies it"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="70">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="Configuration state — Configured (set by a GPO) or Not Configured (gap)"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="60"/>
                                <DataGridTemplateColumn Header="Source" Width="75" SortMemberPath="Source">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="4,1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#2A2A2C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Source}" Value="Intune">
                                                                <Setter Property="Background" Value="#1A3B5C"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Source}" Value="Local GPO">
                                                                <Setter Property="Background" Value="#2E4032"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Source}" Value="Domain GPO">
                                                                <Setter Property="Background" Value="#3D2E50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Source}" FontSize="10" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Category" Width="160" SortMemberPath="Category">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CategoryBadgeBg}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Category}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimary}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Category}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="GPO / Source" Width="*" SortMemberPath="GPOName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding GPOName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding RegistryKey}" Padding="0,2" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border x:Name="SettingsDetailPane" Grid.Row="2" Background="{DynamicResource ThemeCardBg}" CornerRadius="6" Padding="12,8" Margin="0,8,0,0" Visibility="Collapsed" MaxHeight="200">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="DetailPaneText" Text="Select a row to view details" FontSize="11.5" FontFamily="Cascadia Code,Consolas,monospace" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" AutomationProperties.Name="Setting detail pane"/>
                                </ScrollViewer>
                                <Button x:Name="BtnCloseDetailPane" Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Top" Margin="4,0,0,0" Padding="4" Cursor="Hand" ToolTip="Close detail pane" Background="Transparent" Foreground="{DynamicResource ThemeTextMuted}" BorderThickness="0" AutomationProperties.Name="Close detail pane"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== PANEL: CONFLICTS ===== -->
                    <Grid x:Name="PanelConflicts" Visibility="Collapsed" Margin="24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Conflicts &amp; Redundancies" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                            <TextBlock Text="Settings configured with different values in multiple GPOs (conflicts) or identical values in multiple GPOs (redundancy). The Winner column shows which value actually applies based on link order." FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock x:Name="ConflictsSubtitle" Text="Settings configured in multiple GPOs &#x2014; conflicts (different values) and redundancies (same value) that may need cleanup" FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border x:Name="ConflictsEmptyState" Grid.Row="1" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="30,40" VerticalAlignment="Center" HorizontalAlignment="Center"
                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                                <TextBlock Text="&#xE730;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="No conflicts detected" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Run a scan to analyze policy overlap. If the same setting is defined in multiple GPOs, it will appear here with severity and winner analysis." FontSize="12.5" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="ConflictsGrid" Grid.Row="1" Visibility="Collapsed" Style="{StaticResource DarkDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}" CellStyle="{StaticResource DarkDataGridCell}" RowStyle="{StaticResource DarkDataGridRow}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                                <DataGridTextColumn Header="Setting" Binding="{Binding SettingKey}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="ToolTip" Value="{Binding RegistryPath}"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="85"/>
                                <DataGridTextColumn Header="GPOs" Binding="{Binding GPONames}" Width="250"/>
                                <DataGridTextColumn Header="Values" Binding="{Binding Values}" Width="220">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="The conflicting values set by different GPOs — quoted strings show the actual configured data"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="Winner" Binding="{Binding WinnerGPO}" Width="160">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="The GPO whose value actually applies — determined by link order and enforcement precedence"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- ===== PANEL: INTUNE APPS ===== -->
                    <Grid x:Name="PanelIntuneApps" Visibility="Collapsed" Margin="24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Intune Managed Apps" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}"/>
                            <TextBlock Text="Applications managed by Intune (IME) on this device. Shows install state, enforcement intent, and error codes from the local IME registry. Select a row and use Reset in the sidebar to force re-evaluation." FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock x:Name="IntuneAppsSubtitle" Text="Win32, LOB, and Store apps tracked by Intune &#x2014; install state, enforcement, and error codes from the local device registry" FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border x:Name="IntuneAppsEmptyState" Grid.Row="1" Background="{DynamicResource ThemeCardBg}" CornerRadius="10" Padding="30,40" VerticalAlignment="Center" HorizontalAlignment="Center"
                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                                <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="No apps loaded" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="Run a scan with Intune or Combined mode to discover managed apps. Requires the device to be Intune-enrolled." FontSize="12.5" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="IntuneAppsGrid" Grid.Row="1" Visibility="Collapsed" Style="{StaticResource DarkDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}" CellStyle="{StaticResource DarkDataGridCell}" RowStyle="{StaticResource DarkDataGridRow}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="App Name" Binding="{Binding AppName}" Width="*" MinWidth="200"/>
                                <DataGridTextColumn Header="App ID" Binding="{Binding AppId}" Width="280"/>
                                <DataGridTextColumn Header="Version" Binding="{Binding AppVersion}" Width="100"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding AppType}" Width="90"/>
                                <DataGridTextColumn Header="Install State" Binding="{Binding InstallState}" Width="110">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="Current install state — Installed (applied), Failed (error), Pending (queued for install), Not Installed (not targeted or removed)"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="Enforcement" Binding="{Binding EnforcementState}" Width="120">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="IME enforcement state — Required (must install), Available (user choice), or Uninstall (targeted for removal)"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="Error" Binding="{Binding ErrorCode}" Width="90">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="Error code from the last install attempt — 0 means success, other values are HRESULT or Win32 error codes"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="User/Device" Binding="{Binding UserId}" Width="120">
                                            <DataGridTextColumn.HeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkColumnHeader}"><Setter Property="ToolTip" Value="The user SID or device context this app was installed for"/></Style></DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModified}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- ===== PANEL: REPORT PREVIEW ===== -->
                    <Grid x:Name="PanelReport" Visibility="Collapsed" Margin="24,20">
