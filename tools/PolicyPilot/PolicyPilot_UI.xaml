                                    <Button x:Name="FilterGPODisabled" Style="{StaticResource FilterPill}" ToolTip="Show only disabled GPOs that have been toggled off"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterRed}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Disabled"/></StackPanel></Button>
                                </StackPanel>

