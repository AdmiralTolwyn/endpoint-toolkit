                                <TextBlock Text="CATEGORY" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,10,0,8"/>
                                <ComboBox x:Name="CmbCategoryFilter" Style="{StaticResource DarkComboBox}" HorizontalAlignment="Stretch"
                                          ToolTip="Filter by policy category"/>
                                <TextBlock Text="Narrow results to a specific policy category from the scan" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,2,0,8"/>
                                <TextBlock Text="GROUP" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,10,0,4"/>
                                <TextBlock Text="Filter by Intune management group" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,0,0,4">
                                    <Button x:Name="FilterGroupAll" Content="All" Style="{StaticResource FilterPill}" Tag="Active" ToolTip="Show settings from all Intune management groups"/>
                                    <Button x:Name="FilterGroupEndpointSec" Style="{StaticResource FilterPill}" ToolTip="Endpoint Security — Defender, firewall, disk encryption, and attack surface reduction policies"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterRed}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Endpoint Security"/></StackPanel></Button>
                                    <Button x:Name="FilterGroupAcctProt" Style="{StaticResource FilterPill}" ToolTip="Account Protection — Windows Hello, credential guard, and LAPS settings"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterYellow}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Account Protection"/></StackPanel></Button>
                                    <Button x:Name="FilterGroupCompliance" Style="{StaticResource FilterPill}" ToolTip="Compliance — Device compliance policies (OS version, encryption, password requirements)"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterGreen}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Compliance"/></StackPanel></Button>
                                    <Button x:Name="FilterGroupWinUpdate" Style="{StaticResource FilterPill}" ToolTip="Windows Update — Update rings, feature updates, and delivery optimization settings"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterCyan}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Windows Update"/></StackPanel></Button>
                                    <Button x:Name="FilterGroupAppMgmt" Style="{StaticResource FilterPill}" ToolTip="App Management — Win32 app assignments, store apps, and LOB deployment settings"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterPurple}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="App Mgmt"/></StackPanel></Button>
                                    <Button x:Name="FilterGroupRegistry" Style="{StaticResource FilterPill}" ToolTip="Registry — Direct registry-based policy values (ADMX-backed or custom OMA-URI)"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterOrange}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Registry"/></StackPanel></Button>
                                    <Button x:Name="FilterGroupConfigProf" Style="{StaticResource FilterPill}" ToolTip="Configuration Profiles — Device restrictions, Wi-Fi, VPN, email, and certificate profiles"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterBlue}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Config Profiles"/></StackPanel></Button>
                                    <Button x:Name="FilterGroupADMXProf" Style="{StaticResource FilterPill}" ToolTip="ADMX Profiles — Administrative template policies imported into Intune from ADMX/ADML files"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterLightGreen}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="ADMX Profiles"/></StackPanel></Button>
                                    <Button x:Name="FilterGroupGPO" Style="{StaticResource FilterPill}" ToolTip="Group Policy — Traditional domain GPO settings (requires AD scan mode)"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8FC;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterLightPurple}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Group Policy"/></StackPanel></Button>
                                    <Button x:Name="FilterGroupPpkg" Style="{StaticResource FilterPill}" ToolTip="Provisioning Packages — Settings applied via .ppkg files at imaging/OOBE time"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterYellow}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Prov. Packages"/></StackPanel></Button>
                                </WrapPanel>

                                <!-- Settings summary card -->
                                <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="14" Margin="0,14,0,0"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="ANALYSIS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Scan result metrics — coverage shows how many known settings are configured" FontSize="9.5" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Configured" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            <TextBlock x:Name="StatConfigured" Grid.Row="0" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeAccentLight}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Not Configured" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            <TextBlock x:Name="StatNotConfigured" Grid.Row="1" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Non-Default Values" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            <TextBlock x:Name="StatNonDefault" Grid.Row="2" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeError}"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Coverage" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,4,0,0"/>
                                            <TextBlock x:Name="StatCoverage" Grid.Row="3" Grid.Column="1" Text="—" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,4,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Sidebar: Conflicts -->
                            <StackPanel x:Name="SidebarConflicts" Visibility="Collapsed" Margin="16,16">
                                <TextBlock Text="CONFLICT ANALYSIS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                <TextBlock Text="Detect and review settings with conflicting or redundant values across GPOs" FontSize="9" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <!-- Scan status indicator -->
                                <Border x:Name="ScanStatusConflicts" Background="{DynamicResource ThemeCardBg}" CornerRadius="6" Padding="10,8" Margin="0,0,0,14"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="LblScanStatusConflicts" Text="No scan data — use Dashboard to scan" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button x:Name="BtnGoToDashConflicts" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,6,0,0" Padding="8,4" ToolTip="Navigate to Dashboard to configure and run a scan">
                                            <TextBlock Text="Go to Dashboard" FontSize="10"/>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="SEVERITY" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,8"/>
                                <TextBlock Text="Filter by conflict severity — true conflicts vs redundant settings" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button x:Name="FilterConflictAll" Content="All" Style="{StaticResource FilterPill}" Tag="Active" ToolTip="Show all detected issues — conflicts and redundancies"/>
                                    <Button x:Name="FilterConflictOnly" Style="{StaticResource FilterPill}" ToolTip="True conflicts — same setting configured with different values across multiple GPOs or profiles"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterRed}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Conflicts"/></StackPanel></Button>
                                    <Button x:Name="FilterRedundantOnly" Style="{StaticResource FilterPill}" ToolTip="Redundant — same setting configured with identical values in multiple GPOs (safe but unnecessary)"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource FilterOrange}" VerticalAlignment="Center" Margin="0,0,4,0"/><TextBlock Text="Redundant"/></StackPanel></Button>
                                </StackPanel>

                                <!-- Conflict summary -->
                                <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="14" Margin="0,14,0,0"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="SUMMARY" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="ConflictSummaryText" Text="Run a scan to detect conflicts" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Sidebar: Intune Apps -->
                            <StackPanel x:Name="SidebarIntuneApps" Visibility="Collapsed" Margin="16,16">
                                <TextBlock Text="INTUNE APPS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                <TextBlock Text="View managed Win32, MSI, and Store apps deployed via Intune. Reset individual app install states to force re-evaluation on next sync." FontSize="9" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <Button x:Name="BtnScan_IntuneApps" Style="{StaticResource AccentButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" ToolTip="Scan Intune managed apps (forces Intune scan mode)">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE149;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Scan Intune Apps" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="Scans managed apps via local MDM registry (sets mode to Intune if needed)" FontSize="9" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,14"/>

                                <TextBlock Text="APP TYPE" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbAppTypeFilter" Style="{StaticResource DarkComboBox}" SelectedIndex="0" Margin="0,0,0,12" HorizontalAlignment="Stretch" ToolTip="Filter by deployment type — Win32/LOB (SCCM-style), MSI, Store/MSIX, or all">
                                    <ComboBoxItem Content="All Types"/>
                                <TextBlock Text="Filter by deployment method — Win32/LOB (SCCM-style), MSI, or Store/MSIX" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <ComboBoxItem Content="Win32/LOB"/>
                                    <ComboBoxItem Content="MSI/LOB"/>
                                    <ComboBoxItem Content="Store/MSIX"/>
                                    <ComboBoxItem Content="Resettable"/>
                                </ComboBox>

                                <TextBlock Text="STATUS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbAppStatusFilter" Style="{StaticResource DarkComboBox}" SelectedIndex="0" Margin="0,0,0,4" HorizontalAlignment="Stretch" ToolTip="Filter by install state — Installed, Failed, Pending, or Not Installed">
                                    <ComboBoxItem Content="All Statuses"/>
                                    <ComboBoxItem Content="Installed"/>
                                    <ComboBoxItem Content="Failed"/>
                                    <ComboBoxItem Content="Pending"/>
                                    <ComboBoxItem Content="Not Installed"/>
                                </ComboBox>
                                <TextBlock Text="Show only apps with a specific install state" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,2,0,14"/>

                                <!-- Hide internal management apps -->
                                <CheckBox x:Name="ChkHideInternal" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,0,4">
                                    <TextBlock Text="Hide internal packages" Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"/>
                                </CheckBox>
                                <TextBlock Text="Hides Intune management agents (EPM, Inventory, WindowsAgent)" FontSize="9"
                                           Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="18,0,0,14"/>
                                <!-- App summary card -->
                                <Border x:Name="AppAdminBanner" Visibility="Collapsed" Background="{DynamicResource AdminBannerBg}" CornerRadius="6" Padding="10" Margin="0,0,0,10"
                                        BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                                    <DockPanel>
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="{DynamicResource ThemeWarning}" VerticalAlignment="Top" Margin="0,1,8,0" DockPanel.Dock="Left"/>
                                        <Button x:Name="BtnDismissAppBanner" DockPanel.Dock="Right" VerticalAlignment="Top" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0" Padding="4,0" Margin="4,0,0,0" ToolTip="Dismiss">
                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                        </Button>
                                        <TextBlock x:Name="AppAdminBannerText" Text="Not running as admin &#x2014; app list may be incomplete" FontSize="10"
                                                   Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap"/>
                                    </DockPanel>
                                </Border>
                                <Border Background="{DynamicResource ThemeCardBg}" CornerRadius="8" Padding="14" Margin="0,0,0,14"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="SUMMARY" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="IntuneAppsSummaryText" Text="Run scan to detect apps" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextSecondary}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Reset button -->
                                <Button x:Name="BtnResetAppInstall" Style="{StaticResource AccentButton}" HorizontalAlignment="Stretch"
                                        IsEnabled="False" Margin="0,0,0,8" ToolTip="Delete the IME tracking registry key for the selected app so Intune re-evaluates it on next sync">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Reset Selected App" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="Deletes IME tracking key to force re-evaluation on next sync" FontSize="9"
                                           Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,0,0,0"/>
                            </StackPanel>

                            <!-- Sidebar: Report -->
                            <StackPanel x:Name="SidebarReport" Visibility="Collapsed" Margin="16,16">
                                <TextBlock Text="REPORT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                <TextBlock Text="Export scan results as HTML documentation, CSV, or JSON" FontSize="9" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <!-- Scan status indicator -->
                                <Border x:Name="ScanStatusReport" Background="{DynamicResource ThemeCardBg}" CornerRadius="6" Padding="10,8" Margin="0,0,0,14"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="LblScanStatusReport" Text="No scan data — use Dashboard to scan" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button x:Name="BtnGoToDashReport" Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,6,0,0" Padding="8,4" ToolTip="Navigate to Dashboard to configure and run a scan">
                                            <TextBlock Text="Go to Dashboard" FontSize="10"/>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="BtnExportHtml" Style="{StaticResource AccentButton}" HorizontalAlignment="Stretch" Margin="0,0,0,8" IsEnabled="False"
                                        ToolTip="Generate a self-contained HTML documentation report">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Export HTML Report" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnExportCsv" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Margin="0,0,0,8" IsEnabled="False"
                                        ToolTip="Export all settings to CSV for Excel analysis">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Export CSV" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnExportConflictsCsv" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" IsEnabled="False"
                                        ToolTip="Export only conflicts/redundancies to CSV">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Export Conflicts CSV" FontSize="12"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="ADDITIONAL EXPORTS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,14,0,8"/>
                                <Button x:Name="BtnExportScript" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" IsEnabled="False" ToolTip="Generate a PowerShell script to recreate GPO settings (Ctrl+G)" AutomationProperties.Name="Export as PowerShell script">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Export as Script" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnExportReg" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" IsEnabled="False" ToolTip="Export registry settings as .reg file" AutomationProperties.Name="Export registry file">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Export .reg File" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnPrintReport" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" IsEnabled="False" ToolTip="Open report in browser for printing (Ctrl+P)" AutomationProperties.Name="Print report">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Print / Open in Browser" FontSize="12"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="COMPARISON" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,14,0,8"/>
                                <Button x:Name="BtnCompareSnapshot" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6" IsEnabled="False" ToolTip="Compare current scan against a saved snapshot (Ctrl+D)" AutomationProperties.Name="Compare with snapshot">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Compare Snapshot" FontSize="12"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="OPTIONS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,18,0,8"/>
                                <CheckBox x:Name="ChkIncludeDisabled" Content="Include disabled GPOs" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,8" ToolTip="When enabled, disabled GPOs appear in reports and exports"/>
                                <CheckBox x:Name="ChkIncludeUnlinked" Content="Include unlinked GPOs" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,8" ToolTip="When enabled, GPOs not linked to any OU are included"/>
                                <CheckBox x:Name="ChkShowRegistryPaths" Content="Show registry paths" Style="{StaticResource ToggleSwitch}" IsChecked="True" ToolTip="Show full registry paths for each policy setting in the grid"/>
                            </StackPanel>

                            <!-- Sidebar: App Settings -->
                            <!-- ===== SIDEBAR: IME LOGS ===== -->
                            <StackPanel x:Name="SidebarIMELogs" Visibility="Collapsed" Margin="16,16">
                                <TextBlock Text="IME LOG VIEWER" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                <TextBlock Text="Stream and analyze Intune Management Extension log files in real time" FontSize="9" Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Log source -->
                                <TextBlock Text="LOG SOURCE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbImeLogSource" Style="{StaticResource DarkComboBox}" Height="30" Margin="0,0,0,14" SelectedIndex="0"
                                          ToolTip="Select which IME log file to tail">
                                    <ComboBoxItem Content="IntuneManagementExtension"/>
                                    <ComboBoxItem Content="AgentExecutor"/>
                                    <ComboBoxItem Content="HealthScripts"/>
                                    <ComboBoxItem Content="Sensor"/>
                                    <ComboBoxItem Content="AppWorkload"/>
                                    <ComboBoxItem Content="AppActionProcessor"/>
                                </ComboBox>

                                <!-- Line limit -->
                                <TextBlock Text="LINE LIMIT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                <TextBlock Text="Load only the last N lines for faster analysis" FontSize="9" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbImeLineLimit" Style="{StaticResource DarkComboBox}" Height="30" Margin="0,0,0,14" SelectedIndex="1"
                                          ToolTip="Limit how many lines to load in analysis mode (tail-read)">
                                    <ComboBoxItem Content="Last 1,000 lines"/>
                                    <ComboBoxItem Content="Last 5,000 lines"/>
                                    <ComboBoxItem Content="Last 10,000 lines"/>
                                    <ComboBoxItem Content="All lines (slow)"/>
                                </ComboBox>

                                <!-- Mode toggle -->
                                <TextBlock Text="MODE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,6"/>
                                <CheckBox x:Name="ChkImeLiveTail" Content="Live tail" Style="{StaticResource ToggleSwitch}" IsChecked="True" Margin="0,0,0,2"
                                          ToolTip="When enabled, streams new log lines in real time. When off, loads the full log for analysis."/>
                                <TextBlock x:Name="ImeModeHint" Text="Streaming new log entries in real time" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}" TextWrapping="Wrap" Margin="0,0,0,14"/>

                                <!-- Severity filter -->
                                <TextBlock Text="SEVERITY FILTER" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                <TextBlock Text="Show all entries or only errors, warnings, and info messages" FontSize="9" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,0,0,14">
                                    <Button x:Name="FilterImeAll" Content="All" Style="{StaticResource FilterPill}" Tag="Active" ToolTip="Show all log entries regardless of severity"/>
                                    <Button x:Name="FilterImeError" Content="Errors" Style="{StaticResource FilterPill}" ToolTip="Show only error entries — app install failures, timeouts, exceptions"/>
                                    <Button x:Name="FilterImeWarning" Content="Warnings" Style="{StaticResource FilterPill}" ToolTip="Show only warning entries — retries, partial failures, non-critical issues"/>
                                    <Button x:Name="FilterImeInfo" Content="Info" Style="{StaticResource FilterPill}" ToolTip="Show only informational entries — normal operations, state transitions"/>
                                </WrapPanel>

                                <TextBlock Text="CONTENT FILTER" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ThemeTextMuted}" Margin="0,0,0,4"/>
                                <TextBlock Text="Filter by keyword, component, or regex" FontSize="9" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,6"/>
                                <TextBox x:Name="TxtImeContentFilter" Style="{StaticResource DarkTextBox}" Height="28" Margin="0,0,0,6"
                                         ToolTip="Type keyword or /regex/ to filter entries (e.g. Win32App, /install|removal/)"/>
