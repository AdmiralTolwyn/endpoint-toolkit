                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Center" Margin="0,0,6,0"/>
