<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="PresentationOptions"
        Title="Azure Change Tracker" Height="860" Width="1340"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        Background="{DynamicResource ThemeAppBg}" Foreground="{DynamicResource ThemeTextBody}" FontFamily="Inter, Segoe UI Variable Display, Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="4" GlassFrameThickness="1" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- THEME BRUSHES (Dark defaults — mutated at runtime for Light Mode) -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="ThemeAppBg"           Color="#111113" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemePanelBg"         Color="#18181B" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeCardBg"          Color="#1E1E1E" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeCardAltBg"       Color="#1A1A1A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeInputBg"         Color="#141414" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeDeepBg"          Color="#0D0D0D" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeOutputBg"        Color="#0A0A0A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSurfaceBg"       Color="#1F1F23" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeHoverBg"         Color="#27272B" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSelectedBg"      Color="#2A2A2A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemePressedBg"       Color="#1A1A1A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccent"          Color="#0078D4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentHover"     Color="#1A8AD4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentLight"     Color="#60CDFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentDim"       Color="#1A0078D4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeGreenAccent"     Color="#00C853" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentText"      Color="#FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextPrimary"     Color="#FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextBody"        Color="#E0E0E0" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextSecondary"   Color="#A1A1AA" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextMuted"       Color="#71717A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextDim"         Color="#8B8B93" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextDisabled"    Color="#383838" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextFaintest"    Color="#6B6B73" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorder"          Color="#0FFFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderCard"      Color="#0FFFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderElevated"  Color="#333333" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderHover"     Color="#444444" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderMedium"    Color="#1AFFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderSubtle"    Color="#333333" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeScrollThumb"     Color="#999999" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeScrollTrack"     Color="#22FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSuccess"         Color="#00C853" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeWarning"         Color="#F59E0B" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeError"           Color="#FF5000" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeErrorDim"        Color="#20FF5000" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeProgressEdge"    Color="#18FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSidebarBg"       Color="#111113" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSidebarBorder"   Color="#00000000" PresentationOptions:Freeze="False"/>

        <!-- DOT GRID PATTERN -->
        <DrawingBrush x:Key="DotGridBrush" TileMode="Tile" Viewport="0,0,44,44" ViewportUnits="Absolute"
                      Viewbox="0,0,44,44" ViewboxUnits="Absolute" PresentationOptions:Freeze="False">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <SolidColorBrush Color="#1EFFFFFF"/>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="22,22" RadiusX="1.3" RadiusY="1.3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- SCROLLVIEWER: hide corner rectangle -->
        <Style TargetType="{x:Type ScrollViewer}">
            <Style.Resources>
                <Style TargetType="Rectangle">
                    <Setter Property="Fill" Value="Transparent"/>
                </Style>
            </Style.Resources>
        </Style>

        <!-- SCROLLBAR (Minimal 10px, rounded, themed) -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Background="{DynamicResource ThemeScrollTrack}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder" Background="{DynamicResource ThemeScrollThumb}" CornerRadius="4" MinHeight="40" Margin="1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ThemeAccentLight}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ThemeTextPrimary}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="10"/>
                                <Setter Property="MinHeight" Value="10"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--                        BUTTON STYLES                              -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <!-- TITLE BAR BUTTON -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent" Width="46" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeSurfaceBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TITLE BAR CLOSE BUTTON (red hover) -->
        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent" Width="46" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="#E81123"/></Setter.Value>
                                </Setter>
                                <Setter Property="Foreground"><Setter.Value><SolidColorBrush Color="White"/></Setter.Value></Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="#B90D1C"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACCENT BUTTON (gradient, primary CTA) -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="16,6" BorderThickness="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#005A9E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A8AD4" Offset="0"/>
                                            <GradientStop Color="#0067C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bdr" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#0078D4" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#005A9E" Offset="0"/>
                                            <GradientStop Color="#004578" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GREEN BUTTON (success CTA) -->
        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="16,6" BorderThickness="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#008F3D" Offset="0"/>
                                    <GradientStop Color="#006E2E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00C853" Offset="0"/>
                                            <GradientStop Color="#008F3D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST BUTTON (secondary, outline) -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="12,5" BorderThickness="1"
                                Background="Transparent" BorderBrush="{DynamicResource ThemeBorderCard}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER GHOST BUTTON -->
        <Style x:Key="DangerGhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="12,5" BorderThickness="1"
                                Background="Transparent" BorderBrush="{DynamicResource ThemeBorderCard}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeErrorDim}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeError}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeError}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ICON BUTTON (32x32 square) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- THEMED COMBOBOX (subscription selector) -->
        <Style x:Key="SubComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bdr" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeAccentDim}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SubComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ThemeDeepBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SubComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleBtn" ClickMode="Press" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bdr" Background="{DynamicResource ThemeDeepBg}"
                                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                                CornerRadius="8" Padding="10,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="10" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentSite" IsHitTestVisible="False" Margin="12,5,24,5"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropBorder" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260"
                                        Background="{DynamicResource ThemeCardBg}" CornerRadius="8"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Margin="0,2,0,0" Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.4"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TOGGLE SWITCH (CheckBox-based) -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="36" Height="18">
                            <Border x:Name="Track" CornerRadius="9" Background="{DynamicResource ThemeSurfaceBg}"
                                    BorderBrush="{DynamicResource ThemeBorderElevated}" BorderThickness="1"/>
                            <Border x:Name="Knob" Width="12" Height="12" CornerRadius="6"
                                    Background="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="KnobTranslate" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#0078D4" Offset="0"/>
                                            <GradientStop Color="#0067C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="Knob" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="White"/></Setter.Value>
                                </Setter>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate" Storyboard.TargetProperty="X"
                                                             To="18" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate" Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!--                          MAIN LAYOUT                                  -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>                                              <!-- Title bar -->
            <RowDefinition Height="Auto"/>                                            <!-- Auth bar -->
            <RowDefinition Height="*"/>                                               <!-- Main content -->
            <RowDefinition Height="Auto"/>                                            <!-- Splitter handle -->
            <RowDefinition x:Name="rowBottomPanel" Height="160" MinHeight="0"/>       <!-- Debug log -->
            <RowDefinition Height="28"/>                                              <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Background radial gradient glow -->
        <Border Grid.Row="0" Grid.RowSpan="6">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,0" RadiusX="1.2" RadiusY="1.0">
                    <GradientStop Color="#08338833" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Confetti canvas (overlays everything, clicks pass through) -->
        <Canvas x:Name="cnvConfetti" Grid.Row="0" Grid.RowSpan="6" Panel.ZIndex="999"
                IsHitTestVisible="False" Visibility="Collapsed"/>

        <!-- Toast notification host -->
        <StackPanel x:Name="pnlToastHost" Grid.Row="2" Panel.ZIndex="100"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="0,12,24,0" IsHitTestVisible="False"/>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 0: CUSTOM TITLE BAR                                           -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeDeepBg}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Border Background="{DynamicResource ThemeAccent}" CornerRadius="4" Width="20" Height="20" Margin="0,0,8,0">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="lblTitle" Text="Azure Change Tracker" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblTitleVersion" Text="v0.1.0-alpha" FontSize="9" Margin="8,0,0,0"
                               Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                    <Border CornerRadius="4" Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center"
                            BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                        <TextBlock Text="EXPERIMENTAL" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                    </Border>
                </StackPanel>
                <Button x:Name="btnHelp" Grid.Column="2" Style="{StaticResource TitleBarButton}" Content="?"
                        FontSize="13" FontFamily="Segoe UI" FontWeight="Bold" ToolTip="Help"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button x:Name="btnThemeToggle" Grid.Column="3" Style="{StaticResource TitleBarButton}"
                        Content="&#x2600;" FontSize="13" FontFamily="Segoe UI"/>
                <Button x:Name="btnMinimize" Grid.Column="4" Style="{StaticResource TitleBarButton}" Content="&#xE921;"/>
                <Button x:Name="btnMaximize" Grid.Column="5" Style="{StaticResource TitleBarButton}" Content="&#xE922;"/>
                <Button x:Name="btnClose"    Grid.Column="6" Style="{StaticResource TitleBarCloseButton}" Content="&#xE8BB;"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 1: AUTH BAR                                                   -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{DynamicResource ThemeSidebarBg}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Auth status pill -->
                <Border Grid.Column="0" CornerRadius="12" Padding="10,4" Height="26" MinWidth="120"
                        Background="{DynamicResource ThemeInputBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="authDot" Width="7" Height="7" Fill="{DynamicResource ThemeError}" Margin="0,0,7,0"/>
                        <TextBlock x:Name="lblAuthStatus" Text="Not connected" FontSize="11"
                                   Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"
                                   MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                <!-- Subscription selector -->
                <ComboBox x:Name="cmbSubscription" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                          MinWidth="200" MaxWidth="400" Visibility="Collapsed"
                          FontSize="11" FontFamily="Segoe UI Variable Small, Segoe UI"
                          Style="{StaticResource SubComboBox}"/>
                <!-- Sign In -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,4,0">
                    <Button x:Name="btnLogin" Style="{StaticResource AccentButton}" Padding="16,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Sign In" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Button x:Name="btnLogout" Grid.Column="4" Style="{StaticResource DangerGhostButton}"
                        Content="Sign Out" Visibility="Collapsed" Padding="12,4"/>
            </Grid>
        </Border>

        <!-- Accent glow separator -->
        <Border Grid.Row="1" VerticalAlignment="Bottom" Height="1" Panel.ZIndex="1"
                Background="{DynamicResource ThemeAccent}" Opacity="0.25" IsHitTestVisible="False"/>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 2: MAIN CONTENT (icon rail + sidebar + splitter + content)    -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44"/>                                         <!-- Icon rail -->
                <ColumnDefinition x:Name="colLeftPanel" Width="260" MinWidth="0"/>     <!-- Sidebar -->
                <ColumnDefinition Width="Auto"/>                                       <!-- Splitter -->
                <ColumnDefinition Width="*" MinWidth="400"/>                           <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- LEFT ICON RAIL -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeSidebarBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel Margin="0,8,0,0" DockPanel.Dock="Top">
                        <!-- Hamburger -->
                        <Button x:Name="btnHamburger" Style="{StaticResource IconButton}"
                                Content="&#xE700;" ToolTip="Toggle Sidebar" Margin="6,0,6,6"/>
                        <!-- Dashboard -->
                        <Button x:Name="railDashboard" Style="{StaticResource IconButton}" ToolTip="Dashboard" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railDashboardIndicator" Width="3" Fill="{DynamicResource ThemeAccentLight}"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Changes -->
                        <Button x:Name="railChanges" Style="{StaticResource IconButton}" ToolTip="Changes" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railChangesIndicator" Width="3" Fill="Transparent"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Timeline -->
                        <Button x:Name="railTimeline" Style="{StaticResource IconButton}" ToolTip="Timeline" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railTimelineIndicator" Width="3" Fill="Transparent"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE787;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Resources -->
                        <Button x:Name="railResources" Style="{StaticResource IconButton}" ToolTip="Resources" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railResourcesIndicator" Width="3" Fill="Transparent"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE74C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Settings -->
                        <Button x:Name="railSettings" Style="{StaticResource IconButton}" ToolTip="Settings" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railSettingsIndicator" Width="3" Fill="Transparent"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <!-- Bottom: output toggle -->
                    <Button x:Name="railOutput" Style="{StaticResource IconButton}" ToolTip="Toggle Debug Log"
                            DockPanel.Dock="Bottom" Content="&#xE756;" Margin="6,0,6,8" VerticalAlignment="Bottom"/>
                </DockPanel>
            </Border>

            <!-- LEFT SIDEBAR CONTENT -->
            <Border Grid.Column="1" Background="{DynamicResource ThemePanelBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12,12">
                    <StackPanel x:Name="pnlSidebar">
                        <!-- Sidebar: Dashboard context -->
                        <StackPanel x:Name="pnlSidebarDashboard" Visibility="Visible">
                            <TextBlock Text="O V E R V I E W" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <!-- Quick stats cards -->
                            <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Total Resources" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                    <TextBlock x:Name="lblSidebarResourceCount" Text="—" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Last Snapshot" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                    <TextBlock x:Name="lblSidebarLastSnapshot" Text="Never" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Snapshots Stored" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                    <TextBlock x:Name="lblSidebarSnapshotCount" Text="0" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeAccentLight}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Snapshot list -->
                            <TextBlock Text="SNAPSHOTS" FontSize="10" FontWeight="Bold" Margin="0,12,0,8"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <ListBox x:Name="lstSnapshots" Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource ThemeTextBody}"
                                     MaxHeight="300" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        </StackPanel>

                        <!-- Sidebar: Changes context -->
                        <StackPanel x:Name="pnlSidebarChanges" Visibility="Collapsed">
                            <TextBlock Text="COMPARE" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <TextBlock Text="From Snapshot" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbDiffFrom" MinWidth="100" FontSize="11" Style="{StaticResource SubComboBox}" Margin="0,0,0,10"/>
                            <TextBlock Text="To Snapshot" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbDiffTo" MinWidth="100" FontSize="11" Style="{StaticResource SubComboBox}" Margin="0,0,0,12"/>
                            <Button x:Name="btnRunCompare" Style="{StaticResource AccentButton}" HorizontalAlignment="Stretch" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8F4;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Compare" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                            <!-- Filters -->
                            <TextBlock Text="FILTER" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <TextBlock Text="Resource Type" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <Border CornerRadius="6" BorderThickness="1" MaxHeight="240" Margin="0,0,0,8"
                                    Background="{DynamicResource ThemeInputBg}" BorderBrush="{DynamicResource ThemeBorder}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="2">
                                    <StackPanel x:Name="pnlResourceTypeFilters" Margin="4,4,4,4"/>
                                </ScrollViewer>
                            </Border>
                            <TextBlock Text="Change Type" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbFilterChangeType" FontSize="11" Style="{StaticResource SubComboBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Search" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtFilterSearch" FontSize="11" Padding="8,4" Margin="0,0,0,12"
                                     Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeTextBody}"
                                     BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"/>
                            <StackPanel x:Name="pnlHideVolatileToggle" Orientation="Horizontal" Margin="0,0,0,4" Cursor="Hand">
                                <Border x:Name="chkHideVolatileTrack" Width="36" Height="20" CornerRadius="10"
                                        Background="{DynamicResource ThemeAccentLight}" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border x:Name="chkHideVolatileThumb" Width="16" Height="16" CornerRadius="8"
                                            Background="White" HorizontalAlignment="Right" Margin="2"/>
                                </Border>
                                <TextBlock Text="Hide metadata-only" FontSize="11"
                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Sidebar: Timeline context -->
                        <StackPanel x:Name="pnlSidebarTimeline" Visibility="Collapsed">
                            <TextBlock Text="TIMELINE" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <TextBlock Text="Resource Search" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtTimelineSearch" FontSize="11" Padding="8,4" Margin="0,0,0,12"
                                     Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeTextBody}"
                                     BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"/>
                            <TextBlock Text="Resource Type" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbTimelineType" FontSize="11" Style="{StaticResource SubComboBox}" Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- Sidebar: Resources context -->
                        <StackPanel x:Name="pnlSidebarResources" Visibility="Collapsed">
                            <TextBlock Text="INVENTORY" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <TextBlock Text="Resource Type" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbResourceType" FontSize="11" Style="{StaticResource SubComboBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Resource Group" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbResourceGroup" FontSize="11" Style="{StaticResource SubComboBox}" Margin="0,0,0,8"/>
                            <TextBlock Text="Search" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtResourceSearch" FontSize="11" Padding="8,4" Margin="0,0,0,8"
                                     Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeTextBody}"
                                     BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"/>
                        </StackPanel>

                        <!-- Sidebar: Settings context -->
                        <StackPanel x:Name="pnlSidebarSettings" Visibility="Collapsed">
                            <TextBlock Text="SETTINGS" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <TextBlock Text="Settings are displayed in the main panel." FontSize="11"
                                       Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Achievements (all contexts) -->
                        <Border Margin="0,20,0,0" Padding="0,10,0,0" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="ACHIEVEMENTS" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextMuted}"/>
                                    <TextBlock x:Name="lblAchievementCount" Text="0/15" FontSize="10" Margin="8,0,0,0"
                                               Foreground="{DynamicResource ThemeTextDim}"/>
                                </StackPanel>
                                <WrapPanel x:Name="pnlAchievements"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- GRID SPLITTER (sidebar ↔ content) -->
            <GridSplitter Grid.Column="2" Width="3" Background="Transparent" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Cursor="SizeWE" Focusable="False"/>

            <!-- MAIN CONTENT AREA -->
            <Grid Grid.Column="3">
                <!-- Background layers -->
                <Border x:Name="bdrDotGrid" Background="{DynamicResource DotGridBrush}" Panel.ZIndex="-2"/>
                <Border x:Name="bdrGradientGlow" Panel.ZIndex="-1" Height="320" VerticalAlignment="Top"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#200078D4" Offset="0.0"/>
                            <GradientStop Color="#100078D4" Offset="0.35"/>
                            <GradientStop Color="#080078D4" Offset="0.6"/>
                            <GradientStop Color="#00000000" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Shimmer progress bar (shown during background ops) -->
                <Border x:Name="bdrShimmer" Height="3" VerticalAlignment="Top" Panel.ZIndex="10"
                        Visibility="Collapsed" ClipToBounds="True">
                    <Border Width="300" HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#0078D4" Offset="0.3"/>
                                <GradientStop Color="#60CDFF" Offset="0.5"/>
                                <GradientStop Color="#0078D4" Offset="0.7"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="ShimmerTranslate" X="-500"/>
                        </Border.RenderTransform>
                    </Border>
                </Border>

                <!-- Tab bar + content -->
                <DockPanel>
                    <!-- Tab bar -->
                    <Border DockPanel.Dock="Top" Padding="16,0,16,0"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <!-- Snapshot Now button (left of tabs) -->
                            <Button x:Name="btnSnapshotNow" Style="{StaticResource AccentButton}" Margin="0,6,16,6"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE722;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Snapshot Now" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                            <Border Width="1" Height="20" Background="{DynamicResource ThemeBorder}" Margin="0,0,16,0"/>
                            <!-- Tab buttons -->
                            <Border x:Name="tabDashboard" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                    BorderThickness="0,0,0,2" BorderBrush="{DynamicResource ThemeAccent}">
                                <TextBlock Text="Dashboard" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThemeTextPrimary}"/>
                            </Border>
                            <Border x:Name="tabChanges" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                    BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                <TextBlock Text="Changes" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}"/>
                            </Border>
                            <Border x:Name="tabTimeline" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                    BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                <TextBlock Text="Timeline" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}"/>
                            </Border>
                            <Border x:Name="tabResources" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                    BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                <TextBlock Text="Resources" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}"/>
                            </Border>
                            <Border x:Name="tabSettings" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                    BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                <TextBlock Text="Settings" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}"/>
                            </Border>
                            <!-- Right-side toolbar -->
                            <Border Width="1" Height="20" Background="{DynamicResource ThemeBorder}" Margin="16,0,16,0"/>
                            <Button x:Name="btnExportReport" Style="{StaticResource GhostButton}" VerticalAlignment="Center" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEDE1;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                               Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Export" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnSaveBaseline" Style="{StaticResource GreenButton}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Save Baseline" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Tab content panels -->
                    <Grid>
                        <!-- STARTUP SPLASH OVERLAY -->
                        <Border x:Name="pnlSplash" Panel.ZIndex="50"
                                Background="{DynamicResource ThemeMainBg}"
                                Visibility="Visible">
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="480" Margin="0,40,0,0">
                                <StackPanel>
                                    <!-- App icon + title -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <TextBlock Text="&#xE728;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="28"
                                                   Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="Azure Change Tracker" FontSize="24" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblSplashVersion" Text="v1.0.0" FontSize="11"
                                               Foreground="{DynamicResource ThemeTextDim}" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                                    <!-- Step indicators -->
                                    <Border CornerRadius="10" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="24,20" Margin="0,0,0,0">
                                        <StackPanel>
                                            <!-- Step 1 -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Ellipse x:Name="dotStep1" Width="10" Height="10" Fill="{DynamicResource ThemeTextDim}"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="lblStep1" Text="Checking prerequisites..." FontSize="12"
                                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <!-- Step 2 -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Ellipse x:Name="dotStep2" Width="10" Height="10" Fill="{DynamicResource ThemeTextDim}"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="lblStep2" Text="Validating Azure credentials..." FontSize="12"
                                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <!-- Step 3 -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Ellipse x:Name="dotStep3" Width="10" Height="10" Fill="{DynamicResource ThemeTextDim}"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="lblStep3" Text="Initializing workspace..." FontSize="12"
                                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <!-- Status line -->
                                            <Border Margin="0,4,0,0" Padding="0,10,0,0"
                                                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
                                                <TextBlock x:Name="lblSplashStatus" Text="Starting up..."
                                                           FontSize="11" Foreground="{DynamicResource ThemeTextMuted}"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- DASHBOARD TAB -->
                        <ScrollViewer x:Name="pnlTabDashboard" VerticalScrollBarVisibility="Auto" Padding="24,20">
                            <StackPanel>
                                <!-- Summary cards row -->
                                <UniformGrid x:Name="pnlDashboardCards" Columns="4" Margin="0,0,0,20">
                                    <!-- Card: Total Resources -->
                                    <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Total Resources" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                            <TextBlock x:Name="lblDashTotalResources" Text="—" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Card: Changes -->
                                    <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Changes (Last Diff)" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                            <TextBlock x:Name="lblDashChanges" Text="—" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeWarning}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Card: Added -->
                                    <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Added" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                            <TextBlock x:Name="lblDashAdded" Text="—" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeSuccess}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Card: Removed -->
                                    <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Removed" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                            <TextBlock x:Name="lblDashRemoved" Text="—" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeError}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- Severity breakdown -->
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="20,16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Severity Breakdown" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,12"/>
                                        <StackPanel x:Name="pnlSeverityBars">
                                            <TextBlock Text="No diff data yet. Take two snapshots and compare."
                                                       FontSize="11" Foreground="{DynamicResource ThemeTextDim}" FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Recent changes -->
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="20,16" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Recent Changes" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,12"/>
                                        <StackPanel x:Name="pnlRecentChanges">
                                            <TextBlock Text="No changes recorded yet." FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextDim}" FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- CHANGES TAB -->
                        <Grid x:Name="pnlTabChanges" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Summary header -->
                            <Border Grid.Row="0" Padding="24,12" Background="{DynamicResource ThemeCardBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="lblDiffHeader" Text="Select two snapshots to compare"
                                               FontSize="13" Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                    <Border x:Name="badgeAdded" CornerRadius="4" Background="{DynamicResource ThemeSuccess}"
                                            Padding="8,2" Margin="12,0,0,0" Visibility="Collapsed">
                                        <TextBlock x:Name="lblBadgeAdded" Text="0 Added" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <Border x:Name="badgeRemoved" CornerRadius="4" Background="{DynamicResource ThemeError}"
                                            Padding="8,2" Margin="6,0,0,0" Visibility="Collapsed">
                                        <TextBlock x:Name="lblBadgeRemoved" Text="0 Removed" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <Border x:Name="badgeModified" CornerRadius="4" Background="{DynamicResource ThemeWarning}"
                                            Padding="8,2" Margin="6,0,0,0" Visibility="Collapsed">
                                        <TextBlock x:Name="lblBadgeModified" Text="0 Modified" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <!-- Changes DataGrid -->
                            <ListView x:Name="lstChanges" Grid.Row="1" Background="Transparent" BorderThickness="0"
                                      Margin="16,8" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        </Grid>

                        <!-- TIMELINE TAB -->
                        <ScrollViewer x:Name="pnlTabTimeline" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="24,20">
                            <StackPanel>
                                <TextBlock Text="Timeline" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,12"/>
                                <StackPanel x:Name="pnlTimeline">
                                    <TextBlock Text="Take multiple snapshots to see resource change history."
                                               FontSize="11" Foreground="{DynamicResource ThemeTextDim}" FontStyle="Italic"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- RESOURCES TAB -->
                        <Grid x:Name="pnlTabResources" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Padding="24,12" Background="{DynamicResource ThemeCardBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Resource Inventory" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="lblResourceInventoryCount" Text="" FontSize="11" Margin="10,0,0,0"
                                               Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TreeView x:Name="treeResources" Grid.Row="1" Background="Transparent" BorderThickness="0"
                                      Margin="16,8" Foreground="{DynamicResource ThemeTextPrimary}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </Grid>

                        <!-- SETTINGS TAB -->
                        <ScrollViewer x:Name="pnlTabSettings" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="24,20">
                            <StackPanel MaxWidth="600">
                                <TextBlock Text="Settings" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,0,0,16"/>
                                <!-- Theme -->
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Dark Mode" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThemeTextPrimary}"/>
                                            <TextBlock Text="Toggle between dark and light theme" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextMuted}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="chkDarkMode" Grid.Column="1" IsChecked="True"
                                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <!-- Auto snapshot -->
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Auto-Snapshot on Launch" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThemeTextPrimary}"/>
                                            <TextBlock Text="Automatically take a snapshot when the tool starts" FontSize="10"
                                                       Foreground="{DynamicResource ThemeTextMuted}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="chkAutoSnapshot" Grid.Column="1" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <!-- Retention -->
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,0,0,12">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Snapshot Retention" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextPrimary}"/>
                                                <TextBlock Text="Automatically delete snapshots and diffs older than the specified days" FontSize="10"
                                                           Foreground="{DynamicResource ThemeTextMuted}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <CheckBox x:Name="chkRetentionEnabled" Grid.Column="1" IsChecked="True"
                                                      Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                        </Grid>
                                        <StackPanel x:Name="pnlRetentionDays" Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Days:" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource ThemeTextSecondary}"/>
                                            <TextBox x:Name="txtRetentionDays" Text="90" FontSize="12"
                                                     Padding="8,4" Width="70" HorizontalAlignment="Left"
                                                     Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeTextBody}"
                                                     BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Excluded resource types -->
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Excluded Resource Types" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeTextPrimary}"/>
                                        <TextBlock Text="One type per line (e.g. Microsoft.Advisor/recommendations)" FontSize="10"
                                                   Foreground="{DynamicResource ThemeTextMuted}" Margin="0,4,0,8"/>
                                        <TextBox x:Name="txtExcludedTypes" FontSize="11" Padding="8,6" Height="100"
                                                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Cascadia Code, Consolas, Segoe UI"
                                                 Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeTextBody}"
                                                 BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 3: BOTTOM SPLITTER HANDLE                                     -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <GridSplitter Grid.Row="3" Height="4" Background="Transparent" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" Cursor="SizeNS" Focusable="False"
                      ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 4: DEBUG / ACTIVITY LOG PANEL                                 -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="{DynamicResource ThemeOutputBg}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
            <DockPanel>
                <!-- Log header toolbar -->
                <Border DockPanel.Dock="Top" Padding="12,4" Background="{DynamicResource ThemeDeepBg}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Activity Log" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextSecondary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnClearLog" Style="{StaticResource IconButton}" Content="&#xE74D;"
                                    ToolTip="Clear Log" FontSize="11"/>
                            <Button x:Name="btnToggleBottomSize" Style="{StaticResource IconButton}" ToolTip="Maximize/Restore">
                                <TextBlock x:Name="icoToggleBottomSize" Text="&#xE70E;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                           Foreground="{DynamicResource ThemeTextSecondary}"/>
                            </Button>
                            <Button x:Name="btnHideBottom" Style="{StaticResource IconButton}" Content="&#xE70D;"
                                    ToolTip="Collapse" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Log content -->
                <ScrollViewer x:Name="logScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <RichTextBox x:Name="rtbActivityLog" IsReadOnly="True" Background="Transparent"
                                 BorderThickness="0" Padding="12,6" FontSize="11"
                                 FontFamily="Cascadia Code, Consolas, Segoe UI"
                                 Foreground="{DynamicResource ThemeTextDim}"
                                 VerticalScrollBarVisibility="Disabled">
                        <FlowDocument x:Name="docActivityLog" PagePadding="0">
                            <Paragraph x:Name="paraLog" LineHeight="18"/>
                        </FlowDocument>
                    </RichTextBox>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 5: STATUS BAR                                                 -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="5" Background="{DynamicResource ThemeDeepBg}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="statusDot" Grid.Column="0" Width="6" Height="6"
                         Fill="{DynamicResource ThemeTextDim}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblStatus" Grid.Column="1" Text="Ready" FontSize="10"
                           Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblStatusResourceCount" Grid.Column="3" Text="" FontSize="10" Margin="0,0,16,0"
                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblStatusSub" Grid.Column="4" Text="" FontSize="10"
                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
