<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="PresentationOptions"
        Title="AVD Rewind" Height="860" Width="1340"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        Background="{DynamicResource ThemeAppBg}" Foreground="{DynamicResource ThemeTextBody}" FontFamily="Inter, Segoe UI Variable Display, Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="4" GlassFrameThickness="1" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- THEME BRUSHES (Dark defaults — mutated at runtime for Light Mode) -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="ThemeAppBg"           Color="#111113" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemePanelBg"         Color="#18181B" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeCardBg"          Color="#1E1E1E" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeCardAltBg"       Color="#1A1A1A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeInputBg"         Color="#141414" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeDeepBg"          Color="#0D0D0D" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeOutputBg"        Color="#0A0A0A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSurfaceBg"       Color="#1F1F23" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeHoverBg"         Color="#27272B" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSelectedBg"      Color="#2A2A2A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemePressedBg"       Color="#1A1A1A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccent"          Color="#0078D4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentHover"     Color="#1A8AD4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentLight"     Color="#60CDFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentDim"       Color="#1A0078D4" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeGreenAccent"     Color="#00C853" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeAccentText"      Color="#FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextPrimary"     Color="#FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextBody"        Color="#E0E0E0" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextSecondary"   Color="#A1A1AA" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextMuted"       Color="#71717A" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextDim"         Color="#8B8B93" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextDisabled"    Color="#383838" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeTextFaintest"    Color="#6B6B73" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorder"          Color="#0FFFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderCard"      Color="#0FFFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderElevated"  Color="#333333" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderHover"     Color="#444444" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderMedium"    Color="#1AFFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeBorderSubtle"    Color="#333333" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeScrollThumb"     Color="#999999" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeScrollTrack"     Color="#22FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSuccess"         Color="#00C853" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeWarning"         Color="#F59E0B" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeError"           Color="#FF5000" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeErrorDim"        Color="#20FF5000" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeProgressEdge"    Color="#18FFFFFF" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSidebarBg"       Color="#111113" PresentationOptions:Freeze="False"/>
        <SolidColorBrush x:Key="ThemeSidebarBorder"   Color="#00000000" PresentationOptions:Freeze="False"/>

        <!-- DOT GRID PATTERN -->
        <DrawingBrush x:Key="DotGridBrush" TileMode="Tile" Viewport="0,0,44,44" ViewportUnits="Absolute"
                      Viewbox="0,0,44,44" ViewboxUnits="Absolute" PresentationOptions:Freeze="False">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <SolidColorBrush Color="#1EFFFFFF"/>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="22,22" RadiusX="1.3" RadiusY="1.3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- SCROLLVIEWER: hide corner rectangle -->
        <Style TargetType="{x:Type ScrollViewer}">
            <Style.Resources>
                <Style TargetType="Rectangle">
                    <Setter Property="Fill" Value="Transparent"/>
                </Style>
            </Style.Resources>
        </Style>

        <!-- SCROLLBAR (Minimal 10px, rounded, themed) -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Background="{DynamicResource ThemeScrollTrack}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder" Background="{DynamicResource ThemeScrollThumb}" CornerRadius="4" MinHeight="40" Margin="1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ThemeAccentLight}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ThemeTextPrimary}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="10"/>
                                <Setter Property="MinHeight" Value="10"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!--                        BUTTON STYLES                              -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <!-- TITLE BAR BUTTON -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent" Width="46" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeSurfaceBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TITLE BAR CLOSE BUTTON (red hover) -->
        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent" Width="46" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="#E81123"/></Setter.Value>
                                </Setter>
                                <Setter Property="Foreground"><Setter.Value><SolidColorBrush Color="White"/></Setter.Value></Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="#B90D1C"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACCENT BUTTON (gradient, primary CTA) -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="16,6" BorderThickness="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#005A9E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A8AD4" Offset="0"/>
                                            <GradientStop Color="#0067C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="bdr" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#0078D4" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#005A9E" Offset="0"/>
                                            <GradientStop Color="#004578" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GREEN BUTTON (success CTA) -->
        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="16,6" BorderThickness="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#008F3D" Offset="0"/>
                                    <GradientStop Color="#006E2E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00C853" Offset="0"/>
                                            <GradientStop Color="#008F3D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST BUTTON (secondary, outline) -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="12,5" BorderThickness="1"
                                Background="Transparent" BorderBrush="{DynamicResource ThemeBorderCard}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER GHOST BUTTON -->
        <Style x:Key="DangerGhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="8" Padding="12,5" BorderThickness="1"
                                Background="Transparent" BorderBrush="{DynamicResource ThemeBorderCard}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeErrorDim}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeError}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeError}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ICON BUTTON (32x32 square) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemePressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- THEMED COMBOBOX ITEM -->
        <Style x:Key="SubComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondary}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bdr" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeAccentDim}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeAccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- THEMED COMBOBOX -->
        <Style x:Key="SubComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ThemeDeepBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextDim}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderCard}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SubComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleBtn" ClickMode="Press" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bdr" Background="{DynamicResource ThemeDeepBg}"
                                                BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                                CornerRadius="8" Padding="10,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                           FontSize="10" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource ThemeAccentLight}"/>
                                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentSite" IsHitTestVisible="False" Margin="12,5,24,5"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border x:Name="dropBorder" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260"
                                        Background="{DynamicResource ThemeCardBg}" CornerRadius="8"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Margin="0,2,0,0" Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.4"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TOGGLE SWITCH (CheckBox-based) -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="36" Height="18">
                            <Border x:Name="Track" CornerRadius="9" Background="{DynamicResource ThemeSurfaceBg}"
                                    BorderBrush="{DynamicResource ThemeBorderElevated}" BorderThickness="1"/>
                            <Border x:Name="Knob" Width="12" Height="12" CornerRadius="6"
                                    Background="{DynamicResource ThemeTextMuted}" HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="KnobTranslate" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#0078D4" Offset="0"/>
                                            <GradientStop Color="#0067C0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="Knob" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="White"/></Setter.Value>
                                </Setter>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate" Storyboard.TargetProperty="X"
                                                             To="18" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTranslate" Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="outerCircle" Width="16" Height="16" CornerRadius="8"
                                    BorderBrush="{DynamicResource ThemeBorderMedium}" BorderThickness="1.5"
                                    Background="Transparent" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse x:Name="innerDot" Width="8" Height="8" Fill="{DynamicResource ThemeAccent}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="outerCircle" Property="BorderBrush" Value="{DynamicResource ThemeAccent}"/>
                                <Setter TargetName="innerDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outerCircle" Property="BorderBrush" Value="{DynamicResource ThemeAccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextBody}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Small, Segoe UI"/>
            <Setter Property="Padding" Value="2,2,0,2"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
        </Style>
    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!--                          MAIN LAYOUT                                  -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="rowBottomPanel" Height="160" MinHeight="0"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Full-window dotted background -->
        <Border x:Name="bdrDotGrid" Grid.Row="0" Grid.RowSpan="6" Panel.ZIndex="-2"
                Background="{DynamicResource DotGridBrush}" IsHitTestVisible="False"/>

        <!-- Full-window gradient glow overlay -->
        <Border x:Name="bdrGradientGlow" Grid.Row="0" Grid.RowSpan="6" Panel.ZIndex="-1"
                IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,0" RadiusX="1.2" RadiusY="1.0">
                    <GradientStop Color="#08338833" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Confetti canvas -->
        <Canvas x:Name="cnvConfetti" Grid.Row="0" Grid.RowSpan="6" Panel.ZIndex="999"
                IsHitTestVisible="False" Visibility="Collapsed"/>

        <!-- Toast notification host -->
        <StackPanel x:Name="pnlToastHost" Grid.Row="2" Panel.ZIndex="100"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="0,12,24,0" IsHitTestVisible="False"/>

        <!-- ═══════════════ ROW 0: CUSTOM TITLE BAR ═══════════════ -->
        <Border x:Name="titleBar" Grid.Row="0" Background="{DynamicResource ThemeDeepBg}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Border Background="{DynamicResource ThemeAccent}" CornerRadius="4" Width="20" Height="20" Margin="0,0,8,0">
                        <TextBlock Text="&#xE7AD;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="lblTitle" Text="AVD Rewind" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblTitleVersion" Text="v0.1.0-alpha" FontSize="9" Margin="8,0,0,0"
                               Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                    <Border CornerRadius="4" Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center"
                            BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                        <TextBlock Text="EXPERIMENTAL" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource ThemeWarning}"/>
                    </Border>
                </StackPanel>
                <Button x:Name="btnHelp" Grid.Column="2" Style="{StaticResource TitleBarButton}" Content="?"
                        FontSize="13" FontFamily="Segoe UI" FontWeight="Bold" ToolTip="Help"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button x:Name="btnThemeToggle" Grid.Column="3" Style="{StaticResource TitleBarButton}"
                        Content="&#x2600;" FontSize="13" FontFamily="Segoe UI"/>
                <Button x:Name="btnMinimize" Grid.Column="4" Style="{StaticResource TitleBarButton}" Content="&#xE921;"/>
                <Button x:Name="btnMaximize" Grid.Column="5" Style="{StaticResource TitleBarButton}" Content="&#xE922;"/>
                <Button x:Name="btnClose"    Grid.Column="6" Style="{StaticResource TitleBarCloseButton}" Content="&#xE8BB;"/>
            </Grid>
        </Border>

        <!-- ═══════════════ ROW 1: AUTH BAR ═══════════════ -->
        <Border Grid.Row="1" Background="{DynamicResource ThemeSidebarBg}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="12" Padding="10,4" Height="26" MinWidth="120"
                        Background="{DynamicResource ThemeInputBg}" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="authDot" Width="7" Height="7" Fill="{DynamicResource ThemeError}" Margin="0,0,7,0"/>
                        <TextBlock x:Name="lblAuthStatus" Text="Not connected" FontSize="11"
                                   Foreground="{DynamicResource ThemeTextMuted}" VerticalAlignment="Center"
                                   MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                <ComboBox x:Name="cmbSubscription" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                          MinWidth="200" MaxWidth="400" Visibility="Collapsed"
                          FontSize="11" FontFamily="Segoe UI Variable Small, Segoe UI"
                          Style="{StaticResource SubComboBox}"
                          ToolTip="Switch between Azure subscriptions. The topology tree updates when you change subscription."/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,4,0">
                    <Button x:Name="btnLogin" Style="{StaticResource AccentButton}" Padding="16,5"
                                ToolTip="Authenticate to Azure using Connect-AzAccount. Required before any AVD operations.">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Sign In" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Button x:Name="btnLogout" Grid.Column="4" Style="{StaticResource DangerGhostButton}"
                        Content="Sign Out" Visibility="Collapsed" Padding="12,4"
                        ToolTip="Disconnect from Azure and clear the cached login session."/>
            </Grid>
        </Border>

        <!-- Accent glow separator -->
        <Border Grid.Row="1" VerticalAlignment="Bottom" Height="1" Panel.ZIndex="1"
                Background="{DynamicResource ThemeAccent}" Opacity="0.25" IsHitTestVisible="False"/>

        <!-- ═══════════════ ROW 2: MAIN CONTENT ═══════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition x:Name="colLeftPanel" Width="260" MinWidth="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT ICON RAIL -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeSidebarBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel Margin="0,8,0,0" DockPanel.Dock="Top">
                        <Button x:Name="btnHamburger" Style="{StaticResource IconButton}"
                                Content="&#xE700;" ToolTip="Toggle Sidebar" Margin="6,0,6,6"/>
                        <!-- Dashboard -->
                        <Button x:Name="railDashboard" Style="{StaticResource IconButton}" ToolTip="Dashboard" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railDashboardIndicator" Width="3" Fill="{DynamicResource ThemeAccentLight}"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Topology -->
                        <Button x:Name="railTopology" Style="{StaticResource IconButton}" ToolTip="Topology" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railTopologyIndicator" Width="3" Fill="Transparent"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE728;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Backups -->
                        <Button x:Name="railBackups" Style="{StaticResource IconButton}" ToolTip="Backups" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railBackupsIndicator" Width="3" Fill="Transparent"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE7B8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Restore -->
                        <Button x:Name="railRestore" Style="{StaticResource IconButton}" ToolTip="Restore" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railRestoreIndicator" Width="3" Fill="Transparent"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Settings -->
                        <Button x:Name="railSettings" Style="{StaticResource IconButton}" ToolTip="Settings" Margin="6,0,6,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Rectangle x:Name="railSettingsIndicator" Width="3" Fill="Transparent"
                                                   HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" Margin="-4,4,0,4"/>
                                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Foreground="{DynamicResource ThemeTextMuted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource ThemeHoverBg}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <Button x:Name="railOutput" Style="{StaticResource IconButton}" ToolTip="Toggle Debug Log"
                            DockPanel.Dock="Bottom" Content="&#xE756;" Margin="6,0,6,8" VerticalAlignment="Bottom"/>
                </DockPanel>
            </Border>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="1" Background="{DynamicResource ThemePanelBg}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12,12">
                    <StackPanel x:Name="pnlSidebar">
                        <!-- Sidebar: Dashboard -->
                        <StackPanel x:Name="pnlSidebarDashboard" Visibility="Visible">
                            <TextBlock Text="O V E R V I E W" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Host Pools" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                    <TextBlock x:Name="lblSidebarHostPools" Text="—" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Session Hosts" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                    <TextBlock x:Name="lblSidebarSessionHosts" Text="—" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeAccentLight}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Last Backup" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                    <TextBlock x:Name="lblSidebarLastBackup" Text="Never" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Sidebar: Topology -->
                        <StackPanel x:Name="pnlSidebarTopology" Visibility="Collapsed">
                            <TextBlock Text="T O P O L O G Y" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <TextBlock Text="Resource Group" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbTopoResourceGroup" FontSize="11" Style="{StaticResource SubComboBox}" Margin="0,0,0,8"
                                         ToolTip="Filter the topology tree to show only resources in the selected resource group. Select (All) to show everything."/>
                            <TextBlock Text="Search" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtTopoSearch" FontSize="11" Padding="8,4" Margin="0,0,0,8"
                                     Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeTextBody}"
                                     BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                                     ToolTip="Type to filter topology nodes by name. Matching is case-insensitive."/>
                        </StackPanel>

                        <!-- Sidebar: Backups -->
                        <StackPanel x:Name="pnlSidebarBackups" Visibility="Collapsed">
                            <TextBlock Text="B A C K U P S" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                    BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Stored Backups" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"/>
                                    <TextBlock x:Name="lblSidebarBackupCount" Text="0" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeAccentLight}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="btnCompareWithCurrent" Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                        ToolTip="Compare the selected backup against the live AVD topology to identify added, removed, or changed resources.">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8F4;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                               Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Compare with Current" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Sidebar: Restore -->
                        <StackPanel x:Name="pnlSidebarRestore" Visibility="Collapsed">
                            <TextBlock Text="R E S T O R E" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <TextBlock Text="Source Backup" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbRestoreSource" FontSize="11" Style="{StaticResource SubComboBox}" Margin="0,0,0,10"
                                         ToolTip="Select the backup snapshot to use as the source for restore operations."/>
                            <TextBlock Text="Target Region" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="rdoSameRegion" Content="Same Region" IsChecked="True" Margin="0,0,12,0"
                                             Style="{StaticResource ThemeRadioButton}"
                                             ToolTip="Restore resources to the same Azure region as the original backup."/>
                                <RadioButton x:Name="rdoDiffRegion" Content="Different" Margin="0,0,0,0"
                                             Style="{StaticResource ThemeRadioButton}"
                                             ToolTip="Restore resources to a different Azure region (e.g. for DR failover)."/>
                            </StackPanel>
                            <ComboBox x:Name="cmbTargetRegion" FontSize="11" Style="{StaticResource SubComboBox}" Margin="0,0,0,8"
                                      Visibility="Collapsed"
                                      ToolTip="Choose the target Azure region for the restore. Regions from the backup are listed first."/>

                            <!-- RG Mapping -->
                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,4,0,8"/>
                            <TextBlock Text="Resource Groups" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox x:Name="chkAutoCreateRg" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="True" ToolTip="Automatically create missing resource groups in the target subscription before restoring resources."
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Auto-create missing RGs" FontSize="11" Foreground="{DynamicResource ThemeTextDim}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel x:Name="pnlRgMapping" Margin="0,0,0,4"/>
                            <TextBlock x:Name="lblRgMappingHint" Text="Select a backup to see resource groups."
                                       FontSize="10" FontStyle="Italic" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4"/>

                            <!-- Session Host Discovery -->
                            <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,4,0,8"/>
                            <TextBlock Text="Session Hosts" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextSecondary}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox x:Name="chkDiscoverVms" Style="{StaticResource ToggleSwitch}"
                                          ToolTip="Discover existing VMs that match the host pool naming pattern but are not in the backup. Useful when the backup is stale."
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Discover VMs by name pattern" FontSize="11" Foreground="{DynamicResource ThemeTextDim}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="lblDiscoverVmsHint" Text=""
                                       FontSize="10" FontStyle="Italic" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,4" Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Sidebar: Settings -->
                        <StackPanel x:Name="pnlSidebarSettings" Visibility="Collapsed">
                            <TextBlock Text="S E T T I N G S" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                       Foreground="{DynamicResource ThemeTextMuted}"/>
                            <TextBlock Text="Settings are displayed in the main panel." FontSize="11"
                                       Foreground="{DynamicResource ThemeTextDim}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Achievements (all contexts) -->
                        <Border Margin="0,20,0,0" Padding="0,10,0,0" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="ACHIEVEMENTS" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeTextMuted}"/>
                                    <TextBlock x:Name="lblAchievementCount" Text="0/15" FontSize="10" Margin="8,0,0,0"
                                               Foreground="{DynamicResource ThemeTextDim}"/>
                                </StackPanel>
                                <WrapPanel x:Name="pnlAchievements"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- GRID SPLITTER -->
            <GridSplitter Grid.Column="2" Width="3" Background="Transparent" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Cursor="SizeWE" Focusable="False"/>

            <!-- MAIN CONTENT AREA -->
            <Grid Grid.Column="3">
                <!-- Tab bar + content -->
                <DockPanel>
                    <!-- Global Progress Bar (WinGetMM style) - above tab row -->
                    <Grid x:Name="pnlGlobalProgress" DockPanel.Dock="Top"
                          Visibility="Collapsed" ClipToBounds="True">
                        <!-- Background track -->
                        <Border Height="22" Background="{DynamicResource ThemeSurfaceBg}" CornerRadius="0"/>
                        <!-- Determinate fill -->
                        <ProgressBar x:Name="prgGlobal" Height="22" Minimum="0" Maximum="100" Value="0"
                                     Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0078D4" Offset="0.0"/>
                                    <GradientStop Color="#60CDFF" Offset="0.5"/>
                                    <GradientStop Color="#0078D4" Offset="1.0"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                        <!-- Indeterminate shimmer (animated gradient band) -->
                        <Border x:Name="bdrShimmer" Height="22" CornerRadius="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0"
                                                     MappingMode="RelativeToBoundingBox" SpreadMethod="Pad">
                                    <GradientStop Color="Transparent"  Offset="0.0"/>
                                    <GradientStop Color="#0078D4"      Offset="0.15"/>
                                    <GradientStop Color="#60CDFF"      Offset="0.35"/>
                                    <GradientStop Color="#0078D4"      Offset="0.55"/>
                                    <GradientStop Color="Transparent"  Offset="0.7"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ShimmerTranslate" X="-500"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             From="-500" To="1200"
                                                             Duration="0:0:2.0"
                                                             AutoReverse="False"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <!-- Subtle top/bottom edge lines -->
                        <Border Height="22" BorderThickness="0,1,0,1"
                                BorderBrush="{DynamicResource ThemeProgressEdge}" IsHitTestVisible="False"/>
                        <!-- Centered label overlay -->
                        <TextBlock x:Name="lblGlobalProgress" Text="" FontSize="11" FontWeight="SemiBold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="Black" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>

                    <!-- Tab row -->
                    <Border DockPanel.Dock="Top" Padding="16,0,16,0"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <!-- Tabs (left) -->
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <Border x:Name="tabDashboard" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                        BorderThickness="0,0,0,2" BorderBrush="{DynamicResource ThemeAccent}">
                                    <TextBlock Text="Dashboard" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThemeTextPrimary}"/>
                                </Border>
                                <Border x:Name="tabTopology" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                        BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                    <TextBlock Text="Topology" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Border>
                                <Border x:Name="tabBackups" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                        BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                    <TextBlock Text="Backups" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Border>
                                <Border x:Name="tabRestore" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                        BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                    <TextBlock Text="Restore" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Border>
                                <Border x:Name="tabSettings" Cursor="Hand" Padding="16,10" Margin="0,0,2,0"
                                        BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                    <TextBlock Text="Settings" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Border>
                            </StackPanel>
                            <!-- Action buttons (right) -->
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0,4,0,4">
                                <Button x:Name="btnRefreshTopology" Style="{StaticResource GreenButton}" VerticalAlignment="Center"
                                        Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Refresh" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnBackupNow" Style="{StaticResource AccentButton}" VerticalAlignment="Center"
                                        Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Backup Now" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnExportReport" Style="{StaticResource GhostButton}" VerticalAlignment="Center"
                                        ToolTip="Export the current topology or backup data as a report.">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Export" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Tab content panels -->
                    <Grid>
                        <!-- STARTUP SPLASH OVERLAY -->
                        <Border x:Name="pnlSplash" Panel.ZIndex="50"
                                Background="{DynamicResource ThemeAppBg}"
                                Visibility="Visible">
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="480" Margin="0,40,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <TextBlock Text="&#xE7AD;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="28"
                                                   Foreground="{DynamicResource ThemeAccent}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="AVD Rewind" FontSize="24" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblSplashVersion" Text="v0.1.0" FontSize="11"
                                               Foreground="{DynamicResource ThemeTextDim}" HorizontalAlignment="Center" Margin="0,0,0,28"/>
                                    <Border CornerRadius="10" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="24,20">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Ellipse x:Name="dotStep1" Width="10" Height="10" Fill="{DynamicResource ThemeTextDim}"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="lblStep1" Text="Checking prerequisites..." FontSize="12"
                                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Ellipse x:Name="dotStep2" Width="10" Height="10" Fill="{DynamicResource ThemeTextDim}"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="lblStep2" Text="Validating Azure credentials..." FontSize="12"
                                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Ellipse x:Name="dotStep3" Width="10" Height="10" Fill="{DynamicResource ThemeTextDim}"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemeTextDim}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="lblStep3" Text="Loading AVD topology..." FontSize="12"
                                                           Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Margin="0,4,0,0" Padding="0,10,0,0"
                                                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
                                                <TextBlock x:Name="lblSplashStatus" Text="Starting up..."
                                                           FontSize="11" Foreground="{DynamicResource ThemeTextMuted}"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ═══════ DASHBOARD TAB ═══════ -->
                        <ScrollViewer x:Name="pnlTabDashboard" VerticalScrollBarVisibility="Auto" Padding="24,20">
                            <StackPanel>
                                <TextBlock Text="DASHBOARD" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16">
                                    <Run>Overview of your Azure Virtual Desktop environment. Counters update after each Refresh or Backup operation. Use the quick actions below to navigate to common tasks.</Run>
                                </TextBlock>
                                <UniformGrid x:Name="pnlDashboardCards" Columns="5" Margin="0,0,0,20">
                                    <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Host Pools" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"
                                                       ToolTip="Number of AVD host pools discovered in the current subscription"/>
                                            <TextBlock x:Name="lblDashHostPools" Text="—" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeTextPrimary}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="App Groups" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"
                                                       ToolTip="Number of application groups (Desktop or RemoteApp) linked to host pools"/>
                                            <TextBlock x:Name="lblDashAppGroups" Text="—" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeAccentLight}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Workspaces" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"
                                                       ToolTip="Number of AVD workspaces that aggregate app groups for end-user access"/>
                                            <TextBlock x:Name="lblDashWorkspaces" Text="—" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeWarning}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Session Hosts" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"
                                                       ToolTip="Total session host VMs registered across all host pools"/>
                                            <TextBlock x:Name="lblDashSessionHosts" Text="—" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeSuccess}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                            BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Scaling Plans" FontSize="10" Foreground="{DynamicResource ThemeTextMuted}"
                                                       ToolTip="Number of autoscale plans governing host pool capacity"/>
                                            <TextBlock x:Name="lblDashScalingPlans" Text="—" FontSize="28" FontWeight="Bold"
                                                       Foreground="{DynamicResource ThemeGreenAccent}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                                <!-- Drift indicator -->
                                <Border x:Name="pnlDriftBanner" CornerRadius="8" Padding="16,10" Margin="0,0,0,20" Visibility="Collapsed"
                                        Background="{DynamicResource ThemeCardBg}" BorderBrush="{DynamicResource ThemeWarning}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="{DynamicResource ThemeWarning}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock x:Name="lblDriftMessage" Text="" FontSize="12"
                                                   Foreground="{DynamicResource ThemeTextBody}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- Quick actions -->
                                <TextBlock Text="QUICK ACTIONS" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Button x:Name="btnQuickBackup" Style="{StaticResource AccentButton}" Margin="0,0,8,0"
                                            ToolTip="Snapshot the current AVD topology to a local JSON file for disaster recovery">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Take Backup" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="btnQuickRestore" Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                                            ToolTip="Navigate to the Restore tab to recreate AVD resources from a backup">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Restore" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="btnQuickCompare" Style="{StaticResource GhostButton}"
                                            ToolTip="Compare the live environment against a previous backup to detect configuration drift">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8F4;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Compare Drift" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <!-- Recent activity placeholder -->
                                <TextBlock Text="RECENT ACTIVITY" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                <StackPanel x:Name="pnlRecentActivity">
                                    <TextBlock Text="No activity yet. Connect to Azure and take your first backup."
                                               FontSize="12" Foreground="{DynamicResource ThemeTextDim}" FontStyle="Italic"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ═══════ TOPOLOGY TAB ═══════ -->
                        <ScrollViewer x:Name="pnlTabTopology" VerticalScrollBarVisibility="Auto" Padding="24,20"
                                      Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="AVD ENVIRONMENT TOPOLOGY" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                 <TextBlock xml:space="preserve" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16"><Run FontWeight="SemiBold">Interactive resource tree</Run><Run> of your Azure Virtual Desktop environment. Click </Run><Run FontWeight="SemiBold">Refresh</Run><Run> to query the current subscription. Each node shows the resource type, name, location, and status. Use the sidebar filters to narrow by resource group or search by name.</Run></TextBlock>
                                <TreeView x:Name="tvTopology" Background="Transparent" BorderThickness="0"
                                          Foreground="{DynamicResource ThemeTextBody}" Padding="0,0,0,20"/>
                                <TextBlock x:Name="lblTopologyEmpty" Text="Connect to Azure and click Refresh to load the AVD topology."
                                           FontSize="12" Foreground="{DynamicResource ThemeTextDim}" FontStyle="Italic"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ═══════ BACKUPS TAB ═══════ -->
                        <ScrollViewer x:Name="pnlTabBackups" VerticalScrollBarVisibility="Auto" Padding="24,20"
                                      Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="BACKUP HISTORY" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                 <TextBlock xml:space="preserve" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16"><Run>Each backup is a point-in-time JSON snapshot of your AVD topology including host pools, application groups, workspaces, session hosts, RBAC assignments, scaling plans, and diagnostic settings. Backups are stored in </Run><Run FontFamily="Cascadia Mono, Consolas" FontSize="11">backups\</Run><Run> relative to the script folder. Select a backup and click </Run><Run FontWeight="SemiBold">Compare with Current</Run><Run> to detect drift.</Run></TextBlock>
                                <ListBox x:Name="lstBackups" Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource ThemeTextBody}" MaxHeight="600"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                                <TextBlock x:Name="lblBackupsEmpty" Text="No backups found. Click 'Backup Now' to create your first backup."
                                           FontSize="12" Foreground="{DynamicResource ThemeTextDim}" FontStyle="Italic" Margin="0,10,0,0"/>
                                <!-- Diff overlay area -->
                                <Border x:Name="pnlDiffOverlay" CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,20,0,0" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="COMPARISON RESULTS" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                                   Foreground="{DynamicResource ThemeTextMuted}"/>
                                        <StackPanel x:Name="pnlDiffResults"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ═══════ RESTORE TAB ═══════ -->
                        <ScrollViewer x:Name="pnlTabRestore" VerticalScrollBarVisibility="Auto" Padding="24,20"
                                      Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="SELECTIVE RESTORE" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                 <TextBlock xml:space="preserve" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16"><Run FontWeight="SemiBold">Recreate AVD resources</Run><Run> from a backup snapshot. Select a source backup in the sidebar, then check the items you want to restore. Use </Run><Run FontWeight="SemiBold">Dry Run</Run><Run> to validate the plan without making changes, or </Run><Run FontWeight="SemiBold">Export Plan</Run><Run> to save the restore manifest as JSON for review. </Run><Run FontWeight="SemiBold">Execute Restore</Run><Run> requires typing RESTORE to confirm. Resources are created in the target subscription and region.</Run></TextBlock>
                                <!-- Restore object tree with checkboxes -->
                                <TreeView x:Name="tvRestoreTree" Background="Transparent" BorderThickness="0"
                                          Foreground="{DynamicResource ThemeTextBody}" MinHeight="200" MaxHeight="500"/>
                                <TextBlock x:Name="lblRestoreEmpty" Text="Select a backup from the sidebar to populate the restore tree."
                                           FontSize="12" Foreground="{DynamicResource ThemeTextDim}" FontStyle="Italic" Margin="0,10,0,0"/>
                                <!-- Pre-flight checks -->
                                <Border x:Name="pnlPreFlight" CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,20,0,0" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="PRE-FLIGHT CHECKS" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                                   Foreground="{DynamicResource ThemeTextMuted}"/>
                                        <StackPanel x:Name="pnlPreFlightResults"/>
                                    </StackPanel>
                                </Border>
                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                    <Button x:Name="btnExecuteRestore" Style="{StaticResource GreenButton}" Margin="0,0,8,0" IsEnabled="False"
                                            ToolTip="Deploy selected resources to Azure. Requires typing RESTORE to confirm.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Execute Restore" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="btnDryRun" Style="{StaticResource GhostButton}" Margin="0,0,8,0" IsEnabled="False"
                                            ToolTip="Validate the restore plan without creating any resources. Checks required fields and API compatibility.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Dry Run" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="btnExportPlan" Style="{StaticResource GhostButton}" IsEnabled="False"
                                            ToolTip="Save the restore manifest as a structured JSON file for offline review or audit.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEDE1;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Export Plan" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ═══════ SETTINGS TAB ═══════ -->
                        <ScrollViewer x:Name="pnlTabSettings" VerticalScrollBarVisibility="Auto" Padding="24,20"
                                      Visibility="Collapsed">
                            <StackPanel MaxWidth="640">
                                <TextBlock Text="PREFERENCES" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,16">
                                    <Run>Configure application behaviour, theme, and backup retention. Prerequisites are checked at startup — any missing PowerShell modules are listed below with install commands.</Run>
                                </TextBlock>

                                <!-- PREREQUISITES STATUS -->
                                <TextBlock Text="PREREQUISITES" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource ThemeTextDim}" Margin="0,0,0,10">
                                            <Run>AVD Rewind requires the following Az PowerShell modules. Install missing modules from an elevated PowerShell prompt.</Run>
                                        </TextBlock>
                                        <StackPanel x:Name="pnlPrereqStatus"/>
                                    </StackPanel>
                                </Border>
                                <Button x:Name="btnCopyInstallCmd" Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                                        Margin="0,4,0,16" Padding="12,5" Visibility="Collapsed"
                                        ToolTip="Copy the Install-Module command for all missing modules to the clipboard">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                                   Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="lblCopyInstallCmd" Text="Copy Install Command" FontSize="11"
                                                   Foreground="{DynamicResource ThemeTextSecondary}"/>
                                    </StackPanel>
                                </Button>
                                <Border Height="1" Background="{DynamicResource ThemeBorder}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="GENERAL" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                <!-- Theme -->
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Dark Mode" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThemeTextPrimary}"/>
                                            <TextBlock Text="Switch between dark and light theme" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="chkDarkMode" Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="True" VerticalAlignment="Center"
                                                  ToolTip="Toggle between dark and light colour schemes. Preference is saved automatically."/>
                                    </Grid>
                                </Border>
                                <!-- Auto-backup -->
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Auto-backup on Launch" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThemeTextPrimary}"/>
                                            <TextBlock Text="Automatically create a backup when the tool starts" FontSize="11"
                                                       Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="chkAutoBackup" Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  ToolTip="When enabled, a topology backup is created automatically each time the tool starts and connects to Azure."/>
                                    </Grid>
                                </Border>
                                <!-- Retention -->
                                <Border CornerRadius="8" Background="{DynamicResource ThemeCardBg}"
                                        BorderBrush="{DynamicResource ThemeBorderCard}" BorderThickness="1"
                                        Padding="16,14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Backup Retention" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeTextPrimary}"/>
                                                <TextBlock Text="Auto-delete backups older than N days" FontSize="11"
                                                           Foreground="{DynamicResource ThemeTextMuted}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <CheckBox x:Name="chkRetentionEnabled" Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                      VerticalAlignment="Center"
                                                      ToolTip="Automatically remove backups older than the specified number of days to save disk space."/>
                                        </Grid>
                                        <StackPanel x:Name="pnlRetentionDays" Orientation="Horizontal" Margin="0,10,0,0" Visibility="Collapsed">
                                            <TextBlock Text="Days:" FontSize="11" Foreground="{DynamicResource ThemeTextSecondary}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox x:Name="txtRetentionDays" Text="30" Width="60" FontSize="11" Padding="8,4"
                                                     ToolTip="Number of days to keep backups before automatic cleanup. Default: 30 days."
                                                     Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeTextBody}"
                                                     BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Reset -->
                                <Button x:Name="btnResetSettings" Style="{StaticResource DangerGhostButton}" Content="Reset to Defaults"
                                        HorizontalAlignment="Left" Margin="0,10,0,20" Padding="16,6"
                                        ToolTip="Reset all settings (theme, auto-backup, retention) to their default values."/>

                                <!-- Achievements panel -->
                                <TextBlock Text="ACHIEVEMENTS" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                                <WrapPanel x:Name="pnlAchievementsSettings"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- ═══════════════ ROW 3: SPLITTER HANDLE ═══════════════ -->
        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="Transparent" Cursor="SizeNS" Focusable="False"/>

        <!-- ═══════════════ ROW 4: DEBUG LOG PANEL ═══════════════ -->
        <Border Grid.Row="4" Background="{DynamicResource ThemeOutputBg}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,6"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Activity Log" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="btnClearLog" Grid.Column="1" Style="{StaticResource IconButton}"
                                Content="&#xE74D;" ToolTip="Clear Log" FontSize="11"/>
                    </Grid>
                </Border>
                <RichTextBox x:Name="logScroller" Background="Transparent" Foreground="{DynamicResource ThemeTextDim}"
                             FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="11"
                             IsReadOnly="True" BorderThickness="0" Padding="12,6"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <FlowDocument>
                        <Paragraph x:Name="paraLog"/>
                    </FlowDocument>
                </RichTextBox>
            </DockPanel>
        </Border>

        <!-- ═══════════════ ROW 5: STATUS BAR ═══════════════ -->
        <Border Grid.Row="5" Background="{DynamicResource ThemeDeepBg}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblStatusBar" Grid.Column="0" Text="Ready" FontSize="10"
                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblStatusRight" Grid.Column="1" Text="" FontSize="10"
                           Foreground="{DynamicResource ThemeTextDim}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
